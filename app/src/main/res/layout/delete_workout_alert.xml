<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="@color/tabbackground"
        android:layout_height="wrap_content"
        android:layout_margin="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <ImageView
                android:layout_width="60dp"
                android:id="@+id/im"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"
                android:src="@drawable/c_ircle"
                android:layout_height="60dp"/>
            <TextView
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="24sp"
                android:fontFamily="@font/manrope_bold"
                android:layout_gravity="center"
                android:layout_below="@+id/im"
                android:gravity="center"
                android:id="@+id/tv"
                android:text="@string/delete_workout"
                android:textColor="@color/white"/>
            <TextView
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:fontFamily="@font/manrope_semi_bold"
                android:layout_gravity="center"
                android:layout_below="@+id/im"
                android:gravity="center"
                android:id="@+id/tvmsg"
                android:text="@string/you_re_going_to_delete_this_workout_are_you_sure"
                android:textColor="@color/smallTextcolor"
                android:textStyle="bold"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_below="@+id/tv"
                android:layout_marginBottom="30dp"
                android:layout_marginTop="40dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tvcancel"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:background="@drawable/white_rectangle_package"
                    android:gravity="center"
                    android:paddingVertical="15dp"
                    android:fontFamily="@font/manrope_bold"
                    android:text="@string/no_keep_it"
                    android:textAllCaps="true"
                    android:textColor="@color/white"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/tvdelete"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:background="@drawable/white_rectangle"
                    android:gravity="center"
                    android:paddingVertical="15dp"
                    android:fontFamily="@font/manrope_bold"
                    android:textStyle="bold"
                    android:text="@string/yes_delete"
                    android:textColor="@color/buttontextcolor"
                    android:textAllCaps="true"
                    android:textSize="16sp" />

            </LinearLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

</RelativeLayout>