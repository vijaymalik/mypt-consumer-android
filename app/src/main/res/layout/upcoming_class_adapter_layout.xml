<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:id="@+id/relative"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginStart="2dp"
        app:cardCornerRadius="20dp"
        android:layout_width="280dp"
        android:layout_height="320dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:scaleType="centerCrop"
                android:id="@+id/classImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/upcoming_class_dummy"
                />
            <androidx.cardview.widget.CardView
                android:layout_margin="10dp"
                app:cardCornerRadius="8dp"

                app:cardBackgroundColor="@color/home_frag_blk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:textSize="12sp"
                    android:paddingVertical="5dp"
                    android:paddingHorizontal="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="26 Aug - 9PM - 11PM"
                    android:id="@+id/dateTime"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:textColor="@color/headingcolor"/>
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:layout_alignParentBottom="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.cardview.widget.CardView
                    app:cardCornerRadius="15dp"
                    android:layout_margin="10dp"
                    app:cardBackgroundColor="@color/home_frag_blk"
                    android:layout_alignParentBottom="true"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:gravity="center_vertical"
                        android:padding="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <TextView
                                android:textSize="12sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MyPT Zumba Classes"
                                android:id="@+id/className"
                                android:maxLength="17"
                                android:fontFamily="@font/manrope_medium"
                                android:textColor="@color/white"/>
                            <TextView
                                android:textSize="10sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Location: My PT Studio, Cedre Community Center, DSO, Dubai"
                                android:id="@+id/location"
                                android:maxLines="3"
                                android:ellipsize="end"
                                android:fontFamily="@font/manrope_medium"
                                android:textColor="@color/location_color"/>
                        </LinearLayout>
                        <View
                            android:layout_marginHorizontal="10dp"
                            android:layout_marginVertical="5dp"
                            android:background="@drawable/line_gradient"
                            android:layout_width="1dp"
                            android:layout_height="match_parent"/>
                        <TextView
                            android:textSize="20sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="200 AED\nOnwards"
                            android:id="@+id/price"
                            android:gravity="end"
                            android:fontFamily="@font/clash_display_medium"
                            android:textColor="@color/txt_clr_1"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>