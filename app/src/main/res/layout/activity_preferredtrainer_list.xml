<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".RenewSubscription.PrefferedTrainerListActivity">
    <ImageView
        android:id="@+id/im"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:src="@drawable/chest_press_dark_blur"
        />
    <ImageView
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:id="@+id/back"
        android:layout_alignParentTop="true"
        android:layout_marginTop="20dp"
        android:layout_marginLeft="15dp"
        android:layout_alignParentStart="true"
        android:src="@drawable/backarrow"
        />
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_below="@id/back"
        android:layout_above="@id/cardContinue"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_below="@id/back"
            android:id="@+id/linear"
            android:orientation="vertical"
            android:layout_marginTop="20dp"
            android:layout_height="wrap_content">
            <TextView
                android:layout_marginHorizontal="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="32sp"
                android:gravity="center"
                android:fontFamily="@font/clash_display_medium"
                android:text="@string/choose_your_preferred_trainer"
                />
            <TextView
                android:layout_marginHorizontal="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="14sp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:fontFamily="@font/manrope_semi_bold"
                android:text="@string/select_your_trainer_to_help_us_appreciate_their_efforts"
                />
            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:orientation="vertical"
                android:id="@+id/trainerRecycler"
                android:layout_marginTop="20dp"
                android:nestedScrollingEnabled="false"
                android:layout_height="wrap_content"/>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_marginHorizontal="15dp"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="20dp"
                android:layout_above="@+id/cardContinue"
                android:id="@+id/cardSelectTrainer"
                app:cardBackgroundColor="#101113"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14sp"
                        android:paddingStart="15dp"
                        android:paddingVertical="22dp"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:text="@string/select_later"
                        />
                    <CheckBox
                        android:paddingHorizontal="5dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:id="@+id/checkDebit"
                        android:buttonTint="@color/headingcolor"
                        style="@style/CustomCheckboxBrand"
                        android:fontFamily="@font/manrope_medium"
                        />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="15dp"
        app:cardBackgroundColor="#FAFAFA"
        app:cardCornerRadius="12dp"
        android:id="@+id/cardContinue"
        android:layout_marginBottom="10dp"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000502"
            android:textSize="16sp"
            android:gravity="center"
            android:textAllCaps="true"
            android:paddingVertical="15dp"
            android:fontFamily="@font/manrope_bold"
            android:text="@string/cont_inue"
            />
    </androidx.cardview.widget.CardView>

</RelativeLayout>