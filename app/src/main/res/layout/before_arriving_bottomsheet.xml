<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent"
    xmlns:card_view="http://schemas.android.com/tools">
    <LinearLayout
        android:layout_width="match_parent"
        android:background="@drawable/top_rounded_corners"
        app:cardCornerRadius="15dp"
        android:id="@+id/standard_bottom_sheet"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:orientation="vertical"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:background="@drawable/arriving_brown_gradient"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:fontFamily="serif-monospace"
                android:text="Things to prepare before Christene Koning arrives"/>
            <ImageView
                android:layout_width="16dp"
                android:layout_marginLeft="10dp"
                android:src="@drawable/arrow_right"
                android:layout_height="16dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_marginHorizontal="15dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_marginEnd="10dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:id="@+id/tvAddress"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_regular_400"
                    android:text="Arriving at your home - 23B,Dubai Mall Street Road"
                    />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/time_drawable"
                    android:paddingVertical="10dp"
                    android:layout_marginRight="15dp"
                    android:paddingHorizontal="15dp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_medium"
                        android:text="67"
                        />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:text="@string/mins"
                        />
                </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="15dp"
                android:layout_height="wrap_content"

                android:orientation="horizontal">
                <androidx.cardview.widget.CardView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    app:cardCornerRadius="26dp"
                    app:cardBackgroundColor="#1C1F21"> <!-- Outer boundary color -->

                    <androidx.cardview.widget.CardView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="25dp"
                        app:cardBackgroundColor="#09131D"> <!-- Inner boundary color -->

                        <!-- Content (optional) -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"

                            android:src="@drawable/dummy_trainer" />

                    </androidx.cardview.widget.CardView>
                </androidx.cardview.widget.CardView>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="10dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="16sp"
                        android:maxLines="2"
                        android:id="@+id/tvTrainer_name"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:text="Christene De Koning"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/recycler"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:orientation="horizontal"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:orientation="vertical"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"

                        android:orientation="horizontal">
                        <EditText
                            android:id="@+id/ed1"
                            android:layout_width="30dp"
                            android:layout_height="32dp"
                            android:fontFamily="@font/manrope_bold"
                            android:ems="2"
                            android:textSize="14sp"
                            android:layout_marginEnd="5dp"
                            android:gravity="center"
                            android:inputType="number"
                            android:autofillHints="smsOTPCode"
                            android:importantForAutofill="yes"
                            android:background="@drawable/arriving_otp_gradient"
                            android:maxLength="1"
                            android:textColor="@color/white" />
                        <EditText
                            android:id="@+id/ed2"
                            android:layout_width="30dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="5dp"
                            android:background="@drawable/arriving_otp_gradient"
                            android:ems="2"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:autofillHints="smsOTPCode"
                            android:fontFamily="@font/manrope_bold"
                            android:importantForAutofill="yes"
                            android:textColor="@color/white" />
                        <EditText
                            android:id="@+id/ed3"
                            android:layout_width="30dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="5dp"
                            android:textSize="14sp"
                            android:background="@drawable/arriving_otp_gradient"
                            android:ems="2"
                            android:fontFamily="@font/manrope_bold"
                            android:autofillHints="smsOTPCode"
                            android:importantForAutofill="yes"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="@color/white"/>
                        <EditText
                            android:id="@+id/ed4"
                            android:layout_width="30dp"
                            android:fontFamily="@font/manrope_bold"
                            android:layout_height="32dp"
                            android:background="@drawable/arriving_otp_gradient"
                            android:ems="2"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:autofillHints="smsOTPCode"
                            android:importantForAutofill="yes"
                            android:textColor="@color/white" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="12sp"
                        android:layout_marginTop="10dp"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:text="@string/otp_for_session"/>
                </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="20dp"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="16sp"
                    android:textAllCaps="true"
                    android:id="@+id/tvTrainerSessionDetail"
                    android:fontFamily="@font/manrope_bold"
                    android:text="@string/training_session_details"/>
                <ImageView
                    android:layout_width="24dp"
                    android:layout_marginLeft="10dp"
                    android:src="@drawable/arrow_right"
                    android:layout_height="24dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_marginBottom="10dp"
                android:background="@drawable/grey_rounded_corner_rectangle"
                android:layout_width="match_parent"
                android:layout_marginTop="50dp"
                android:paddingStart="20dp"
                android:layout_marginHorizontal="15dp"
                android:gravity="center_vertical"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:layout_marginHorizontal="10dp"
                    android:src="@drawable/baseline_info_outline_24"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    app:tint="@color/fast_filling" />
                <TextView
                    android:letterSpacing=".12"
                    android:layout_width="wrap_content"
                    android:id="@+id/tvcontinue"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:fontFamily="@font/manrope_medium"
                    android:paddingVertical="15dp"
                    android:text="@string/we_won_t_be_charging_you_a_cancellation_fee"
                    android:textColor="@color/white"
                    android:textSize="12sp" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:id="@+id/cancelBooking"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginBottom="35dp"
                android:background="@drawable/rectangle_btn"
                android:gravity="center"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="15dp"
                android:textFontWeight="700"
                android:textAllCaps="true"
                android:text="@string/cancel_booking"
                android:textStyle="bold"
                android:textColor="@color/headingcolor"
                android:textSize="16dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>