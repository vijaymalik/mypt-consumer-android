<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/buttontextcolor"
    android:fitsSystemWindows="true"
    tools:context=".WorkoutLibrary.SpiderWebSessionSummaryActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/linearHeader"
        android:layout_alignParentTop="true"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/headerLayout"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:id="@+id/back_1"
                android:layout_marginHorizontal="10dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/backarrow"
                />
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/session_summary"
                />


        </LinearLayout>
        <View
            android:background="@color/tabbackground"
            android:layout_width="match_parent"

            android:layout_height="2dp"/>


    </LinearLayout>

    <com.github.mikephil.charting.charts.RadarChart
        android:id="@+id/chart1"
        android:visibility="gone"
        android:layout_below="@+id/linearHeader"
        android:layout_width="match_parent"
        android:layout_above="@+id/tvMyPTScore"
        android:background="@color/buttontextcolor"
        android:layout_marginBottom="20dp"
        android:layout_height="match_parent" />
    <co.com.mypt.utils.RadarView
        android:id="@+id/radarchart"
        android:layout_below="@+id/linearHeader"
        android:layout_width="match_parent"
        android:layout_above="@+id/tvMyPTScore"
        android:background="@color/buttontextcolor"
        android:layout_marginBottom="20dp"
        android:layout_height="match_parent" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/headingcolor"
        android:textSize="14sp"
        android:textStyle="bold"
        android:id="@+id/tvMyPTScore"
        android:gravity="center"
        android:layout_above="@+id/tvScore"
        android:fontFamily="@font/clash_display_medium"
        android:text="@string/mypt_score"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/booked"
        android:textSize="80sp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="40dp"
        android:textStyle="bold"

        android:gravity="center"
        android:id="@+id/tvScore"
        android:layout_above="@+id/tvgymtext"
        android:fontFamily="@font/clash_display_medium"
        android:text="89"/>
    <TextView
        android:layout_width="match_parent"
        android:id="@+id/tvgymtext"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginBottom="15dp"
        android:background="@drawable/grey_rounded_corner_rectangle"
        android:gravity="center"
        android:fontFamily="@font/manrope_medium"
        android:paddingVertical="20dp"
        android:textStyle="bold"
        android:layout_above="@+id/tv_complete"
        android:text="@string/you_re_crushing_it_at_the_gym"
        android:textColor="@color/subheadingcolor"
        android:textSize="12sp" />
    <TextView
        android:layout_width="match_parent"
        android:id="@+id/tv_complete"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginBottom="15dp"
        android:background="@drawable/white_rectangle"
        android:gravity="center"
        android:fontFamily="@font/manrope_medium"
        android:paddingVertical="20dp"
        android:textFontWeight="700"
        android:layout_alignParentBottom="true"
        android:textAllCaps="true"
        android:text="@string/cont_inue"
        android:textColor="@color/buttontextcolor"
        android:textSize="16sp" />
</RelativeLayout>