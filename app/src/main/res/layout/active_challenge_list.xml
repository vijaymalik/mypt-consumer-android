<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:id="@+id/activeChallenge"
        android:padding="15dp"
        android:background="@drawable/workout_gradient_rectangle"
        android:layout_marginHorizontal="15dp"
        android:layout_marginTop="15dp"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:orientation="horizontal">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/transparent_white_1"
                android:textSize="12sp"
                android:fontFamily="@font/manrope_medium"
                android:text="HIIT Training"
                />
            <TextView
                android:layout_marginTop="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:id="@+id/tvChallenge"
                android:textColor="@color/white"
                android:fontFamily="@font/clash_display_semibold"
                android:text="Strength Challenge"
                />
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.cardview.widget.CardView
                    android:layout_width="12dp"
                    app:cardCornerRadius="4dp"
                    app:cardBackgroundColor="@color/orangecolor"
                    android:layout_height="12dp"/>
                <TextView
                    android:layout_marginStart="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/transparent_white_1"
                    android:fontFamily="@font/manrope_medium"
                    android:textSize="12sp"
                    android:id="@+id/tvWeeks"
                    android:text="8 weeks"
                    />
                <androidx.cardview.widget.CardView
                    android:layout_width="12dp"
                    android:layout_marginStart="12dp"
                    app:cardCornerRadius="4dp"
                    app:cardBackgroundColor="@color/progressBlue"
                    android:layout_height="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/transparent_white_1"
                    android:textSize="12sp"
                    android:layout_marginStart="4dp"
                    android:id="@+id/tvWorkouts"
                    android:fontFamily="@font/manrope_medium"
                    android:text="12 workouts"
                    />
            </LinearLayout>
            <androidx.cardview.widget.CardView
                app:cardCornerRadius="8dp"
                android:id="@+id/tvViewChallenge"
                android:layout_marginTop="12dp"
                android:layout_width="151dp"
                android:layout_height="42dp">
                <LinearLayout
                    android:layout_margin="10dp"
                    android:orientation="horizontal"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/buttontextcolor"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp"
                        android:fontFamily="@font/manrope_bold"
                        android:text="@string/view_challenge"
                        />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_marginVertical="10dp"
            android:layout_height="wrap_content">
            <co.com.mypt.utils.CircularFillView
                android:rotation="90"
                android:id="@+id/circularBlueView"
                android:layout_width="127dp"
                android:layout_height="127dp"/>
            <co.com.mypt.utils.CircularFillView
                android:rotation="90"
                android:id="@+id/circularOrangeView"
                android:layout_width="100dp"
                android:layout_centerInParent="true"
                android:layout_height="100dp"/>
            <LinearLayout
                android:layout_width="75dp"
                android:paddingLeft="6dp"
                android:paddingBottom="5dp"
                android:layout_centerInParent="true"
                android:layout_height="75dp">
                <androidx.cardview.widget.CardView

                    app:cardCornerRadius="17dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:src="@drawable/weight_im"
                        android:layout_centerInParent="true"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </RelativeLayout>
    </LinearLayout>
</RelativeLayout>