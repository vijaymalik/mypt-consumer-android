<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:layout_height="540dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@+id/trainerImage"
        android:scaleType="centerCrop"
        android:src="@drawable/gym"
        android:layout_marginTop="3dp"
        android:layout_width="match_parent"
        android:layout_height="400dp"
        />
    <RelativeLayout
        android:layout_width="match_parent"
        android:gravity="center"
        android:layout_marginTop="-3dp"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="128dp"
            android:text="MY PT Studio"
            android:textSize="12dp"
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/tvtag"
            android:paddingBottom="5dp"
            android:fontFamily="@font/manrope_bold"
            android:background="@drawable/im_tag"
            android:layout_height="34dp"/>

    </RelativeLayout>
    <ImageView
        android:layout_width="match_parent"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        android:layout_marginTop="3dp"
        android:layout_height="400dp"
        android:src="@drawable/b_w_gradient"/>
    <LinearLayout
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:paddingHorizontal="15dp"
            android:paddingVertical="10dp"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:id="@+id/userName"
                android:fontFamily="@font/clash_display_medium"
                android:text="MyPT Studio Dubai"
                />
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/location"/>
                <TextView
                    android:id="@+id/distance"
                    android:layout_marginHorizontal="3dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:text="2205.41km"
                    android:textSize="12sp"/>
                <View
                    android:layout_marginEnd="3dp"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:layout_gravity="center"
                    android:background="@drawable/dot"/>
                <TextView
                    android:id="@+id/place"
                    android:layout_width="90dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:minLines="1"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textSize="12sp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">
                    <View
                        android:layout_marginHorizontal="3dp"
                        android:layout_width="3dp"
                        android:layout_height="3dp"
                        android:layout_gravity="center"
                        android:background="@drawable/dot"/>
                    <TextView
                        android:id="@+id/time"
                        android:text="06:00 AM-10:00 PM"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/white"
                        android:textSize="12sp"/>

                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/star"/>
                <TextView
                    android:id="@+id/avgRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="12sp"/>
                <View
                    android:layout_marginHorizontal="3dp"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@drawable/dot"/>
                <TextView
                    android:id="@+id/totalRatings"

                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:layout_marginStart="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:id="@+id/exerciseRecyclerView"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:text="@string/view_details"
                android:layout_weight="1"
                android:textColor="@color/headingcolor"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:id="@+id/tvDetail"
                android:textAllCaps="true"
                android:layout_marginEnd="8dp"
                android:fontFamily="@font/manrope_medium"
                android:layout_height="56dp"
                android:background="@drawable/view_detail_rectangle"/>
            <androidx.cardview.widget.CardView
                app:cardBackgroundColor="@color/headingcolor"
                android:layout_marginStart="8dp"
                app:cardCornerRadius="15dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:id="@+id/tvConfirmGym"
                android:layout_height="wrap_content">
                <TextView
                    android:background="@color/headingcolor"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:textColor="@color/buttontextcolor"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"
                    android:textAllCaps="true"
                    android:id="@+id/bookSlot"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/select_gym"
                    android:paddingHorizontal="10dp"
                    />
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>