<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/buttontextcolor"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    tools:context=".fragments.LibraryFragment">

    <TextView
        android:layout_marginTop="10dp"
        android:layout_marginEnd="15dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/headingcolor"
        android:textSize="18sp"
        android:textStyle="bold"
        android:paddingVertical="15dp"
        android:paddingStart="15dp"
        android:fontFamily="@font/manrope_medium"
        android:text="@string/explore_library"
        />
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:padding="10dp"
                        android:id="@+id/linearSearch"
                        android:layout_marginHorizontal="15dp"
                        android:layout_marginVertical="10dp"
                        android:layout_gravity="center"
                        android:background="@drawable/edittext_background"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp">
                        <ImageView
                            android:src="@drawable/search"
                            android:layout_width="24dp"
                            android:layout_height="24dp"/>
                        <TextView
                            android:id="@+id/searchTv"
                            android:layout_marginHorizontal="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/headingcolor"
                            android:textSize="14sp"
                            android:fontFamily="@font/manrope_semi_bold"
                            />
                    </LinearLayout>
                    <ImageView
                        android:layout_marginEnd="10dp"
                        android:layout_marginTop="10dp"
                        android:id="@+id/imWorkout"
                        android:src="@drawable/search_workout_img"
                        android:layout_width="56dp"
                        android:layout_height="56dp"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="10dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:id="@+id/workoutCategoryRecycler"
                    />

                <TextView
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/featured"
                    app:drawableEndCompat="@drawable/baseline_keyboard_arrow_right_24" />
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="10dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:id="@+id/featuredLibraryRecycler"
                    />
                <TextView
                    android:layout_marginHorizontal="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"
                    android:visibility="gone"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:id="@+id/tvNoFeaturedWorkout"
                    android:fontFamily="@font/manrope_medium"
                    android:text="No featured workout found"
                    />
                <TextView
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/my_workouts"
                    />
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:id="@+id/dateRecyclerView"
                    />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/workoutRecyclerView"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginTop="5dp"
                    android:nestedScrollingEnabled="false"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    />

                <TextView
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"
                    android:visibility="gone"
                    android:gravity="center"
                    android:textStyle="bold"
                    android:id="@+id/tvnoWorkout"
                    android:fontFamily="@font/manrope_medium"
                    android:text="No workout found"
                 />
                <TextView
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/workout"
                    app:drawableEndCompat="@drawable/baseline_keyboard_arrow_right_24" />
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"

                    android:layout_marginHorizontal="10dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:id="@+id/WorkoutTypeRecyclerView"
                    />
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="10dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:id="@+id/allWorkoutRecyclerView"
                    />
                <ImageView
                    android:layout_width="match_parent"
                    android:id="@+id/im_no_data"
                    android:visibility="gone"
                    android:src="@drawable/no_workout_found"
                    android:layout_centerInParent="true"
                    android:layout_height="200dp"/>
                <TextView
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="15dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/your_active_challenge"
                    app:drawableEndCompat="@drawable/baseline_keyboard_arrow_right_24" />

                <LinearLayout
                    android:id="@+id/activeChallenge"
                    android:padding="20dp"
                    android:background="@drawable/workout_gradient_rectangle"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/transparent_white_1"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="HIIT Training"
                            />
                        <TextView
                            android:layout_marginTop="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:id="@+id/challengeName"
                            android:fontFamily="@font/clashdisplay_medium"
                            android:text="Strength Challenge"
                            />
                        <LinearLayout
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:layout_marginTop="20dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <androidx.cardview.widget.CardView
                                android:layout_width="10dp"
                                app:cardCornerRadius="4dp"
                                app:cardBackgroundColor="@color/orangecolor"
                                android:layout_height="10dp"/>
                            <TextView
                                android:layout_marginStart="4dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/transparent_white_1"
                                android:fontFamily="@font/manrope_medium"
                                android:textStyle="bold"
                                android:text="5/8 weeks"
                                />
                            <androidx.cardview.widget.CardView
                                android:layout_width="10dp"
                                android:layout_marginStart="10dp"
                                app:cardCornerRadius="4dp"
                                app:cardBackgroundColor="@color/progressBlue"
                                android:layout_height="10dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/transparent_white_1"
                                android:textSize="12sp"
                                android:layout_marginStart="4dp"
                                android:fontFamily="@font/manrope_medium"
                                android:textStyle="bold"
                                android:text="9/12 workouts"
                                />
                        </LinearLayout>
                        <androidx.cardview.widget.CardView
                            app:cardCornerRadius="10dp"
                            android:layout_marginTop="20dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <LinearLayout
                                android:layout_margin="13dp"
                                android:orientation="horizontal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/play_1"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textColor="@color/buttontextcolor"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:layout_marginStart="4dp"
                                    android:fontFamily="@font/manrope_medium"
                                    android:text="@string/resume"
                                    />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <co.com.mypt.utils.CircularFillView
                            android:rotation="90"
                            android:id="@+id/circularBlueView"
                            android:layout_width="160dp"
                            android:layout_height="160dp"/>
                        <co.com.mypt.utils.CircularFillView
                            android:rotation="90"
                            android:id="@+id/circularOrangeView"
                            android:layout_width="130dp"
                            android:layout_centerInParent="true"
                            android:layout_height="130dp"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_centerInParent="true"
                            android:layout_height="wrap_content">
                            <androidx.cardview.widget.CardView
                                android:layout_marginStart="5dp"
                                android:layout_marginBottom="5dp"
                                app:cardCornerRadius="10dp"
                                android:layout_width="90dp"
                                android:layout_height="90dp">
                                <ImageView
                                    android:src="@drawable/weight_lifter"
                                    android:layout_centerInParent="true"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"/>
                                <LinearLayout
                                    android:gravity="center"
                                    android:layout_gravity="center"
                                    android:orientation="vertical"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="18sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/white"
                                        android:id="@+id/completedPercentage"
                                        android:fontFamily="@font/clashdisplay_medium"
                                        android:text="75 %"
                                        />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/white"
                                        android:fontFamily="@font/manrope_medium"
                                        android:text="@string/complete"
                                        />
                                </LinearLayout>
                            </androidx.cardview.widget.CardView>
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>

                <ImageView
                    android:layout_marginVertical="30dp"
                    android:layout_marginHorizontal="10dp"
                    android:src="@drawable/divider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:layout_gravity="center_horizontal"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    android:fontFamily="@font/clashdisplay_medium"
                    android:text="“ Believe you can and\nyou're halfway there ”"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:fontFamily="@font/clashdisplay_medium"
                    android:textColor="@color/edittextbordercolor"
                    android:text="-Theodore Roosevelt"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginVertical="15dp"/>
                <ImageView
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:src="@drawable/home_header_image"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        <ImageView
            android:layout_width="match_parent"
            android:src="@drawable/im_workout"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_height="match_parent"/>

    </RelativeLayout>

</LinearLayout>