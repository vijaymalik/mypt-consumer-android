<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"

    tools:context=".PlanRenewal.Renew.Gym.RenewGymListActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/headerLayout"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:id="@+id/back_1"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="10dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/backarrow"
                />
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:id="@+id/tvgymCount"
                android:fontFamily="@font/manrope_medium"
                android:text=""
                />
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:id="@+id/im_search"
                android:layout_marginTop="10dp"
                android:layout_marginRight="15dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/search"
                />


        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/linearLocation"
            android:background="@drawable/offer_rectangle"
            android:paddingHorizontal="10dp"
            android:gravity="center"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="15dp"
            android:paddingVertical="15dp"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/gymlocation"/>

            <TextView
                android:text="Selected location:"
                android:layout_width="wrap_content"

                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:layout_marginLeft="10dp"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/smallTextcolor"
                android:textSize="14dp"/>
            <TextView
                android:text=""
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:id="@+id/tvLocation"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginLeft="5dp"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/white"
                android:textSize="14dp"/>
            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/arrow_bottom"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:layout_marginVertical="15dp"
            android:id="@+id/exerciseRecyclerView"
            android:layout_marginStart="15dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/trainerRecyclerView"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:layout_width="match_parent"

            android:layout_height="wrap_content"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textColor="@color/headingcolor"
        android:textSize="14sp"
        android:gravity="center"
        android:visibility="gone"
        android:textStyle="bold"
        android:id="@+id/tvNodata"
        android:fontFamily="@font/manrope_medium"
        android:text="@string/no_data_found"
        />
</RelativeLayout>