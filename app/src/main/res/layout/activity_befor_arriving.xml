<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent"
    tools:context=".ActiveSession.BeforeArrivingActivity">
    <fragment
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_above="@+id/linearbottom"
        android:layout_alignParentTop="true"
        android:layout_marginBottom="-30dp"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_marginTop="20dp"
        android:layout_alignParentTop="true"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:id="@+id/back"
            android:layout_marginLeft="15dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginHorizontal="15dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/track_my_trainer"
            />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:background="@drawable/top_rounded_corners"
        app:cardCornerRadius="15dp"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:id="@+id/linearbottom"
        android:layout_height="wrap_content">
        <LinearLayout
            android:paddingHorizontal="10dp"
            android:layout_width="match_parent"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:id="@+id/linearthings"
            android:background="@drawable/arriving_brown_gradient"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:layout_marginLeft="5dp"
                android:id="@+id/tvTrainerText"
                android:fontFamily="monospace"
                android:text="Things to prepare before Christene Koning arrives"/>
            <ImageView
                android:layout_width="16dp"
                android:layout_marginLeft="10dp"
                android:src="@drawable/arrow_right"
                android:layout_height="16dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_marginHorizontal="15dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="20dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_marginEnd="10dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:id="@+id/tvAddress"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_regular_400"
                    android:text="Arriving at your home - 23B,Dubai Mall Street Road"
                    />
                <LinearLayout
                    android:layout_width="60dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/time_drawable"
                    android:layout_height="60dp">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:gravity="center"
                        android:id="@+id/tvTime"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:text=""
                        android:fontFamily="@font/manrope_semi_bold"
                        />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:text="@string/mins"
                        />
                </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="15dp"
                android:layout_height="wrap_content"

                android:orientation="horizontal">
                <androidx.cardview.widget.CardView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    app:cardCornerRadius="26dp"
                    app:cardBackgroundColor="#1C1F21"> <!-- Outer boundary color -->

                    <androidx.cardview.widget.CardView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="25dp"
                        app:cardBackgroundColor="#09131D"> <!-- Inner boundary color -->

                        <!-- Content (optional) -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:id="@+id/im"
                            />

                    </androidx.cardview.widget.CardView>
                </androidx.cardview.widget.CardView>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="10dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="16sp"
                        android:maxLines="2"
                        android:id="@+id/tvTrainer_name"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:text="Christene De Koning"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/recycler"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:orientation="horizontal"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:orientation="vertical"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"

                        android:orientation="horizontal">
                        <EditText
                            android:id="@+id/ed1"
                            android:layout_width="30dp"
                            android:layout_height="32dp"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:ems="2"
                            android:textSize="14sp"
                            android:layout_marginEnd="5dp"
                            android:gravity="center"
                            android:inputType="number"
                            android:autofillHints="smsOTPCode"
                            android:importantForAutofill="yes"
                            android:background="@drawable/arriving_otp_gradient"
                            android:maxLength="1"
                            android:textColor="@color/white" />
                        <EditText
                            android:id="@+id/ed2"
                            android:layout_width="30dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="5dp"
                            android:background="@drawable/arriving_otp_gradient"
                            android:ems="2"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:autofillHints="smsOTPCode"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:importantForAutofill="yes"
                            android:textColor="@color/white" />
                        <EditText
                            android:id="@+id/ed3"
                            android:layout_width="30dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="5dp"
                            android:textSize="14sp"
                            android:background="@drawable/arriving_otp_gradient"
                            android:ems="2"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:autofillHints="smsOTPCode"
                            android:importantForAutofill="yes"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:textColor="@color/white"/>
                        <EditText
                            android:id="@+id/ed4"
                            android:layout_width="30dp"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:layout_height="32dp"
                            android:background="@drawable/arriving_otp_gradient"
                            android:ems="2"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:inputType="number"
                            android:maxLength="1"
                            android:autofillHints="smsOTPCode"
                            android:importantForAutofill="yes"
                            android:textColor="@color/white" />
                    </LinearLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="12sp"
                        android:layout_marginTop="10dp"
                        android:gravity="end"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:text="@string/otp_for_session"/>
                </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_marginHorizontal="15dp"
                android:layout_marginVertical="20dp"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/headingcolor"
                    android:textSize="16sp"
                    android:textAllCaps="true"
                    android:id="@+id/tvTrainerSessionDetail"
                    android:fontFamily="@font/manrope_bold"
                    android:text="@string/training_session_details"/>
                <ImageView
                    android:layout_width="24dp"
                    android:layout_marginLeft="10dp"
                    android:src="@drawable/arrow_right"
                    android:layout_height="24dp"
                    app:tint="@color/headingcolor" />
            </LinearLayout>

            <LinearLayout
                android:layout_marginTop="10dp"
                android:layout_marginBottom="40dp"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="15dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <EditText
                    android:hint="@string/any_message_for_the_trainer"
                    android:textColorHint="@color/smallTextcolor"
                    android:textColor="@color/smallTextcolor"
                    android:background="@drawable/edittext_background"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:textSize="14sp"
                    android:padding="10dp"
                    android:focusable="false"
                    android:enabled="false"
                    android:layout_height="match_parent"/>
                <androidx.cardview.widget.CardView
                    android:layout_marginStart="16dp"
                    app:cardCornerRadius="12dp"
                    android:layout_width="50dp"
                    android:id="@+id/cardDialer"
                    app:cardBackgroundColor="@color/F6F3F0"
                    android:layout_height="50dp">
                    <ImageView
                        android:layout_gravity="center"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/call"
                        app:tint="@color/black" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>