<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none"
    android:fitsSystemWindows="true"
    android:background="@color/buttontextcolor"
    tools:context=".WorkoutLibrary.SearchWorkoutActivity">
    <LinearLayout
        android:id="@+id/headerLayout"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back_1"
            android:layout_marginHorizontal="15dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/workout_library"
            />


    </LinearLayout>
    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerLayout"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout
                android:gravity="center_vertical"
                android:padding="10dp"
                android:layout_marginVertical="10dp"
                android:layout_marginHorizontal="15dp"
                android:layout_gravity="center"
                android:id="@+id/linearSearch"
                android:background="@drawable/edittext_background"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="56dp">
                <ImageView
                    android:src="@drawable/search"
                    android:layout_width="24dp"
                    android:layout_height="24dp"/>
                <EditText
                    android:background="@android:color/transparent"
                    android:layout_marginHorizontal="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/headingcolor"
                    android:textColorHint="@color/progress_track_color_1"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:id="@+id/searchEditText"
                    android:fontFamily="@font/manrope_medium"
                    android:hint="Search for Workout"
                    />
            </LinearLayout>
            <ImageView
                android:layout_marginEnd="10dp"
                android:layout_marginTop="10dp"
                android:src="@drawable/search_workout_img"
                android:layout_width="56dp"
                android:layout_height="56dp"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="15dp"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:id="@+id/tvcount"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text=""
                />
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:id="@+id/imfilter"
                android:src="@drawable/filter_edit"/>
            <TextView
                android:id="@+id/filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_gravity="center"
                android:layout_marginLeft="10dp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="FILTER"
                />
        </LinearLayout>


        <androidx.recyclerview.widget.RecyclerView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            android:layout_marginHorizontal="15dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:id="@+id/featuredLibraryRecycler"
            />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_gravity="center_horizontal"
            android:layout_margin="10dp"
            android:visibility="gone"
            android:layout_width="30dp"
            android:backgroundTint="@color/white"
            android:indeterminateTint="@color/white"
            android:layout_height="30dp"
            android:progressTint="@color/white"/>
    </LinearLayout>
    <ImageView
        android:layout_width="match_parent"
        android:id="@+id/tvNOdata"
        android:visibility="gone"
        android:src="@drawable/no_data_found"
        android:layout_centerInParent="true"
        android:layout_height="wrap_content"/>

</RelativeLayout>