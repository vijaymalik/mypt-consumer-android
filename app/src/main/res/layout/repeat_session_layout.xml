<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:background="@drawable/top_rounded_corners"
        app:cardCornerRadius="15dp"
        android:id="@+id/standard_bottom_sheet"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:orientation="vertical"
        android:layout_height="wrap_content">
        <androidx.cardview.widget.CardView
            android:layout_marginTop="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="70dp"
            app:cardCornerRadius="3dp"
            android:layout_height="5dp"
            app:cardBackgroundColor="@color/rulersmallline"/>
        <TextView
            android:layout_marginHorizontal="10dp"
            android:layout_width="match_parent"

            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="24sp"
            android:layout_marginTop="20dp"

            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/repeat_frequency"
            />
        <androidx.cardview.widget.CardView
            android:layout_marginTop="20dp"
            android:layout_marginBottom="50dp"
            android:layout_marginHorizontal="15dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="#0954A9"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_margin="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:src="@drawable/customer_support"
                        android:layout_width="24dp"
                        android:layout_height="24dp"/>
                    <TextView
                        android:textSize="16sp"
                        android:textColor="@color/headingcolor"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_marginHorizontal="10dp"
                        android:text="@string/dedicated_support"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                    <ImageView
                        android:src="@drawable/arrow_right"
                        android:layout_width="24dp"
                        android:layout_height="24dp"/>
                </LinearLayout>
                <TextView
                    android:layout_marginTop="5dp"
                    android:textSize="14sp"
                    android:textColor="@color/ltblue"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_medium"
                    android:layout_marginStart="40dp"
                    android:text="@string/for_assistance_with_on_training_issues_or_any_escalations"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>