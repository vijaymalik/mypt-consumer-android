<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="@color/buttontextcolor"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".activities.ChooseExcerciseActivity">
    <LinearLayout
        android:background="@color/buttontextcolor"
        android:id="@+id/headerLayout"
        android:layout_alignParentTop="true"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back_1"
            android:layout_marginHorizontal="10dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/choose_exercise"
            />


    </LinearLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:id="@+id/nested"
        android:layout_below="@id/headerLayout"
        android:layout_above="@+id/tvAddExerciseLayout"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_marginBottom="-10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:gravity="center_vertical"
                        android:paddingHorizontal="10dp"
                        android:layout_marginHorizontal="10dp"
                        android:layout_gravity="center"
                        android:id="@+id/linearSearch"
                        android:background="@drawable/edittext_background"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="56dp">
                        <ImageView
                            android:src="@drawable/search"
                            android:layout_width="24dp"
                            android:layout_height="24dp"/>
                        <EditText
                            android:background="@android:color/transparent"
                            android:layout_marginHorizontal="10dp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:textColor="@color/headingcolor"
                            android:textColorHint="@color/smallTextcolor"
                            android:textSize="14sp"
                            android:id="@+id/searchEditText"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:hint="@string/search_for_exercise"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edittext_background"
                        android:layout_marginRight="10dp"
                        >
                        <ImageView
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/human"
                            />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:layout_marginLeft="10dp"
                        android:id="@+id/linearMuscle"
                        android:background="@drawable/edittext_background"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginLeft="15dp"
                            android:layout_gravity="center"
                            android:src="@drawable/running_person"
                            />
                        <TextView

                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:textColor="@color/headingcolor"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingVertical="15dp"
                            android:layout_marginHorizontal="5dp"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/all_muscles"
                            />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="15dp"
                            android:rotation="90"
                            android:layout_gravity="center"
                            android:src="@drawable/arrow_right"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="20dp"
                        android:layout_marginLeft="15dp"
                        android:id="@+id/linearEquipment"
                        android:background="@drawable/edittext_background"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="15dp"
                            android:layout_gravity="center"
                            android:src="@drawable/white_dumble"
                            />
                        <TextView

                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:textColor="@color/headingcolor"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:paddingVertical="15dp"
                            android:layout_marginHorizontal="10dp"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/all_equipment_s"
                            />
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginLeft="10dp"
                            android:layout_marginRight="15dp"
                            android:rotation="90"
                            android:layout_gravity="center"
                            android:src="@drawable/arrow_right"
                            />
                    </LinearLayout>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/recyclerAddedExercise"
                    android:layout_marginRight="10dp"
                    android:visibility="gone"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:orientation="horizontal"
                    />
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/recyclerExercise"
                    android:layout_marginTop="20dp"
                    android:visibility="gone"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:orientation="vertical"
                    />
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_gravity="center_horizontal"
                    android:layout_margin="10dp"
                    android:visibility="gone"
                    android:layout_width="30dp"
                    android:backgroundTint="@color/white"
                    android:indeterminateTint="@color/white"
                    android:layout_height="30dp"
                    android:progressTint="@color/white"/>
            </LinearLayout>

        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>
    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:id="@+id/linearNoExercise"
        android:visibility="gone"
        android:layout_centerInParent="true"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_width="match_parent"
            android:src="@drawable/im_no_slot"
            android:layout_height="200dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:layout_marginTop="-30dp"
            android:fontFamily="@font/manrope_bold"
            android:text="No exercise found"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:background="@drawable/bottom_button_gradient"
        android:id="@+id/tvAddExerciseLayout"
        android:layout_alignParentBottom="true"
        android:layout_width="match_parent"
        android:gravity="center"
        android:layout_height="80dp">
        <TextView
            android:layout_width="match_parent"
            android:id="@+id/tvAddExercise"
            android:layout_height="56dp"
            android:layout_marginHorizontal="10dp"
            android:background="@drawable/rectangle_btn"
            android:gravity="center"
            android:fontFamily="@font/manrope_bold"
            android:textAllCaps="true"
            android:text="@string/add_exercise"
            android:textColor="@color/subheadingcolor"
            android:textSize="16sp" />

    </LinearLayout>
</RelativeLayout>