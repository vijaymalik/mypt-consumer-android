<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"

    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:background="@drawable/superset_bg"
            android:layout_marginTop="170dp"
            android:layout_marginHorizontal="11dp"
            android:layout_height="wrap_content">
            <CheckBox
                android:paddingHorizontal="10dp"
                android:id="@+id/check"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="30dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:buttonTint="@color/white"
                style="@style/CustomCheckboxBrand"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/white"
                android:text="Select for Superset 01" />
        </LinearLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_marginTop="15dp"
            android:id="@+id/relative"
            android:layout_marginHorizontal="10dp"
            android:clipToOutline="true"
            android:background="@drawable/superset_exercise_gradient"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="246dp"
                android:src="@drawable/gymgirl"
                android:layout_alignParentEnd="true"
                android:scaleType="centerCrop"
                android:id="@+id/im"
                android:layout_alignParentTop="true"
                android:layout_height="190dp"/>
            <LinearLayout
                android:id="@+id/ll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginTop="20dp"
                    >
                    <TextView
                        android:text="Rope"
                        android:background="@drawable/booking_choicelayout"
                        android:paddingVertical="5dp"
                        android:paddingHorizontal="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:id="@+id/tv"
                        android:layout_alignParentStart="true"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/white"
                        android:textSize="14sp"/>
                    <ImageView
                        android:id="@+id/verticalDots"
                        android:layout_alignParentEnd="true"
                        android:layout_width="50dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/vertical_dots"/>
                </RelativeLayout>
                <TextView
                    android:text="Rope Aerobics"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:id="@+id/tvTittle"
                    android:layout_marginTop="15dp"
                    android:layout_marginHorizontal="20dp"
                    android:fontFamily="@font/clash_display_medium"
                    android:textColor="@color/white"
                    android:textSize="20sp"/>
                <TextView
                    android:text="Shinomiya Kaguya"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:layout_marginTop="15dp"
                    android:layout_marginHorizontal="20dp"
                    android:fontFamily="@font/clash_display_medium"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="14sp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="15dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/imdumbel"/>
                    <TextView
                        android:text="12"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:id="@+id/tvReps"
                        android:layout_marginLeft="5dp"
                        android:fontFamily="@font/clash_display_medium"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                    <TextView
                        android:text="Reps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:layout_marginLeft="5dp"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:src="@drawable/solid_fire"/>
                    <TextView
                        android:text="251"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:id="@+id/tvcal"
                        android:layout_marginLeft="5dp"
                        android:fontFamily="@font/clash_display_medium"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                    <TextView
                        android:text="Kcal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:layout_marginLeft="5dp"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>

        </RelativeLayout>

    </RelativeLayout>


</RelativeLayout>