<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/buttontextcolor"
    android:fitsSystemWindows="true"
    tools:context=".Notification.AcceptBookingActivity">
    <LinearLayout
        android:background="@color/buttontextcolor"
        android:id="@+id/headerLayout"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back_1"
            android:layout_marginHorizontal="10dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/booking_details"
            />

    </LinearLayout>
    <View
        android:background="@color/tabbackground"
        android:layout_width="match_parent"
        android:id="@+id/view"
        android:layout_below="@id/headerLayout"
        android:layout_height="2dp"/>

    <LinearLayout
        android:id="@+id/dataLayout"
        android:visibility="gone"
        android:layout_below="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:id="@+id/nested"
            android:layout_above="@+id/linearpay"
            android:layout_marginHorizontal="15dp"
            >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginVertical="20dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/my_trainer"
                    />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/review_rectangle"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="15dp"
                        android:paddingVertical="20dp">

                        <ImageView
                            android:layout_width="60dp"
                            android:id="@+id/imTrainer"
                            android:scaleType="centerCrop"
                            android:layout_height="60dp"
                            android:src="@drawable/dummy_trainer" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="10dp"
                            android:layout_gravity="center"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_medium"
                                android:text="Christene De Koning"
                                android:textColor="@color/headingcolor"
                                android:textFontWeight="700"
                                android:textSize="14dp"
                                android:id="@+id/tvTrainerName"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@drawable/gymlocation" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginLeft="3dp"
                                    android:fontFamily="@font/manrope_medium"
                                    android:text="1.2km"
                                    android:id="@+id/tvdistance"
                                    android:textColor="@color/smallTextcolor"
                                    android:textSize="12dp"
                                    android:textStyle="bold" />

                                <View
                                    android:layout_width="3dp"
                                    android:layout_height="3dp"
                                    android:layout_marginHorizontal="5dp"
                                    android:background="@drawable/dot" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:id="@+id/tvTrainerLocation"
                                    android:fontFamily="@font/manrope_medium"
                                    android:text="Near Dubai Mall"
                                    android:textColor="@color/smallTextcolor"
                                    android:textSize="12dp"
                                    android:textStyle="bold" />
                            </LinearLayout>


                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"

                            android:layout_marginEnd="5dp"
                            android:layout_gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/star" />

                            <TextView
                                android:id="@+id/avgRating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="3dp"
                                android:fontFamily="@font/manrope_medium"
                                android:text="4"
                                android:textColor="@color/white"
                                android:textSize="12sp" />

                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:id="@+id/view1"
                        android:layout_marginHorizontal="15dp"
                        android:layout_marginBottom="15dp"
                        android:visibility="gone"
                        android:background="@drawable/completebooking_view" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="15dp"
                        android:fontFamily="@font/manrope_medium"
                        android:gravity="center"
                        android:text="@string/rate_trainer"
                        android:id="@+id/tvRateTrainer"
                        android:visibility="gone"
                        android:textColor="@color/smallTextcolor"
                        android:textFontWeight="700"
                        android:textSize="14dp"
                        android:textStyle="bold" />
                </LinearLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/session_overview"
                    />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/session_rectangle"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_marginTop="20dp"
                        android:layout_marginHorizontal="15dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:textColor="@color/smallTextcolor"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/date_time"
                            />
                        <TextView
                            android:layout_width="wrap_content"
                            android:id="@+id/tvDateTime"
                            android:layout_height="wrap_content"
                            android:textColor="@color/headingcolor"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="Aug 15, 2024, 8:00 AM"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_marginTop="15dp"
                        android:layout_marginHorizontal="15dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:textColor="@color/smallTextcolor"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/session_type"
                            />
                        <TextView
                            android:layout_width="wrap_content"
                            android:id="@+id/tvSessionType"
                            android:layout_height="wrap_content"
                            android:textColor="@color/headingcolor"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="Aug 15, 2024, 8:00 AM"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_marginTop="15dp"
                        android:layout_marginBottom="20dp"
                        android:layout_marginHorizontal="15dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:textColor="@color/smallTextcolor"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/training_preference"
                            />
                        <TextView
                            android:layout_width="wrap_content"
                            android:id="@id/tvTrainingPrefernce"
                            android:layout_height="wrap_content"
                            android:textColor="@color/headingcolor"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="Aug 15, 2024, 8:00 AM"
                            />
                    </LinearLayout>

                </LinearLayout>



                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:paddingVertical="20dp"
                    android:background="@drawable/session_rectangle"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="15dp"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:textColor="@color/smallTextcolor"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_gravity="center"
                            android:fontFamily="@font/manrope_regular_400"
                            android:text="@string/location"
                            />
                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:id="@+id/editAddress"
                            android:src="@drawable/edir"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:id="@+id/tvAddress"
                        android:layout_marginTop="10dp"
                        android:layout_marginHorizontal="15dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Villa 12, Street 5, Al Barsha 3, Dubai, UAE 157698"
                        />

                </LinearLayout>
                <androidx.cardview.widget.CardView
                    app:cardCornerRadius="12dp"
                    android:layout_marginVertical="15dp"
                    android:layout_width="match_parent"
                    app:cardBackgroundColor="#242529"
                    android:id="@+id/AddnewAddress"
                    android:visibility="gone"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:orientation="horizontal"
                        android:paddingVertical="15dp"

                        android:paddingHorizontal="15dp"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="24dp"
                            android:src="@drawable/add"
                            android:layout_height="24dp"/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/headingcolor"
                            android:textSize="16sp"
                            android:layout_marginHorizontal="10dp"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:text="@string/add_new_address__"
                            />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/session_rectangle"
                    android:layout_marginVertical="20dp"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_marginVertical="20dp"
                        android:layout_marginHorizontal="15dp"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:textColor="@color/smallTextcolor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/cost"
                            />
                        <TextView
                            android:layout_width="wrap_content"
                            android:id="@+id/tvCost"
                            android:layout_height="wrap_content"
                            android:textColor="@color/headingcolor"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="1 PT Credit"
                            />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_alignParentBottom="true"
            android:orientation="vertical"
            android:id="@+id/linearpay"

            android:layout_height="wrap_content">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:paddingVertical="10dp"
                android:id="@+id/tv1PTamountmsg"
                android:background="@drawable/onept_rectangle"
                android:paddingHorizontal="20dp"
                android:textColor="#0FA958"
                android:fontFamily="@font/manrope_semi_bold"
                android:text="1 PT will be deducted from your account, no additional charges will apply."/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="horizontal"
                android:background="@color/tabbackground"

                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                >
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="15dp"
                    android:orientation="vertical">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:orientation="horizontal"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="28sp"
                            android:id="@+id/tvPrice"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:textColor="@color/white"
                            android:fontFamily="@font/manrope_bold"
                            android:text=""/>
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:id="@+id/tvcurrency"
                            android:layout_marginTop="3dp"
                            android:layout_gravity="center"
                            android:layout_marginLeft="5dp"
                            android:textColor="@color/white"
                            android:fontFamily="@font/manrope_regular_400"
                            android:text="AED"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/smallTextcolor"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:text="@string/view_breakdown"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/confirm_booking"
                    android:background="@drawable/white_rectangle"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:paddingVertical="18dp"
                    android:paddingHorizontal="25dp"
                    android:id="@+id/tvPayment"
                    android:textAllCaps="true"
                    android:fontFamily="@font/manrope_bold"
                    />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>