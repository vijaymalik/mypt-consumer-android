<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/top_rounded_corners"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:id="@+id/tophandle"
        android:layout_width="70dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="5dp"
        app:cardBackgroundColor="@color/rulersmallline"
        app:cardCornerRadius="3dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="32dp">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_back_arrow_new" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginHorizontal="8dp"
            android:layout_toEndOf="@+id/backBtn"
            android:fontFamily="@font/clash_display_medium"
            android:text="Review Booking"
            android:textColor="@color/text_color_neutral_200"
            android:textSize="20sp" />

    </RelativeLayout>


    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="20dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/funnel_sans_regular"
                android:text="Selected dates &amp; trainers"
                android:textColor="@color/location_txt"
                android:textSize="16sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_details_container"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvTrainerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/funnel_sans_medium"
                    android:text="Dhruv Nair"
                    android:textColor="@color/white"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/edittext_border"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/funnel_sans_semibold"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:layout_marginHorizontal="5dp"
                        android:background="@drawable/grey_dot"
                        android:backgroundTint="#1AFFFFFF" />

                    <TextView
                        android:id="@+id/tvSlot"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/funnel_sans_semibold"
                        android:text=""
                        android:textColor="@color/white"
                        android:textSize="12sp" />
                </LinearLayout>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/funnel_sans_regular"
                android:text="Training location"
                android:layout_marginTop="20dp"
                android:textColor="@color/location_txt"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/tranningAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_details_container"
                android:orientation="horizontal"
                android:padding="16dp">


                <RelativeLayout
                    android:id="@+id/rlAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/homeicon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@drawable/home_icon" />

                    <TextView
                        android:id="@+id/workType"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginStart="22dp"
                        android:layout_marginEnd="5dp"
                        android:layout_toStartOf="@+id/addressArrow"
                        android:layout_toEndOf="@+id/homeicon"
                        android:fontFamily="@font/funnel_sans_regular"
                        android:text="HOME"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/address"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/workType"
                        android:layout_alignStart="@+id/workType"
                        android:layout_marginTop="6dp"
                        android:layout_toStartOf="@+id/addressArrow"
                        android:drawableTint="@color/bg_color_primary_white_55"
                        android:fontFamily="@font/funnel_sans_regular"
                        android:lineHeight="16sp"
                        android:text="NA"
                        android:textColor="@color/grey_text"
                        android:textSize="14sp" />


                    <ImageView
                        android:id="@+id/addressArrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="3dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/white" />

                </RelativeLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/funnel_sans_regular"
                android:text="Amount"
                android:layout_marginTop="20dp"
                android:textColor="@color/location_txt"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_details_container"
                android:orientation="horizontal"
                android:padding="16dp">


                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ptIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_pt_assessment_amount" />

                    <TextView
                        android:id="@+id/tvPTSession"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginStart="22dp"
                        android:layout_marginEnd="5dp"
                        android:layout_toEndOf="@+id/ptIcon"
                        android:fontFamily="@font/funnel_sans_regular"
                        android:lineHeight="24sp"
                        android:text="1 PT session will be deducted"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tvPTSessionRemain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/tvPTSession"
                        android:layout_alignStart="@+id/tvPTSession"
                        android:layout_marginTop="6dp"
                        android:drawableTint="@color/bg_color_primary_white_55"
                        android:fontFamily="@font/funnel_sans_regular"
                        android:lineHeight="16sp"
                        android:text="NA"
                        android:textColor="@color/grey_text"
                        android:textSize="14sp" />


                </RelativeLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirm"
        style="@style/PrimaryButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:text="Confirm Booking"
        app:icon="@drawable/ic_arrow_right"
        app:iconGravity="textEnd" />
</LinearLayout>