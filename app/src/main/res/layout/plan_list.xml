<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/relative"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_width="match_parent"
        android:background="@drawable/session_rectangle"
        android:id="@+id/linearPlan"
        android:layout_marginLeft="10dp"
        android:orientation="horizontal"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_width="91dp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/gold_shield"
            android:id="@+id/imSheild"
            android:layout_height="98dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_marginVertical="20dp"
            android:orientation="vertical"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:id="@+id/tvplanName"
                android:layout_marginBottom="5dp"
                android:fontFamily="@font/manrope_bold"
                android:text="@string/gold_plan"
                />
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/plan_progress"
                android:layout_marginVertical="5dp"
                android:layout_marginRight="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:indeterminate="false"
                android:max="100"
                app:trackColor="#31343A"
                app:trackThickness="8dp"
                app:indicatorColor="@color/headingcolor"
                app:trackCornerRadius="3dp"
                android:progress="50" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#606060"
                android:textSize="12sp"
                android:id="@+id/tvRemainingSession"
                android:layout_marginRight="15dp"
                android:layout_marginBottom="5dp"
                android:fontFamily="@font/manrope_medium"
                android:text="21 Sessions Remaining ending in 30 days"
                />
            <LinearLayout
                android:layout_width="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="3dp"
                android:layout_marginTop="5dp"
                android:paddingHorizontal="10dp"
                android:background="@drawable/product_offer_drawable"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="12dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginBottom="-1dp"
                    android:src="@drawable/discountshape"
                    android:layout_height="12dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:layout_marginLeft="2dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="Save 10%"
                    />
            </LinearLayout>


        </LinearLayout>

    </LinearLayout>

</RelativeLayout>