<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="20dp"
        android:id="@+id/card"
        android:layout_marginHorizontal="2dp"
        app:cardBackgroundColor="@color/home_frag_blk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/mainLayout"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/product_gradient"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:layout_margin="12dp"
                app:cardCornerRadius="15dp"
                android:layout_width="80dp"
                android:layout_height="80dp">
                <ImageView
                    android:src="@drawable/dummy_ex_1"
                    android:id="@+id/workoutImage"
                    android:layout_width="80dp"
                    android:layout_height="80dp"/>
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:id="@+id/progressLayout"
                android:orientation="vertical"

                android:layout_marginEnd="12dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <TextView
                        android:text="Zen Flow Yoga"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:fontFamily="@font/clash_display_medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="@color/white"
                        android:id="@+id/exerciseName"
                        />
                    <TextView
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:layout_marginHorizontal="10dp"
                        android:text="Yoga"
                        android:background="@drawable/c1f21_25_transparent_rounded_corner"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/headingcolor"
                        android:id="@+id/exerciseType"
                        />
                </LinearLayout>
                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/p_Bar"
                    android:layout_marginVertical="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:indeterminate="false"
                    android:max="100"
                    app:trackColor="@color/progress_track_color_1"
                    app:indicatorColor="@color/progress_clr"
                    app:trackCornerRadius="15dp"
                    android:progress="70" />
                <LinearLayout
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/exerciseStatus"
                        android:layout_width="wrap_content"
                        android:visibility="gone"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Movement 4"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="14sp" />
                    <View
                        android:layout_marginHorizontal="5dp"
                        android:layout_width="4dp"
                        android:visibility="gone"

                        android:layout_height="4dp"
                        android:background="@drawable/dot"
                        />
                    <ImageView
                        android:src="@drawable/clock"
                        android:layout_width="16dp"
                        android:layout_height="16dp"/>
                    <TextView
                        android:layout_marginStart="3dp"
                        android:text="70%"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/subheadingcolor"
                        android:id="@+id/completedPercentage"
                        />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/completedLayout"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginEnd="12dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content">
                <TextView
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="Weightlifting"
                    android:background="@drawable/c1f21_25_transparent_rounded_corner"
                    android:fontFamily="@font/manrope_medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/headingcolor"
                    android:id="@+id/exerciseTypeCompleted"
                    />
                <TextView
                    android:layout_marginStart="3dp"
                    android:layout_marginTop="5dp"
                    android:text="Upper Strength"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:fontFamily="@font/clash_display_medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/white"
                    android:id="@+id/exerciseNameCompleted"
                    />
                <LinearLayout
                    android:layout_marginTop="3dp"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_marginStart="3dp"
                        android:layout_marginEnd="3dp"
                        android:text="@string/completed"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/subheadingcolor" />
                    <View
                        android:layout_marginHorizontal="5dp"
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:background="@drawable/dot_babbbe"
                        />
                    <TextView
                        android:text="+8 Score"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/subheadingcolor"
                        android:id="@+id/completedScore"
                        />
                </LinearLayout>
            </LinearLayout>
            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginRight="15dp"
                android:id="@+id/imComplete"
                android:visibility="gone"
                android:src="@drawable/green_circle"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>