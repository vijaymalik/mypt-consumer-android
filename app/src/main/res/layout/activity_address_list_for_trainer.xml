<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="@color/buttontextcolor"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"

    tools:context=".activities.AddressListForTrainerActivity">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        >
        <LinearLayout
            android:background="@color/buttontextcolor"
            android:id="@+id/headerLayout"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:id="@+id/back_1"
                android:layout_marginHorizontal="10dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/backarrow"
                />
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/book_a_slot"
                />

        </LinearLayout>
        <View
            android:background="@color/tabbackground"
            android:layout_width="match_parent"
            android:id="@+id/view"
            android:layout_below="@+id/headerLayout"
            android:layout_height="2dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:gravity="center"
            android:layout_above="@id/linearSelect"
            android:layout_below="@id/view"
            android:id="@+id/linearNoAddress"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="173dp"
                android:layout_gravity="center"
                android:src="@drawable/im_address"
                android:layout_height="113dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_gravity="center"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="15dp"
                android:textFontWeight="700"
                android:text="@string/no_address_added"
                android:textColor="@color/white"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:gravity="center"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textFontWeight="700"
                android:layout_marginTop="15dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/add_your_home_address_to_book_a_trainer_and_start_your_workouts_hassle_free"
                android:textColor="@color/buttongreycolor"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_gravity="center"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:layout_marginTop="15dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/add_address_now"
                android:id="@+id/addAddress1"
                android:textStyle="bold"
                android:paddingVertical="15dp"
                android:paddingHorizontal="15dp"
                android:drawableLeft="@drawable/baseline_add_24"
                android:background="@drawable/white_rectangle"
                android:textColor="@color/buttontextcolor"
                android:textSize="16sp" />

        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_below="@id/view"
            android:id="@+id/nested"
            android:visibility="gone"
            android:layout_above="@id/linearSelect"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_height="match_parent">
                <TextView
                    android:layout_width="match_parent"
                    android:text="@string/select_your_location"
                    android:textColor="@color/headingcolor"
                    android:textSize="16dp"
                    android:layout_marginHorizontal="15dp"
                    android:textStyle="bold"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/manrope_medium"
                    android:layout_height="wrap_content"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:id="@+id/recyclerAddress"
                    android:orientation="vertical"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:layout_width="match_parent"
                    android:text="@string/add_new_address"
                    android:textColor="@color/headingcolor"
                    android:gravity="center"
                    android:textSize="16dp"
                    android:layout_marginTop="25dp"
                    android:layout_marginBottom="20dp"
                    android:paddingHorizontal="40dp"
                    android:layout_marginHorizontal="15dp"
                    android:paddingVertical="15dp"
                    android:textStyle="bold"
                    android:id="@+id/addAddress2"
                    android:textAllCaps="true"
                    android:fontFamily="@font/manrope_medium"
                    android:layout_height="wrap_content"
                    android:background="@drawable/view_detail_rectangle"/>
            </LinearLayout>



        </androidx.core.widget.NestedScrollView>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_alignParentBottom="true"
            android:background="@drawable/add_address_drawable"
            android:layout_marginHorizontal="15dp"
            android:layout_marginBottom="15dp"
            android:layout_marginTop="15dp"
            android:gravity="center"

            android:id="@+id/linearSelect"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:id="@+id/bookSlot"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="15dp"
                android:textFontWeight="700"
                android:textAllCaps="true"
                android:text="@string/select_date_and_time"
                android:textColor="@color/subheadingcolor"
                android:textSize="16sp" />
            <TextView
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:id="@+id/selectAddress"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="15dp"
                android:textFontWeight="700"
                android:textAllCaps="true"
                android:text="Confirm Address"
                android:textColor="@color/subheadingcolor"
                android:textSize="16sp" />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_marginLeft="10dp"
                android:id="@+id/im"
                android:src="@drawable/baseline_arrow_forward_24"
                android:layout_height="wrap_content"
                app:tint="@color/subheadingcolor" />
        </LinearLayout>
    </RelativeLayout>


</RelativeLayout>