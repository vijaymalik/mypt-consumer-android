<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:id="@+id/relative"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginStart="2dp"
        app:cardCornerRadius="20dp"
        android:layout_width="290dp"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/product_gradient"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.cardview.widget.CardView
                app:cardCornerRadius="12dp"
                android:layout_margin="10dp"
                android:layout_width="match_parent"
                android:layout_height="200dp">
                <ImageView
                    android:scaleType="centerCrop"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:id="@+id/gymImage"
                    android:src="@drawable/near_by_gym_dummy"/>

                <RelativeLayout
                    android:layout_width="match_parent"

                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="128dp"
                        android:text="MY PT Studio"
                        android:textSize="10dp"
                        android:layout_centerInParent="true"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:id="@+id/tvtag"
                        android:paddingBottom="12dp"
                        android:fontFamily="@font/manrope_bold"
                        android:background="@drawable/my_pt_tag"
                        android:layout_height="34dp"/>

                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:textSize="11sp"
                    android:textColor="@color/white"
                    android:visibility="gone"
                    android:id="@+id/availableVoucher"
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="5dp"
                    android:fontFamily="@font/manrope_medium"
                    android:background="@drawable/near_by_gym_gradient"
                    android:text="Free $1200 Amazon Voucher + 1 more"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:id="@+id/tvname"
                android:layout_marginHorizontal="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:fontFamily="@font/clash_display_semibold"
                android:text="MyPT Studio Dubai"
                />
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_marginTop="3dp"
                android:layout_marginHorizontal="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/location"/>
                <TextView
                    android:text="2.5km"
                    android:id="@+id/distance"
                    android:layout_marginStart="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:textColor="@color/white"
                    android:textSize="10sp"/>
                <View
                    android:layout_marginHorizontal="3dp"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@drawable/dot"/>
                <TextView
                    android:text="Near Dubai Mall"
                    android:id="@+id/place"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:maxLength="17"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:textColor="@color/white"
                    android:textSize="10sp"/>
                <View
                    android:layout_marginHorizontal="3dp"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@drawable/dot"/>
                <TextView
                    android:text="12:00 AM - 23:00 PM"
                    android:id="@+id/time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:textColor="@color/white"
                    android:textSize="10sp"/>
            </LinearLayout>
             <TextView
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="10dp"
                android:text="Located right opposite the marina metro, this gym is perfect for medium to heavy workouts with a view."
                android:id="@+id/content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_regular_400"
                android:maxLines="2"
                android:minLines="2"
                android:ellipsize="end"
                android:textColor="@color/subheadingcolor"
                android:textSize="10sp"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_marginVertical="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginLeft="5dp"
                    android:id="@+id/exerciseRecyclerView"
                    android:orientation="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
                <androidx.cardview.widget.CardView
                    app:cardCornerRadius="10dp"
                    android:layout_marginHorizontal="10dp"
                    android:layout_alignParentEnd="true"
                    app:cardBackgroundColor="@color/home_frag_blk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"

                        android:paddingVertical="3dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/headingcolor"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:id="@+id/rating"
                            android:fontFamily="@font/manrope_medium"
                            android:text="4.5"
                            />

                        <ImageView
                            android:layout_marginStart="5dp"
                            android:layout_width="16sp"
                            android:layout_height="16sp"
                            android:src="@drawable/star"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>