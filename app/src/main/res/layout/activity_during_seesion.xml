<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/buttontextcolor"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    tools:context=".activities.DuringSeesionActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <LinearLayout
            android:background="@color/buttontextcolor"
            android:id="@+id/headerLayout"
            android:gravity="center_vertical"
            android:layout_marginHorizontal="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:id="@+id/back_1"
                android:layout_marginHorizontal="10dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/backarrow"
                />
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/book_a_slot"
                />

            <ImageView
                android:id="@+id/verticalDots"
                android:layout_width="50dp"
                android:padding="12dp"
                android:layout_height="match_parent"
                android:src="@drawable/vertical_dots"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:layout_marginHorizontal="10dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/headingcolor"
                    android:textSize="14dp"

                    android:layout_marginRight="10dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/starts" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:id="@+id/linearStart"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="12dp"
                    android:background="@drawable/grey_light_rectangle">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/smallTextcolor"
                        android:id="@+id/tvStartDate"
                        android:textSize="14dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="16, Feb" />
                    <ImageView
                        android:layout_width="5dp"
                        android:layout_gravity="center"
                        android:layout_height="5dp"
                        android:layout_marginTop="2dp"
                        android:layout_marginLeft="5dp"
                        android:src="@drawable/d_ot"
                        app:tint="@color/smallTextcolor" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/smallTextcolor"
                        android:id="@+id/tvstartday"
                        android:textSize="14dp"
                        android:layout_marginLeft="5dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Fri" />
                </LinearLayout>


            </LinearLayout>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginHorizontal="10dp"
                android:adjustViewBounds="true"
                android:layout_marginBottom="5dp"
                android:id="@+id/im"
                android:src="@drawable/arrowright"
                app:tint="@color/white" />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/headingcolor"
                    android:textSize="14dp"
                    android:layout_marginRight="10dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/ends" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:id="@+id/lineaEnd"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="12dp"
                    android:background="@drawable/grey_light_rectangle">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/smallTextcolor"
                        android:id="@+id/tvEndDate"
                        android:textSize="14dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="16, Feb" />
                    <ImageView
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:layout_marginTop="2dp"
                        android:id="@+id/im_end"
                        android:layout_gravity="center"
                        android:layout_marginLeft="5dp"
                        android:src="@drawable/d_ot"
                        app:tint="@color/smallTextcolor" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/smallTextcolor"
                        android:id="@+id/tvendday"
                        android:textSize="14dp"
                        android:layout_marginLeft="5dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Fri" />
                </LinearLayout>


            </LinearLayout>

        </LinearLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/linearRecycler"
                android:orientation="vertical"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginTop="30dp"
                    android:layout_marginBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_marginHorizontal="10dp"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_gravity="center_vertical"
                        android:layout_height="wrap_content"
                        android:textColor="@color/headingcolor"
                        android:textSize="16sp"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:text="@string/select_time_of_the_day"
                        />
                    <LinearLayout
                        android:layout_width="150dp"
                        android:gravity="end|center_vertical"
                        android:layout_height="wrap_content"
                        android:background="@drawable/night_rectangle"
                        android:orientation="horizontal"
                        android:layout_marginEnd="10dp">

                        <LinearLayout
                            android:layout_width="90dp"
                            android:visibility="gone"
                            android:layout_gravity="center"
                            android:id="@+id/linernight"
                            android:background="@drawable/white_rectangle"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="5dp"
                            android:gravity="center_horizontal"
                            android:layout_marginLeft="5dp"
                            android:paddingVertical="10dp"
                            android:paddingHorizontal="5dp"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:layout_gravity="center"
                                android:src="@drawable/night_mode"
                                android:layout_marginRight="10dp"
                                app:tint="@color/black" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/night"
                                android:textColor="@color/black"
                                android:textSize="12sp"
                                android:fontFamily="@font/manrope_semi_bold"
                                />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="15dp"
                            android:id="@+id/im_night"
                            android:src="@drawable/night_mode"/>
                        <LinearLayout
                            android:layout_width="90dp"
                            android:layout_gravity="center"
                            android:gravity="center_horizontal"
                            android:id="@+id/linearmrng"
                            android:background="@drawable/white_rectangle"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="5dp"
                            android:layout_marginVertical="5dp"
                            android:paddingVertical="10dp"
                            android:paddingHorizontal="5dp"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="15dp"
                                android:layout_height="15dp"
                                android:layout_gravity="center"
                                android:src="@drawable/sunny"
                                android:layout_marginRight="10dp"
                                app:tint="@color/black" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/morning"
                                android:textColor="@color/black"
                                android:textSize="12sp"
                                android:fontFamily="@font/manrope_semi_bold"
                                />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="0dp"
                            android:visibility="gone"
                            android:layout_weight="1"
                            android:layout_height="15dp"
                            android:id="@+id/im_mrng"
                            android:src="@drawable/sunny"
                            app:tint="@color/white" />
                    </LinearLayout>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:spanCount="3"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="10dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager" />
            </LinearLayout>

            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:visibility="gone"
                android:gravity="center"
                android:id="@+id/tvNodata"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/no_slots_found"
                />
        </RelativeLayout>

    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:id="@+id/linearpay"
        android:layout_marginVertical="10dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="10dp"
        >
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_alignParentBottom="true"
                android:orientation="horizontal"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    android:textSize="32dp"

                    android:textStyle="bold"
                    android:gravity="center"
                    android:textFontWeight="700"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_medium"
                    android:text="360"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:textSize="14dp"
                    android:layout_gravity="center"
                    android:textStyle="bold"
                    android:layout_marginLeft="10dp"

                    android:textFontWeight="400"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_medium"
                    android:text="AED"/>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14dp"
                android:textStyle="bold"
                android:textFontWeight="400"
                android:textColor="@color/white"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/view_breakdown"/>
        </LinearLayout>
        <TextView
            android:layout_width="0dp"
            android:layout_weight="1.5"
            android:layout_height="wrap_content"
            android:text="@string/make_payment"
            android:textStyle="bold"
            android:background="@drawable/white_rectangle"
            android:textColor="@color/black"
            android:textSize="16dp"
            android:layout_gravity="center_vertical"
            android:gravity="center"
            android:paddingVertical="18dp"
            android:id="@+id/tvPayment"
            android:textFontWeight="700"
            android:fontFamily="@font/manrope_medium"
            />
    </LinearLayout>
    <TextView
        android:layout_width="match_parent"
        android:id="@+id/tvcontinue"
        android:layout_alignParentBottom="true"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="20dp"
        android:background="@drawable/rectangle_btn"
        android:gravity="center"
        android:fontFamily="@font/manrope_bold"
        android:paddingVertical="15dp"
        android:letterSpacing="0.05"
        android:textAllCaps="true"
        android:text="@string/cont_inue"
        android:textColor="@color/white"
        android:textSize="16dp" />
</RelativeLayout>