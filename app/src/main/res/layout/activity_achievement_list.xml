<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/buttontextcolor"
    android:fitsSystemWindows="true"
    tools:context=".AchievementListActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_alignParentTop="true"
        android:layout_height="wrap_content"
        android:id="@+id/headerLayout"
        android:orientation="vertical">
        <LinearLayout
            android:background="@color/buttontextcolor"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:id="@+id/back_1"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="12dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/backarrow"
                />
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/achievements"
                />


        </LinearLayout>
        <View
            android:background="@color/tabbackground"
            android:layout_width="match_parent"
            android:layout_height="2dp"/>

    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_below="@id/headerLayout"
        android:layout_height="wrap_content"
        android:textColor="#D7D8D9"
        android:gravity="center"
        android:textSize="14sp"
        android:id="@+id/tvText"
        android:layout_marginTop="20dp"
        android:textStyle="bold"
        android:fontFamily="@font/manrope_semi_bold"
        android:text="You currently have 25 active badges.\n Congratulations on your fitness journey!"
        />
    <androidx.recyclerview.widget.RecyclerView
        android:layout_width="match_parent"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="3"
        android:layout_marginTop="30dp"
        android:layout_below="@+id/tvText"
        android:layout_marginLeft="20dp"
        android:id="@+id/recycler"
        android:layout_height="wrap_content"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textColor="#D7D8D9"
        android:gravity="center"
        android:id="@+id/tv"
        android:textSize="14sp"
        android:visibility="gone"
        android:textStyle="bold"
        android:fontFamily="@font/manrope_semi_bold"
        android:text="No Data found"
        />
</RelativeLayout>