<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"

    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/standard_bottom_sheet"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:layout_width="match_parent"
        android:background="@drawable/top_rounded_corners"

        android:layout_height="wrap_content">
        <androidx.cardview.widget.CardView
            android:layout_marginTop="10dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="70dp"
            app:cardCornerRadius="3dp"
            android:layout_height="5dp"
            app:cardBackgroundColor="@color/rulersmallline"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="18sp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="5dp"
            android:layout_marginHorizontal="20dp"
            android:fontFamily="@font/manrope_semi_bold"
            android:text="@string/add_rest_time_in_secs"
            />
        <LinearLayout
            app:cardBackgroundColor="#1C1F21"
            android:layout_width="match_parent"
            app:cardCornerRadius="12dp"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="20dp"
            android:layout_height="125dp"
            android:orientation="vertical"
            android:background="@drawable/achievments_drawable">
            <ImageView
                android:layout_marginTop="15dp"
                android:layout_width="21dp"
                android:layout_gravity="center"
                android:src="@drawable/fillarrow"
                android:layout_height="21dp" />
            <View
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"/>
            <co.com.mypt.utils.RulerView
                android:layout_width="match_parent"
                android:id="@+id/rulerviewbottom"
                android:layout_height="wrap_content"/>
        </LinearLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:id="@+id/relative"
            android:layout_alignParentBottom="true"

            android:layout_height="wrap_content">
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:id="@+id/card"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="30dp"
                app:cardBackgroundColor="#F6F3F0"
                app:cardCornerRadius="12dp"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/buttontextcolor"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginVertical="12dp"
                    android:layout_marginHorizontal="15dp"
                    android:fontFamily="@font/manrope_bold"
                    android:textAllCaps="true"
                    android:text="@string/confirm"
                    />
            </androidx.cardview.widget.CardView>

        </RelativeLayout>
    </LinearLayout>


</androidx.coordinatorlayout.widget.CoordinatorLayout>