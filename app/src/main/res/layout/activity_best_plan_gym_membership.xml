<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/onboarding_backgrd_2"
    android:fitsSystemWindows="true"
    tools:context=".fragments.CreatePackageScreen.TotalSessionFragment">

    <RelativeLayout
        android:id="@+id/topLay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/ic_back_arrow_new" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/p_Bar"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:indeterminate="false"
            android:max="100"
            android:progress="50"
            android:progressTint="@color/progress_clr_1"
            android:visibility="visible"
            app:indicatorColor="@color/progress_color"
            app:trackColor="@color/progress_color_bg"
            app:trackCornerRadius="10dp" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/tvcontinueViewParent"
        android:layout_below="@+id/topLay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/linear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_marginTop="46dp"
                android:orientation="vertical">

                <!-- Question Text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginBottom="46dp"
                    android:fontFamily="@font/clash_display_medium"
                    android:gravity="center"
                    android:text="@string/pick_plan"
                    android:textColor="@color/headingcolor"
                    android:textSize="32sp" />

                <!-- Unit Selection (kg / lbs) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/tab_linear_background"
                    android:orientation="horizontal"
                    android:paddingHorizontal="4dp"
                    android:paddingVertical="4dp">

                    <!-- Kilogram Option -->
                    <TextView
                        android:id="@+id/bestPlan"
                        android:layout_width="wrap_content"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:background="@drawable/feet_button"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:gravity="center"
                        android:paddingHorizontal="24dp"
                        android:text="@string/best_plan"
                        android:textAllCaps="false"
                        android:textColor="@color/black"
                        android:textFontWeight="700"
                        android:textSize="14sp" />

                    <!-- Pound Option -->
                    <TextView
                        android:id="@+id/customization"
                        android:layout_width="wrap_content"
                        android:layout_height="46dp"
                        android:layout_weight="1"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:gravity="center"
                        android:paddingHorizontal="24dp"
                        android:text="@string/customization"
                        android:textAllCaps="false"
                        android:textColor="@color/lightgreycolor"
                        android:textFontWeight="600"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/bestPlanParentView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical"
                android:visibility="visible">

                <com.yarolegovich.discretescrollview.DiscreteScrollView
                    android:id="@+id/carouselView"
                    android:layout_width="match_parent"
                    android:layout_height="350dp"
                    android:overScrollMode="never" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/customPlanParentView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="155dp"
                        android:layout_marginHorizontal="20dp"
                        android:background="@drawable/customiz_background"
                        android:orientation="vertical"
                        android:paddingHorizontal="24dp"
                        android:paddingVertical="24dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvCustomPlanTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/clash_display_medium"
                                android:text="Most Popular"
                                android:textColor="@color/white"
                                android:textSize="20sp" />

                            <ImageView
                                android:layout_width="4dp"
                                android:layout_height="4dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginHorizontal="8dp"
                                android:background="@drawable/diamond_white"
                                app:tint="@color/light_lavender" />

                            <TextView
                                android:id="@+id/tvDays"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/funnel_sans_regular"
                                android:text="10 Days"
                                android:textColor="@color/session"
                                android:textSize="14sp"
                                android:visibility="visible" />
                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvAED"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/clash_display_medium"
                                android:maxLines="1"
                                android:text="AED"
                                android:textColor="@color/white"
                                android:textSize="24sp"
                                android:visibility="visible" />

                            <TextView
                                android:id="@+id/tvRealPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:fontFamily="@font/clash_display_medium"
                                android:text=""
                                android:textColor="@color/white"
                                android:textSize="24sp"
                                android:visibility="visible" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/saveTxt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:background="@drawable/category_border_bg"
                            android:fontFamily="@font/funnel_sans_semibold"
                            android:paddingVertical="4dp"
                            android:paddingHorizontal="8dp"
                            android:scaleType="centerCrop"
                            android:text=""
                            android:textColor="#D1ECCC"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <co.com.mypt.rulerHeight.SessionRulerViewHorizontal
                            android:id="@+id/ruler_session"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:layout_marginTop="20dp"
                            app:layout_constraintTop_toTopOf="parent" />

                        <LinearLayout
                            android:id="@+id/arrowView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/ruler_session"
                            android:layout_marginHorizontal="20dp"
                            android:layout_marginTop="-20dp"
                            android:background="@drawable/weight_line"
                            android:gravity="center_horizontal">

                            <ImageView
                                android:layout_width="68dp"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="20dp"
                                android:src="@drawable/weightarrow" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_above="@+id/arrowView"
                            android:layout_centerHorizontal="true"
                            android:layout_marginBottom="-40dp"
                            android:src="@drawable/glow_view" />
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="40dp"
        android:background="@drawable/yellow_top_rounded_corner"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableRight="@drawable/baseline_arrow_forward_ios_24"
            android:drawableTint="@color/gold"
            android:fontFamily="@font/manrope_semi_bold"
            android:gravity="center_vertical"
            android:text="@string/not_sure_what_you_want_consult_an_expert"
            android:textColor="@color/gold"
            android:textSize="16sp" />
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/tvcontinueViewParent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottomView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/blue_border_container"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/topView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:orientation="vertical"
                android:paddingTop="6dp"
                android:paddingBottom="20dp"
                app:layout_constraintBottom_toTopOf="@+id/tvcontinueView">

                <TextView
                    android:id="@+id/yourPlan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/clash_display_regular"
                    android:text="Your Selected Plan"
                    android:textColor="@color/light_blue_text"
                    android:textSize="12sp"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:id="@+id/upArrow"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="24dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/up_arrow"
                    android:padding="5dp"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/planLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    app:layout_constraintTop_toBottomOf="@+id/yourPlan">

                    <TextView
                        android:id="@+id/packagePrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/clash_display_medium"
                        android:text="AED 800"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@drawable/d_ot"
                        android:tint="#4CFAFAFA" />

                    <TextView
                        android:id="@+id/sessionCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/clash_display_regular"
                        android:text="10 Sessions"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <ImageView
                        android:id="@+id/downArrow"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_marginStart="24dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/down_arrow"
                        android:padding="5dp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/devider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@drawable/devider"
                    android:visibility="gone"
                    app:layout_constraintBottom_toTopOf="@+id/freeMsg"
                    app:layout_constraintTop_toBottomOf="@+id/planLayout" />

                <TextView
                    android:id="@+id/freeMsg"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="16dp"
                    android:fontFamily="@font/clash_display_regular"
                    android:text="You save AED 500"
                    android:textColor="@color/neon_color"
                    android:textSize="14sp"
                    android:visibility="gone"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/devider" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/freeMsgCustom"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:fontFamily="@font/clash_display_regular"
                android:gravity="center"
                android:lineHeight="24sp"
                android:paddingVertical="16dp"
                android:text="Savings increase with more days"
                android:textColor="@color/grey_text"
                android:textSize="14sp"
                app:layout_constraintBottom_toTopOf="@+id/tvcontinueView"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:id="@+id/tvcontinueView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginVertical="20dp"
                android:background="@drawable/rounded_cornor"
                android:gravity="center"
                android:paddingVertical="15dp"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:id="@+id/tvcontinue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/funnel_sans_medium"
                    android:text="@string/next"
                    android:textAllCaps="true"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="16sp" />

                <ImageView
                    android:id="@+id/forwardArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="@color/white" />
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</RelativeLayout>