<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"

    android:background="@color/buttontextcolor"
    tools:context=".More.Setting.ChatsActivity">
    <LinearLayout
        android:id="@+id/headerLayout"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true"
        android:layout_width="match_parent"

        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back_1"
            android:layout_marginHorizontal="15dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="18sp"

            android:fontFamily="@font/manrope_medium"
            android:text="@string/chats"
            />

    </LinearLayout>
    <View
        android:background="@color/tabbackground"
        android:layout_width="match_parent"
        android:id="@+id/view"
        android:layout_below="@+id/headerLayout"
        android:layout_height="2dp"/>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_below="@+id/view"
        android:visibility="gone"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/linear"
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="15dp"
                android:orientation="horizontal"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:padding="20dp"
                    android:id="@+id/linearSearch"
                    android:background="@drawable/edittext_background"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:src="@drawable/search"
                        android:layout_width="24dp"
                        android:layout_height="24dp"/>
                    <EditText
                        android:background="@android:color/transparent"
                        android:layout_marginHorizontal="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:textColor="@color/smallTextcolor"
                        android:textColorHint="@color/headingcolor"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:id="@+id/edsearch"
                        android:fontFamily="@font/manrope_medium"
                        android:hint="Search for Workout"
                        />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="15dp"
                    android:paddingHorizontal="20dp"
                    android:background="@drawable/edittext_background">
                    <ImageView
                        android:src="@drawable/filter_edit"
                        android:layout_width="24dp"
                        android:layout_gravity="center"
                        android:layout_height="24dp"/>
                </LinearLayout>

            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:orientation="horizontal"
                android:layout_below="@id/linear"

                android:layout_marginHorizontal="15dp"
                android:id="@+id/typeByChatRecyclerview"
                android:layout_height="wrap_content"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_below="@id/typeByChatRecyclerview"
                android:layout_height="wrap_content">
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:orientation="vertical"
                    android:layout_marginBottom="20dp"

                    android:id="@+id/fullchatRecyclerview"
                    android:layout_height="wrap_content"/>
                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_gravity="center"
                    app:cardBackgroundColor="@color/home_frag_blk"
                    app:cardCornerRadius="8dp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/headingcolor"
                        android:textSize="18sp"
                        android:paddingVertical="15dp"
                        android:paddingHorizontal="20dp"
                        android:drawableTint="@color/white"
                        android:drawableRight="@drawable/baseline_arrow_forward_24"
                        android:fontFamily="@font/manrope_medium"
                        android:text="@string/view_all"

                        />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </RelativeLayout>
    </androidx.core.widget.NestedScrollView>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="20dp"
        android:paddingVertical="15dp"
        android:layout_centerHorizontal="true"
        android:paddingHorizontal="15dp"
        android:gravity="center"
        android:background="@drawable/save_setting_drawable"
        android:id="@+id/linearSave">
        <ImageView
            android:layout_width="24dp"
            android:src="@drawable/message"
            android:layout_height="24dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/buttontextcolor"
            android:textSize="16sp"
            android:layout_marginLeft="10dp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:gravity="center"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/start_new_chat"
            />

    </LinearLayout>
    <ImageView
        android:layout_width="match_parent"
        android:src="@drawable/im_chat"
        android:scaleType="centerCrop"
        android:layout_below="@id/headerLayout"
        android:layout_height="wrap_content"/>
</RelativeLayout>