<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="12dp"
    app:cardBackgroundColor="#101113"

    android:layout_marginRight="15dp"
    android:layout_marginBottom="15dp"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"

            android:layout_marginVertical="10dp"
            android:layout_marginHorizontal="10dp"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="100dp"
                android:gravity="center"
                android:background="@drawable/weekly_list_drawable"
                android:layout_height="100dp">
                <ImageView
                    android:layout_width="62dp"
                    android:src="@drawable/gymgirl"
                    android:scaleType="fitXY"
                    android:layout_height="78dp"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="15dp"

                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_medium"
                    android:text="HandGripper - Green - 5kg to 60kg"
                    />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp"
                    android:layout_height="match_parent">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:id="@+id/tvprice"
                        android:textStyle="bold"
                        android:fontFamily="@font/clash_display_medium"
                        android:text="299"
                        />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:id="@+id/tvcurrency"
                        android:layout_marginLeft="2dp"
                        android:fontFamily="@font/clash_display_medium"
                        android:text="AED"
                        />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/progress_track_color_1"
                        android:textSize="12sp"
                        android:layout_marginLeft="10dp"
                        android:id="@+id/tvRealPrice"
                        android:fontFamily="@font/clash_display_medium"
                        android:text="329 AED"
                        />

                </LinearLayout>

            </LinearLayout>


        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:layout_marginRight="15dp"
            android:layout_marginBottom="20dp"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="28dp"
                android:src="@drawable/im_minus"
                android:id="@+id/im_minus"
                android:layout_height="28dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:text="1"
                android:layout_gravity="center"
                android:layout_marginHorizontal="5dp"
                android:gravity="center"
                android:textColor="@color/white"
                android:layout_height="wrap_content"/>
            <ImageView
                android:layout_width="28dp"
                android:src="@drawable/im_add"
                android:id="@+id/im_add"
                android:layout_height="28dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>