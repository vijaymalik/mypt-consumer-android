<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:background="@drawable/onboarding_backgrd_2"
    android:fitsSystemWindows="true"
    android:layout_height="match_parent"
    tools:context=".activities.SelectTime">
    <LinearLayout
        android:layout_above="@+id/linearpay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/headerLayout"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:id="@+id/back_1"
                android:layout_marginHorizontal="20dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/ic_back_arrow_new"
                />
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/book_a_slot"
                />

            <ImageView
                android:id="@+id/verticalDots"
                android:layout_width="50dp"
                android:visibility="gone"
                android:padding="12dp"
                android:layout_height="match_parent"
                android:src="@drawable/vertical_dots"/>
        </LinearLayout>
        <View
            android:background="@color/tabbackground"
            android:layout_width="match_parent"
            android:layout_height="2dp"/>

        <com.michalsvec.singlerowcalendar.calendar.SingleRowCalendar
            android:id="@+id/main_single_row_calendar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="10dp"
            app:deselection="false"
            app:longPress="false"
            app:multiSelection="false" />
        <LinearLayout
            android:orientation="vertical"
            android:visibility="gone"
            android:id="@+id/animLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_marginHorizontal="10dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_gravity="center_vertical"
                    android:layout_height="wrap_content"
                    android:textColor="@color/headingcolor"
                    android:textSize="16sp"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:text="@string/select_time_of_the_day"
                    />
                <LinearLayout
                    android:layout_width="150dp"
                    android:gravity="end|center_vertical"
                    android:layout_height="wrap_content"
                    android:background="@drawable/night_rectangle"
                    android:orientation="horizontal"
                    android:layout_marginEnd="10dp">

                    <LinearLayout
                        android:layout_width="90dp"
                        android:visibility="gone"
                        android:layout_gravity="center"
                        android:id="@+id/linernight"
                        android:background="@drawable/white_rectangle"
                        android:layout_height="wrap_content"
                        android:layout_marginVertical="5dp"
                        android:gravity="center_horizontal"
                        android:layout_marginLeft="5dp"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="5dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_gravity="center"
                            android:src="@drawable/night_mode"
                            android:layout_marginRight="10dp"
                            app:tint="@color/black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/night"
                            android:textColor="@color/black"
                            android:textSize="12sp"
                            android:fontFamily="@font/manrope_semi_bold"
                            />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="15dp"
                        android:id="@+id/im_night"
                        android:src="@drawable/night_mode"/>
                    <LinearLayout
                        android:layout_width="90dp"
                        android:layout_gravity="center"
                        android:gravity="center_horizontal"
                        android:id="@+id/linearmrng"
                        android:background="@drawable/white_rectangle"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="5dp"
                        android:layout_marginVertical="5dp"
                        android:paddingVertical="10dp"
                        android:paddingHorizontal="5dp"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="15dp"
                            android:layout_height="15dp"
                            android:layout_gravity="center"
                            android:src="@drawable/sunny"
                            android:layout_marginRight="10dp"
                            app:tint="@color/black" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/morning"
                            android:textColor="@color/black"
                            android:textSize="12sp"
                            android:fontFamily="@font/manrope_semi_bold"
                            />
                    </LinearLayout>
                    <ImageView
                        android:layout_width="0dp"
                        android:visibility="gone"
                        android:layout_weight="1"
                        android:layout_height="15dp"
                        android:id="@+id/im_mrng"
                        android:src="@drawable/sunny"
                        app:tint="@color/white" />

                </LinearLayout>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerViewTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:spanCount="3"
                android:layout_marginStart="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="10dp"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager" />
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:id="@+id/linearNoData"
                android:layout_height="match_parent">
                <ImageView
                    android:layout_width="236dp"
                    android:layout_marginTop="-30dp"
                    android:layout_marginBottom="-30dp"
                    android:layout_height="236dp"
                    android:src="@drawable/im_no_slot"/>
                <TextView
                    android:layout_marginEnd="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/headingcolor"
                    android:textSize="24sp"
                    android:id="@+id/tvNodata"
                    android:fontFamily="@font/clash_display_medium"
                    android:text="@string/no_slots_found"
                    />
            </LinearLayout>
           
        </LinearLayout>
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:id="@+id/linearpay"
        android:layout_marginVertical="10dp"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">
        <LinearLayout
            android:gravity="center"
            android:id="@+id/createPackage"
            android:background="@drawable/package_layout"
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:layout_height="wrap_content">
            <TextView

                android:layout_width="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:paddingVertical="20dp"
                android:id="@+id/tvPackage"
                android:gravity="center"
                android:textColor="@color/green1"
                android:fontFamily="@font/manrope_semi_bold"
                android:text="@string/create_a_package_and_save_50"
                />
            <ImageView
                android:layout_marginStart="5dp"
                android:layout_marginTop="2dp"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/baseline_arrow_forward_ios_24"
                app:tint="#0FA958" />
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="10dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:textSize="32sp"
                        android:id="@+id/tvprice"
                        android:gravity="center"
                        android:textColor="@color/white"
                        android:fontFamily="@font/manrope_bold"
                        android:text=""/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:layout_marginTop="3dp"
                        android:layout_gravity="center"
                        android:textStyle="bold"
                        android:id="@+id/tvCurrency"
                        android:layout_marginLeft="10dp"
                        android:textColor="@color/white"
                        android:fontFamily="@font/manrope_regular_400"
                        android:text="AED"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:id="@+id/tvCost"
                    android:textStyle="bold"
                    android:textColor="@color/smallTextcolor"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:text="@string/view_breakdown"/>
            </LinearLayout>
            <TextView
                android:layout_width="200dp"
                android:layout_height="56dp"
                android:text="@string/make_payment"
                android:background="@drawable/white_rectangle"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:layout_gravity="center_vertical"
                android:gravity="center"
                android:id="@+id/tvPayment"
                android:textAllCaps="true"
                android:fontFamily="@font/manrope_bold"
                />
        </LinearLayout>



    </LinearLayout>

</RelativeLayout>