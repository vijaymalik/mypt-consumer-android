<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/left_right_corner"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"

        android:orientation="vertical">
        <androidx.cardview.widget.CardView
            android:layout_marginTop="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="70dp"
            app:cardCornerRadius="3dp"
            android:layout_height="5dp"
            app:cardBackgroundColor="@color/rulersmallline"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="24sp"
            android:padding="15dp"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:id="@+id/title"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/rate_your_trainer"
            />

        <TextView

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/smallTextcolor"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginHorizontal="15dp"
            android:gravity="center"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/your_feedback_helps_us_improve_and_recognize_great_trainer"
            />
        <RatingBar
            style="@style/ratingStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:id="@+id/rating"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="-30dp"
            android:layout_gravity="center"
            />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:padding="15dp"
            android:gravity="center"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="Fine"
            />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/smallTextcolor"
            android:textSize="14sp"
            android:padding="15dp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/additional_feedback"
            />
        <EditText
            android:id="@+id/feedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/edittext_background"
            android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrst uvwxyz1234567890"
            android:inputType="textPersonName"
            android:hint="@string/type_here"
            android:minHeight="150dp"
            android:maxHeight="150dp"
            android:gravity="start"
            android:textColorHint="@color/smallTextcolor"
            android:padding="15dp"
            android:textColor="@color/smallTextcolor"
            android:layout_marginHorizontal="15dp"
            android:textStyle="bold"

            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_alignParentBottom="true"
        android:layout_height="wrap_content"
        android:text="@string/submit_feedback"
        android:layout_marginBottom="25dp"
        android:layout_marginTop="25dp"
        android:layout_marginHorizontal="15dp"
        android:textStyle="bold"
        android:layout_gravity="bottom"
        android:id="@+id/tvsubmit_feedback"
        android:background="@drawable/white_rectangle"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:gravity="center"
        android:paddingVertical="15dp"
        android:textFontWeight="700"
        android:fontFamily="@font/manrope_medium"
        />
</androidx.coordinatorlayout.widget.CoordinatorLayout>