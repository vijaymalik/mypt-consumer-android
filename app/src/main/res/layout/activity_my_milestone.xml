<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:background="@color/buttontextcolor"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"

    tools:context=".More.MyMilestoneActivity">
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/linearheader"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginEnd="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/my_milestone"
            />

    </LinearLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:id="@+id/relative"
        android:layout_height="match_parent">
        <View
            android:layout_width="match_parent"
            android:alpha="0.8"
            android:background="@color/black"
            android:layout_height="match_parent"/>
        <ImageView
            android:layout_width="match_parent"
            android:src="@drawable/blank_locked_screen"
            android:id="@+id/im"
            android:scaleType="centerCrop"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:layout_height="wrap_content">
            <TextView
                android:layout_marginTop="200dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:gravity="center"
                android:id="@+id/tv"
                android:layout_below="@id/im"
                android:fontFamily="@font/clashdisplay_medium"
                android:text="@string/locked_for_now"
                />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_below="@id/tv"
                android:fontFamily="@font/manrope_semi_bold"
                android:text="@string/your_achievements_and_milestones_will_be_available_soon"
                />

        </LinearLayout>

    </RelativeLayout>


</LinearLayout>