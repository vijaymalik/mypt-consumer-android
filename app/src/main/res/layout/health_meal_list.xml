<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.cardview.widget.CardView
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginStart="2dp"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="20dp"
        android:layout_width="290dp"
        android:layout_height="185dp">

        <RelativeLayout
            android:background="@drawable/product_gradient"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <LinearLayout
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="20dp"
                    android:layout_marginEnd="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:text="Salad &amp; Egg"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:fontFamily="@font/clash_display_medium"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textColor="@color/headingcolor"
                        android:id="@+id/tv"
                        />
                    <ImageView
                        android:layout_marginHorizontal="8dp"
                        android:visibility="gone"
                        android:src="@drawable/share"
                        android:layout_width="24dp"
                        android:layout_height="24dp"/>
                    <ImageView
                        android:id="@+id/heart1"
                        android:src="@drawable/heart"
                        android:layout_width="24dp"
                        android:layout_height="24dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_marginStart="20dp"
                    android:layout_width="wrap_content"
                    android:orientation="horizontal"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/fire"
                        android:layout_width="16dp"
                        android:layout_height="16dp"/>
                    <TextView
                        android:text="250"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/headingcolor"
                        android:id="@+id/tvcal"
                        />
                    <TextView
                        android:text=" kcal"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/headingcolor"
                        />
                </LinearLayout>

                <View
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    />
                <LinearLayout
                    android:layout_marginStart="20dp"
                    android:layout_width="wrap_content"
                    android:orientation="horizontal"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/green_dumble"
                        android:layout_width="16dp"
                        android:layout_height="16dp"/>
                    <TextView
                        android:text="30g"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/headingcolor"
                        android:id="@+id/tvprotein"
                        />
                    <TextView
                        android:text=" Protein"
                        android:fontFamily="@font/manrope_variablefont_wght"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/headingcolor"
                        />
                </LinearLayout>
                <LinearLayout
                    android:layout_marginBottom="20dp"
                    android:layout_marginStart="20dp"
                    android:layout_width="wrap_content"
                    android:orientation="horizontal"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_gravity="center_vertical"
                        android:src="@drawable/fat"
                        android:layout_width="16dp"
                        android:layout_height="16dp"/>
                    <TextView
                        android:text="19g"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/headingcolor"
                        android:id="@+id/tvFat"
                        />
                    <TextView
                        android:text=" Fat"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/headingcolor"
                        />
                </LinearLayout>
            </LinearLayout>
            <ImageView
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_width="150dp"
                android:layout_height="wrap_content"
                android:src="@drawable/fork"
                android:adjustViewBounds="true"
                />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_marginBottom="15dp"
        android:id="@+id/relative"
        android:visibility="gone"
        android:layout_marginTop="6dp"
        android:layout_marginHorizontal="15dp"
        android:background="@drawable/meal_list_drawable"
        android:layout_height="225dp">

        <ImageView
            android:layout_marginLeft="10dp"
            android:layout_marginRight="15dp"
            android:layout_width="146dp"
            android:src="@drawable/fork"
            android:layout_marginBottom="2dp"
            android:layout_alignParentEnd="true"
            android:layout_alignParentBottom="true"
            android:layout_height="123dp" />

        <LinearLayout
            android:id="@+id/ll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="10dp"
                android:layout_marginTop="10dp">


                <CheckBox
                    android:id="@+id/checkbox"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:buttonTint="@color/white"
                    style="@style/CustomCheckboxBrand"
                    android:textColor="@color/white" />
            </RelativeLayout>

            <TextView
                android:text="Salad Egg"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:id="@+id/title"

                android:layout_marginLeft="20dp"
                android:layout_marginRight="10dp"
                android:fontFamily="@font/clash_display_medium"
                android:textColor="@color/headingcolor"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="15dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/fire" />

                <TextView
                    android:text="251"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:layout_marginLeft="5dp"
                    android:id="@+id/calories"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:text="kcal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:layout_marginLeft="5dp"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"

                    android:src="@drawable/dumbell_fill"
                    app:tint="#A1DD70" />
                <TextView
                    android:text="25g"
                    android:id="@+id/protien"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:layout_marginLeft="5dp"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="14sp"/>
                <TextView
                    android:text="Protein"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:layout_marginLeft="5dp"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="14sp"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/fire"
                    app:tint="#FFE899" />

                <TextView
                    android:text="17g"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:id="@+id/fat"
                    android:layout_marginLeft="5dp"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

                <TextView
                    android:text="fat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:layout_marginLeft="5dp"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>

    </RelativeLayout>
    <RelativeLayout
        android:layout_width="122dp"
        android:layout_marginLeft="30dp"
        android:visibility="gone"
        android:layout_height="40dp">
        <TextView
            android:text="Breakfast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:background="@drawable/half_rectangle"
            android:gravity="center"
            android:paddingBottom="10dp"
            android:fontFamily="@font/manrope_medium"
            android:textColor="#4A3016"
            android:textSize="12sp"/>


    </RelativeLayout>
</RelativeLayout>