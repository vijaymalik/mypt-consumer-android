<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@drawable/top_rounded_corners">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:layout_marginHorizontal="15dp"
        android:id="@+id/standard_bottom_sheet"
        >
        <androidx.cardview.widget.CardView
            android:layout_marginTop="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="70dp"
            app:cardCornerRadius="3dp"
            android:layout_height="5dp"
            app:cardBackgroundColor="@color/rulersmallline"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">
            <TextView

                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:paddingVertical="15dp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/add_members"
                />
            <ImageView
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:id="@+id/imClose"
                android:layout_gravity="center"
                android:src="@drawable/close"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_gravity="center"
            android:background="@drawable/edittext_background">
            <com.google.android.material.textfield.TextInputLayout

                android:layout_width="match_parent"
                android:layout_gravity="center"
                android:layout_height="wrap_content"
                app:hintTextColor="@color/booked"
                app:boxStrokeColor="@android:color/transparent"
                android:paddingVertical="5dp"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1dp"
                android:textColorHint="@color/booked"
                android:background="@android:color/transparent"
                app:hintTextAppearance="@style/MyFloatingLabelStyle"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textCursorDrawable="@null"
                    android:id="@+id/tvname"
                    android:imeOptions="actionNext"
                    android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrst uvwxyz1234567890"
                    android:inputType="none"
                    android:fontFamily="@font/manrope_medium"
                    android:textColorHint="@color/smallTextcolor"
                    android:hint="@string/enter_full_name"
                    android:textColor="@color/headingcolor"
                    android:background="@android:color/transparent"

                    />

            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_gravity="center"
            android:background="@drawable/edittext_background">
            <com.google.android.material.textfield.TextInputLayout

                android:layout_width="match_parent"
                android:layout_gravity="center"
                android:layout_height="wrap_content"
                app:hintTextColor="@color/booked"
                app:boxStrokeColor="@android:color/transparent"
                android:paddingVertical="5dp"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1dp"
                android:textColorHint="@color/booked"
                android:background="@android:color/transparent"
                app:hintTextAppearance="@style/MyFloatingLabelStyle"
                >

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textCursorDrawable="@null"
                    android:id="@+id/tvAge"
                    android:digits="1234567890"
                    android:inputType="phone"
                    android:maxLength="3"
                    android:imeOptions="actionDone"
                    android:fontFamily="@font/manrope_medium"
                    android:textColorHint="@color/smallTextcolor"
                    android:hint="@string/enter_age"

                    android:textColor="@color/headingcolor"
                    android:background="@android:color/transparent"

                    />

            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
        <TextView

            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="14sp"
            android:paddingVertical="15dp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/select_gender"
            />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <CheckBox
                android:paddingHorizontal="5dp"
                android:id="@+id/checkmale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:buttonTint="@color/white"
                style="@style/CustomCheckboxBrand"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/white"
                android:checked="true"
                android:text="@string/male" />
            <CheckBox

                android:paddingHorizontal="5dp"
                android:id="@+id/checkfemale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:layout_marginLeft="15dp"
                android:buttonTint="@color/white"
                style="@style/CustomCheckboxBrand"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/white"
                android:text="@string/female" />
            <CheckBox
                android:paddingHorizontal="5dp"
                android:id="@+id/checkOther"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:layout_marginLeft="15dp"
                android:buttonTint="@color/white"
                style="@style/CustomCheckboxBrand"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/white"
                android:text="@string/others" />

        </LinearLayout>


        <LinearLayout
            android:layout_marginTop="40dp"
            android:layout_width="match_parent"
            android:layout_marginBottom="20dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:id="@+id/tvSaveAndNext"
                android:layout_height="wrap_content"
                android:layout_marginRight="5dp"

                android:background="@drawable/view_detail_rectangle"
                android:gravity="center"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="15dp"
                android:textFontWeight="700"
                android:textAllCaps="true"
                android:text="@string/save_add_next"
                android:textStyle="bold"
                android:textColor="@color/headingcolor"
                android:textSize="16dp" />
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:id="@+id/tvSave"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"

                android:background="@drawable/grey_rectangle_rounded"

                android:gravity="center"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="15dp"
                android:textFontWeight="700"
                android:textAllCaps="true"
                android:text="@string/save"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:textSize="16dp" />
        </LinearLayout>

    </LinearLayout>


</androidx.coordinatorlayout.widget.CoordinatorLayout>