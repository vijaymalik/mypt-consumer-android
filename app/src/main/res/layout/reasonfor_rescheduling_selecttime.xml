<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/left_right_corner"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <androidx.cardview.widget.CardView
            android:layout_marginTop="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="70dp"
            app:cardCornerRadius="3dp"
            android:layout_height="5dp"
            app:cardBackgroundColor="@color/rulersmallline"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="horizontal">
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:padding="15dp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/reason_for_rescheduling"
                />
            <ImageView
                android:layout_width="30dp"
                android:layout_gravity="center"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                android:id="@+id/imclose"
                android:src="@drawable/close"/>

        </LinearLayout>
        <LinearLayout
            android:layout_marginTop="30dp"
            android:layout_marginBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_marginHorizontal="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="16dp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/select_time_of_the_day"
                />
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:gravity="end|center_vertical"
                android:layout_height="wrap_content"
                android:background="@drawable/night_rectangle"
                android:orientation="horizontal"
                android:layout_marginHorizontal="10dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_gravity="center"
                    android:id="@+id/linernight"
                    android:visibility="gone"
                    android:background="@drawable/white_rectangle"
                    android:layout_height="wrap_content"
                    android:layout_marginVertical="5dp"
                    android:layout_marginLeft="5dp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="20dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_gravity="center"
                        android:src="@drawable/night_mode"
                        android:layout_marginRight="10dp"
                        app:tint="@color/black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/night"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="14dp"
                        android:fontFamily="@font/manrope_medium"
                        />
                </LinearLayout>

                <!-- Kilogram Option -->
                <ImageView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="15dp"
                    android:id="@+id/im_night"

                    android:src="@drawable/night_mode"/>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_gravity="center"
                    android:id="@+id/linearmrng"
                    android:background="@drawable/white_rectangle"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="5dp"
                    android:layout_marginVertical="5dp"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="20dp"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_gravity="center"
                        android:src="@drawable/sunny"
                        android:layout_marginRight="10dp"
                        app:tint="@color/black" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/morning"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:textSize="14dp"
                        android:fontFamily="@font/manrope_medium"
                        />
                </LinearLayout>
                <ImageView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="15dp"
                    android:id="@+id/im_mrng"
                    android:visibility="gone"
                    android:src="@drawable/sunny"
                    app:tint="@color/white" />

            </LinearLayout>

        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            app:spanCount="3"
            android:layout_marginHorizontal="5dp"
            android:layout_marginTop="10dp"
            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager" />
        <TextView
            android:layout_width="match_parent"
            android:id="@+id/tvcontinue"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/rectangle_btn"
            android:gravity="center"
            android:fontFamily="@font/manrope_medium"
            android:paddingVertical="15dp"
            android:textFontWeight="700"
            android:textAllCaps="true"
            android:text="@string/reschedule"
            android:textColor="@color/white"
            android:textSize="16sp" />
    </LinearLayout>
</RelativeLayout>