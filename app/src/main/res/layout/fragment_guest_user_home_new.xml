                                android:layout_height="match_parent"
                                android:layout_gravity="center"
                                android:scaleType="centerCrop"

                                android:src="@drawable/guest_user" />
                        </androidx.cardview.widget.CardView>
                    </RelativeLayout>

                    <LinearLayout
                        android:layout_width="0dp"
