            </RelativeLayout>
<LinearLayout
    android:layout_width="match_parent"
    android:gravity="center_vertical"
    android:paddingHorizontal="20dp"
    android:layout_marginTop="30dp"
    android:layout_marginBottom="16dp"
    android:layout_height="wrap_content">
    <View
        android:layout_width="0dp"
        android:layout_weight="1"
        android:background="@color/separator_list"
        android:layout_height="1dp"/>
    <TextView
        android:text="See MyPT in action"
        android:layout_width="wrap_content"
        android:textColor="@color/white"
        android:paddingHorizontal="20dp"
        android:fontFamily="@font/clash_display_medium"
        android:layout_height="wrap_content"/>
    <View
        android:layout_width="0dp"
        android:layout_weight="1"
        android:background="@color/separator_list"
        android:layout_height="1dp"/>
</LinearLayout>

            <LinearLayout
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/bookATrainer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:adjustViewBounds="true"
                    android:elevation="5dp"
                    android:src="@drawable/guest_user_book_trainer" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/differentWorkouts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:adjustViewBounds="true"
                        android:src="@drawable/guest_user_workout" />

                    <ImageView
                        android:id="@+id/planWorkout"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:adjustViewBounds="true"
                        android:src="@drawable/guest_user_plan_workout" />
                </LinearLayout>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/storiesListRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <ImageView
                android:id="@+id/purchaseGymPass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:adjustViewBounds="true"
                android:src="@drawable/certified_banner" />

            <LinearLayout
                android:layout_width="match_parent"
                android:gravity="center_vertical"
                android:paddingHorizontal="20dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="16dp"
                android:layout_height="wrap_content">
                <View
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:background="@color/separator_list"
                    android:layout_height="1dp"/>
                <TextView
                    android:text="Meet your match"
                    android:layout_width="wrap_content"
                    android:textColor="@color/white"
                    android:paddingHorizontal="20dp"
                    android:fontFamily="@font/clash_display_medium"
                    android:layout_height="wrap_content"/>
                <View
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:background="@color/separator_list"
                    android:layout_height="1dp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/nearByGymRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <TextView
                android:id="@+id/allTransformationStories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="30dp"
                android:fontFamily="@font/manrope_medium"
                android:gravity="center_vertical"
                android:text="@string/transformation_stories"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:textStyle="bold"

                />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/transformationRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:adjustViewBounds="true"
                android:src="@drawable/buy_session_image"
                android:visibility="gone" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="599dp"
                android:layout_marginTop="40dp"
                android:adjustViewBounds="true"
                android:src="@drawable/session_blur" />

            <TextView
                android:id="@+id/allUpcomingClass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="30dp"
                android:fontFamily="@font/manrope_medium"
                android:gravity="center_vertical"
                android:text="@string/upcoming_classes_near_you"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:textStyle="bold"
                app:drawableEndCompat="@drawable/baseline_keyboard_arrow_right_24" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/upcomingClassRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <ImageView
                android:id="@+id/imUpcomingBlur"
                android:layout_width="match_parent"
                android:layout_height="350dp"
                android:adjustViewBounds="true"
                android:src="@drawable/upcoming_blur" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="30dp"
                android:fontFamily="@font/manrope_medium"
                android:gravity="center_vertical"
                android:text="@string/shop_products"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:textStyle="bold"
                app:drawableEndCompat="@drawable/baseline_keyboard_arrow_right_24" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/shopCategoryRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/shopProductsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:orientation="horizontal"
                android:visibility="gone"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="367dp"
                android:adjustViewBounds="true"
                android:src="@drawable/shop_blur" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginVertical="30dp"
                android:src="@drawable/divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:fontFamily="@font/clash_display_medium"
                android:gravity="center_vertical"
                android:text="“ Believe you can and\nyou're halfway there ”"
                android:textColor="@color/smallTextcolor"
                android:textSize="25sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginVertical="15dp"
                android:fontFamily="@font/clash_display_regular"
                android:text="-Theodore Roosevelt"
                android:textColor="@color/edittextbordercolor"
                android:textSize="12sp" />

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:adjustViewBounds="true"
                android:scaleType="centerCrop"
                android:src="@drawable/home_header_image" />
        </LinearLayout>
    </ScrollView>


</RelativeLayout>