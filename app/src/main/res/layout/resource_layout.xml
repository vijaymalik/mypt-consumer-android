<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="356dp"
    android:layout_height="200dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/resource_border_gradient"
    android:layout_marginVertical="10dp"
    android:layout_marginRight="15dp"
    android:id="@+id/resourceLayout"
    android:padding="1.5dp"> <!-- Ensures inner content doesn't overlap the border -->

    <!-- Content Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="22dp"
        app:cardElevation="4dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <!-- Background Image -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:id="@+id/im"
                android:src="@drawable/resource_girl" />
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_marginRight="10dp"
                    android:layout_marginTop="20dp"
                    android:id="@+id/imSHare"
                    android:src="@drawable/share"
                    android:layout_height="24dp" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_marginRight="20dp"
                    android:visibility="gone"
                    android:layout_marginTop="20dp"
                    android:id="@+id/imheart"
                    android:src="@drawable/heart"
                    android:layout_height="24dp" />

            </LinearLayout>

            <!-- Gradient Overlay for Text Readability -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/resource_drawable" />

            <!-- Text Content -->
            <!--<LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zumba"
                    android:textSize="20sp"
                    android:id="@+id/tvname"
                    android:fontFamily="@font/clashdisplay_medium"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="8 classes near you"
                    android:textSize="14sp"
                    android:fontFamily="@font/manrope_medium"

                    android:textColor="@color/subheadingcolor" />
            </LinearLayout>-->
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_gravity="bottom"
                android:layout_marginTop="20dp"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="120dp"
                android:layout_height="wrap_content">

                <TextView
                    android:text="Stretching and  Recovery Sessions"
                    android:layout_marginRight="10dp"
                    android:layout_width="wrap_content"
                    android:textStyle="bold"
                    android:id="@+id/tvname"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/clash_display_medium"
                    android:textColor="@color/headingcolor"
                    android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="20dp"

                    android:layout_marginRight="10dp"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/rating_bar_bg"
                        android:visibility="gone"
                        app:tint="@color/orangecolor" />
                    <TextView
                        android:text="4.1"
                        android:layout_width="wrap_content"
                        android:textStyle="bold"
                        android:layout_marginHorizontal="10dp"
                        android:layout_gravity="center"
                        android:id="@+id/tvRating"
                        android:visibility="gone"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_marginRight="10dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:background="@drawable/dot" />
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:visibility="gone"
                        android:layout_gravity="center"
                        android:src="@drawable/orangeheart"
                        />
                    <TextView
                        android:text="251"
                        android:id="@+id/tvLike"
                        android:layout_marginLeft="5dp"
                        android:layout_width="wrap_content"
                        android:visibility="gone"

                        android:layout_gravity="center"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/white"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>