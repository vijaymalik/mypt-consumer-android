<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    android:layout_width="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:background="@drawable/top_rounded_corners"
        app:cardCornerRadius="15dp"
        android:id="@+id/standard_bottom_sheet"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:orientation="vertical"
        android:layout_height="wrap_content">
        <androidx.cardview.widget.CardView
            android:layout_marginTop="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="70dp"
            app:cardCornerRadius="3dp"
            android:layout_height="5dp"
            app:cardBackgroundColor="@color/rulersmallline"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:padding="15dp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/don_t_let_this_session_go_to_waste_you_re_one_step_closer_to_your_goals"
                />
            <ImageView
                android:id="@+id/close"
                android:layout_width="30dp"
                android:layout_gravity="center"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/close"/>

        </LinearLayout>
        <androidx.cardview.widget.CardView
            android:layout_marginTop="20dp"
            android:layout_marginBottom="50dp"
            android:layout_marginHorizontal="15dp"
            app:cardCornerRadius="10dp"
            app:cardBackgroundColor="#0954A9"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_margin="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <LinearLayout
                    android:gravity="center_vertical"
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:src="@drawable/customer_support"
                        android:layout_width="24dp"
                        android:layout_height="24dp"/>
                    <TextView
                        android:textSize="16sp"
                        android:textColor="@color/headingcolor"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_marginHorizontal="10dp"
                        android:text="@string/dedicated_support"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                    <ImageView
                        android:src="@drawable/arrow_right"
                        android:layout_width="24dp"
                        android:layout_height="24dp"/>
                </LinearLayout>
                <TextView
                    android:layout_marginTop="5dp"
                    android:textSize="14sp"
                    android:textColor="@color/ltblue"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_medium"
                    android:layout_marginStart="40dp"
                    android:text="@string/for_assistance_with_on_training_issues_or_any_escalations"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <TextView
            android:layout_width="match_parent"
            android:id="@+id/tvCancel"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_marginVertical="20dp"
            android:background="@drawable/rounded_corner_red"
            android:gravity="center"
            android:fontFamily="@font/manrope_medium"
            android:paddingVertical="15dp"
            android:textFontWeight="700"
            android:textAllCaps="true"
            android:text="Proceed to Cancel"
            android:textStyle="bold"
            android:textColor="@color/red"
            android:textSize="16dp" />
        <TextView
            android:layout_width="match_parent"
            android:id="@+id/tvrescheduleBooking"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_marginBottom="35dp"
            android:background="@drawable/apply_rectangle"
            android:gravity="center"
            android:fontFamily="@font/manrope_medium"
            android:paddingVertical="15dp"
            android:textFontWeight="700"
            android:textAllCaps="true"
            android:text="@string/reschedule"
            android:textStyle="bold"
            android:textColor="@color/buttontextcolor"
            android:textSize="16dp" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>