<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/left_right_corner"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <androidx.cardview.widget.CardView
            android:layout_marginTop="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="70dp"
            app:cardCornerRadius="3dp"
            android:layout_height="5dp"
            app:cardBackgroundColor="@color/rulersmallline"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30dp"
            android:orientation="horizontal">
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:padding="15dp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/reason_for_rescheduling"
                />
            <ImageView
                android:layout_width="30dp"
                android:layout_gravity="center"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                android:id="@+id/imclose"
                android:src="@drawable/close"/>

        </LinearLayout>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/smallTextcolor"
            android:textSize="14sp"
            android:layout_marginHorizontal="15dp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/select_your_new_date"
            />
        <RelativeLayout
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <androidx.cardview.widget.CardView
                    app:cardBackgroundColor="@color/tabbackground"
                    android:layout_marginHorizontal="20dp"
                    app:cardCornerRadius="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="50dp"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:src="@drawable/arrow_left"
                            android:layout_width="50dp"
                            android:padding="10dp"
                            android:id="@+id/imLeft"
                            android:layout_height="50dp"/>
                        <TextView
                            android:gravity="center"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:textColor="@color/headingcolor"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:id="@+id/monthName"
                            android:fontFamily="@font/manrope_medium"
                            />
                        <ImageView
                            android:src="@drawable/arrow_right"
                            android:layout_width="50dp"
                            android:padding="10dp"
                            android:id="@+id/imRight"
                            android:layout_height="50dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </RelativeLayout>
            <RelativeLayout
                android:layout_marginTop="70dp"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/calendar_gradient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_margin="1dp"
                    android:layout_centerInParent="true"
                    android:layout_width="match_parent"
                    android:background="@drawable/product_gradient_rounded_corner"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <com.prolificinteractive.materialcalendarview.MaterialCalendarView
                        android:id="@+id/calendarView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:mcv_showOtherDates="all"
                        android:layout_marginBottom="10dp"
                        app:mcv_dateTextAppearance="@style/CustomDateTextAppearance"
                        app:mcv_weekDayTextAppearance="@style/CustomWeekDayTextAppearance"
                        />
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:layout_margin="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <androidx.cardview.widget.CardView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            app:cardCornerRadius="5dp"
                            app:cardBackgroundColor="@color/available"/>
                        <TextView
                            android:layout_marginHorizontal="5dp"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:textColor="@color/transparent_white_1"
                            android:textSize="14sp"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/available"
                            />

                        <androidx.cardview.widget.CardView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            app:cardCornerRadius="5dp"
                            app:cardBackgroundColor="@color/fast_filling"/>
                        <TextView
                            android:layout_marginHorizontal="5dp"
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/transparent_white_1"
                            android:textSize="14sp"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/fast_filling"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:layout_marginHorizontal="10dp"
                        android:layout_marginBottom="20dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <androidx.cardview.widget.CardView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            app:cardCornerRadius="5dp"
                            app:cardBackgroundColor="@color/fully_booked"/>
                        <TextView
                            android:layout_marginHorizontal="5dp"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:textColor="@color/transparent_white_1"
                            android:textSize="14sp"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/fully_booked"
                            />

                        <androidx.cardview.widget.CardView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            app:cardCornerRadius="5dp"
                            app:cardBackgroundColor="@color/booked"/>
                        <TextView
                            android:layout_marginHorizontal="5dp"
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/transparent_white_1"
                            android:textSize="14sp"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/closed"
                            />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </RelativeLayout>

        <TextView
            android:layout_width="match_parent"
            android:id="@+id/tvcontinue"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/rectangle_btn"
            android:gravity="center"
            android:fontFamily="@font/manrope_medium"
            android:paddingVertical="15dp"
            android:textFontWeight="700"
            android:textAllCaps="true"
            android:text="@string/reschedule"
            android:textColor="@color/white"
            android:textSize="16sp" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>