<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@drawable/onboarding_backgrd_2"
    tools:context=".activities.TrainersListActivity">
    <LinearLayout
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back"
            android:layout_marginHorizontal="15dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/ic_back_arrow_new"
            />
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="14sp"
            android:textStyle="bold"
            android:id="@+id/userName"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/trainers"
            />
        <View
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="1dp"/>
        <EditText
            android:visibility="visible"
            android:layout_width="88dp"
            android:paddingHorizontal="5dp"
            android:paddingVertical="2dp"
            android:textSize="14sp"
            android:text=""
            android:focusable="true"
            android:hint="@string/search"
            android:textColorHint="@color/bg_color_btn_disabled"
            android:focusableInTouchMode="true"
            android:id="@+id/searchEditText"
            android:drawablePadding="6dp"
            android:textColor="@color/headingcolor"
            android:drawableTint="@color/white"
            android:drawableStart="@drawable/baseline_search_24"
            android:background="@drawable/edittext_border"
            android:layout_height="35dp"/>
       <!-- <ImageView
            android:id="@+id/searchTrainer"
            android:gravity="center_vertical"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginEnd="10dp"
            android:src="@drawable/search"/>-->
        <LinearLayout
            android:layout_marginStart="12dp"
            android:layout_marginEnd="20dp"
            android:gravity="center_vertical"
            android:background="@drawable/transparent_white_border"
            android:layout_width="wrap_content"
            android:paddingVertical="7dp"
            android:paddingHorizontal="7dp"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_marginEnd="5dp"

                android:id="@+id/linearList"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/selected_linear_list"
                 />
            <ImageView

                android:id="@+id/gridList"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/grid_layout"/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="@color/tabbackground"
        android:layout_width="match_parent"
        android:layout_height="2dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_height="wrap_content">
        <androidx.recyclerview.widget.RecyclerView
            android:layout_marginVertical="15dp"
            android:layout_marginLeft="15dp"
            android:id="@+id/exerciseRecyclerView"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
        <androidx.recyclerview.widget.RecyclerView
            android:layout_marginBottom="15dp"
            android:layout_marginLeft="15dp"
            android:id="@+id/filterRecyclerView"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/trainerRecyclerView"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:textColor="@color/headingcolor"
        android:textSize="14sp"
        android:visibility="gone"
        android:gravity="center"
        android:textStyle="bold"
        android:id="@+id/tvNodata"
        android:fontFamily="@font/manrope_medium"
        android:text="@string/no_data_found"
        />
</LinearLayout>