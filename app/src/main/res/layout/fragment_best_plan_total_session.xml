<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".fragments.CreatePackageScreen.TotalSessionFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_marginTop="46dp"
            android:orientation="vertical">

            <!-- Question Text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginBottom="46dp"
                android:fontFamily="@font/clash_display_medium"
                android:gravity="center"
                android:text="@string/pick_plan"
                android:textColor="@color/headingcolor"
                android:textSize="32sp" />

            <!-- Unit Selection (kg / lbs) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginHorizontal="20dp"
                android:background="@drawable/tab_linear_background"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp"
                android:paddingVertical="4dp">

                <!-- Kilogram Option -->
                <TextView
                    android:id="@+id/bestPlan"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:background="@drawable/feet_button"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:text="@string/best_plan"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textFontWeight="700"
                    android:textSize="14sp" />

                <!-- Pound Option -->
                <TextView
                    android:id="@+id/customization"
                    android:layout_width="wrap_content"
                    android:layout_height="46dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:gravity="center"
                    android:paddingHorizontal="24dp"
                    android:text="@string/customization"
                    android:textAllCaps="false"
                    android:textColor="@color/lightgreycolor"
                    android:textFontWeight="600"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginHorizontal="15dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            app:cardBackgroundColor="@color/tabbackground"
                            app:cardCornerRadius="12dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="10dp"
                                android:layout_marginTop="10dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <androidx.cardview.widget.CardView
                                    android:layout_width="55dp"
                                    android:layout_height="55dp"
                                    android:layout_marginTop="10dp"
                                    android:layout_marginBottom="10dp"
                                    app:cardBackgroundColor="@color/tabbackground"
                                    app:cardCornerRadius="12dp">

                                    <ImageView
                                        android:id="@+id/imTrainer"
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:scaleType="centerCrop" />
                                </androidx.cardview.widget.CardView>

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginHorizontal="10dp"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvTrainer_name"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:fontFamily="@font/manrope_medium"
                                        android:textColor="@color/headingcolor"
                                        android:textFontWeight="700"
                                        android:textSize="14dp"
                                        android:textStyle="bold" />

                                    <androidx.recyclerview.widget.RecyclerView
                                        android:id="@+id/recycler"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
                                </LinearLayout>

                                <androidx.cardview.widget.CardView
                                    android:id="@+id/cardEdit"
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:layout_gravity="center"
                                    app:cardBackgroundColor="@color/home_frag_blk"
                                    app:cardCornerRadius="18dp">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/edit" />
                                </androidx.cardview.widget.CardView>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_marginHorizontal="15dp"
                        android:layout_marginTop="85dp"
                        android:background="@drawable/total_sessions_bg"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvPerSession"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="10dp"
                                android:fontFamily="@font/manrope_semi_bold"
                                android:text="@string/per_session_cost"
                                android:textColor="@color/orangecolor"
                                android:textSize="14dp" />

                            <androidx.appcompat.widget.SwitchCompat
                                android:id="@+id/switchCompat"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:thumb="@drawable/switch_thumb"
                                app:track="@drawable/switch_track" />

                            <TextView
                                android:id="@+id/tvTotalcost"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:fontFamily="@font/manrope_semi_bold"
                                android:text="@string/total_cost"
                                android:textColor="@color/booked"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="5dp"
                                android:layout_marginTop="10dp">

                                <ImageView
                                    android:id="@+id/greenLine"
                                    android:layout_width="wrap_content"
                                    android:layout_height="100dp"
                                    android:layout_marginStart="-2dp"
                                    android:adjustViewBounds="true"
                                    android:src="@drawable/green_vertical_line" />

                                <LinearLayout
                                    android:id="@+id/sessionValueCard"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_centerVertical="true"
                                    android:orientation="vertical">

                                    <View
                                        android:id="@+id/view1"
                                        android:layout_width="1px"
                                        android:layout_height="60dp"
                                        android:layout_marginStart="35dp"
                                        android:layout_marginTop="20dp"
                                        android:background="@color/white"
                                        android:visibility="invisible" />

                                    <View
                                        android:id="@+id/view2"
                                        android:layout_width="1px"
                                        android:layout_height="20dp"
                                        android:layout_marginStart="35dp"
                                        android:layout_marginTop="-10dp"
                                        android:background="@color/white"
                                        android:visibility="invisible" />

                                    <androidx.cardview.widget.CardView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="-15dp"
                                        app:cardBackgroundColor="@color/home_frag_blk"
                                        app:cardCornerRadius="10dp">

                                        <TextView
                                            android:id="@+id/sessionValue"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:background="@drawable/black_25_transparent_rounded_bg"
                                            android:fontFamily="@font/manrope_semi_bold"
                                            android:paddingHorizontal="14dp"
                                            android:paddingVertical="10dp"
                                            android:textColor="@color/white"
                                            android:textSize="14sp" />
                                    </androidx.cardview.widget.CardView>

                                </LinearLayout>

                                <LinearLayout
                                    android:id="@+id/endLayout"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentEnd="true"
                                    android:orientation="vertical"
                                    android:visibility="gone">

                                    <View
                                        android:layout_width="1px"
                                        android:layout_height="60dp"
                                        android:layout_marginTop="20dp"
                                        android:layout_marginEnd="35dp"
                                        android:background="@drawable/blue_gradient" />

                                    <View
                                        android:layout_width="1px"
                                        android:layout_height="20dp"
                                        android:layout_marginTop="-10dp"
                                        android:layout_marginEnd="35dp"
                                        android:background="@drawable/blue_gradient" />
                                </LinearLayout>

                                <SeekBar
                                    android:id="@+id/seekBar"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="40dp"
                                    android:max="100"
                                    android:maxHeight="10dp"
                                    android:progressDrawable="@drawable/seekbar_style"
                                    android:splitTrack="false"
                                    android:thumb="@drawable/custom_thumb"
                                    android:thumbOffset="0dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentStart="true"
                                    android:layout_marginStart="20dp"
                                    android:layout_marginTop="20dp"
                                    android:fontFamily="@font/manrope_semi_bold"
                                    android:text="0"
                                    android:textColor="@color/white"
                                    android:textSize="10sp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_alignParentEnd="true"
                                    android:layout_marginTop="20dp"
                                    android:layout_marginEnd="20dp"
                                    android:fontFamily="@font/manrope_semi_bold"
                                    android:text="100"
                                    android:textColor="@color/white"
                                    android:textSize="10dp" />
                            </RelativeLayout>

                            <RelativeLayout
                                android:id="@+id/relaticeSave"
                                android:layout_width="wrap_content"

                                android:layout_height="wrap_content">

                                <TextView
                                    android:id="@+id/tvContent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/save_validity_drawable"
                                    android:fontFamily="@font/manrope_medium"
                                    android:paddingHorizontal="20dp"
                                    android:paddingVertical="8dp"
                                    android:text="Save 20%"
                                    android:textColor="#DFE3E7"
                                    android:textSize="14sp" />

                                <ImageView
                                    android:id="@+id/im"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_below="@id/tvContent"
                                    android:layout_centerInParent="true"
                                    android:layout_marginTop="-8dp"
                                    android:src="@drawable/baseline_arrow_drop_down_24"
                                    app:tint="#9EBCFF" />
                            </RelativeLayout>

                        </RelativeLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="15dp"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal">

                            <TextSwitcher
                                android:id="@+id/textSwitcher1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:inAnimation="@anim/slide_in_top"
                                android:outAnimation="@anim/slide_out_bottom" />

                            <TextView
                                android:id="@+id/tvRealPrice1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:fontFamily="@font/clash_display_medium"
                                android:text="300"
                                android:textColor="@color/booked"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/tvAEDSession1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="10dp"
                                android:fontFamily="@font/clash_display_medium"
                                android:text="AED / Session"
                                android:textColor="@color/white"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:visibility="gone" />
                        </LinearLayout>

                    </LinearLayout>
                </RelativeLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginTop="15dp"
                    android:background="@drawable/light_grey_rectangle"
                    android:fontFamily="monospace"
                    android:gravity="center"
                    android:paddingVertical="12dp"
                    android:text="@string/increase_session_count_for_lower_per_session_cost"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="12sp" />

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/bestPlanParentView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:orientation="vertical">

            <com.yarolegovich.discretescrollview.DiscreteScrollView
                android:id="@+id/carouselView"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:overScrollMode="never" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/customPlanParentView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="155dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@drawable/customiz_background"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingVertical="24dp">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/funnel_sans_medium"
        android:text="Per Session Cost"
        android:textColor="@color/white"
        android:textSize="16sp" />
    <View
        android:layout_width="4dp"
        android:background="@drawable/otp_gradient_grey"
        android:layout_height="4dp"/>
    <TextView
        android:id="@+id/sessionSelected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/funnel_sans_regular"
        android:text="10 Sessions"
        android:textColor="@color/session"
        android:textSize="14sp" />
</LinearLayout>


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:orientation="horizontal">

                        <TextSwitcher
                            android:id="@+id/textSwitcher"
                            android:fontFamily="@font/clash_display_medium"
                            android:textSize="24sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:inAnimation="@anim/slide_in_top"
                            android:visibility="visible"
                            android:outAnimation="@anim/slide_out_bottom" />

                        <TextView
                            android:id="@+id/tvRealPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/clash_display_medium"
                            android:text="300"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvAEDSession"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:fontFamily="@font/clash_display_medium"
                            android:text="AED / Session"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:visibility="visible" />
                    </LinearLayout>

                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <co.com.mypt.rulerHeight.SessionRulerViewHorizontal
                        android:id="@+id/ruler_session"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="50dp"
                        app:layout_constraintTop_toTopOf="parent" />

                    <LinearLayout
                        android:id="@+id/arrowView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/ruler_session"
                        android:layout_marginHorizontal="20dp"
                        android:layout_marginTop="-33dp"
                        android:background="@drawable/weight_line"
                        android:gravity="center_horizontal">

                        <ImageView
                            android:layout_width="68dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="20dp"
                            android:adjustViewBounds="true"
                            android:src="@drawable/weightarrow" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_above="@+id/arrowView"
                        android:layout_centerHorizontal="true"
                        android:layout_marginBottom="-40dp"
                        android:src="@drawable/glow_view" />
                </RelativeLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="40dp"
        android:background="@drawable/yellow_top_rounded_corner"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawableRight="@drawable/baseline_arrow_forward_ios_24"
            android:drawableTint="@color/gold"
            android:fontFamily="@font/manrope_semi_bold"
            android:gravity="center_vertical"
            android:text="@string/not_sure_what_you_want_consult_an_expert"
            android:textColor="@color/gold"
            android:textSize="16sp" />
    </RelativeLayout>
</RelativeLayout>