<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:background="@drawable/top_rounded_corners"
        app:cardCornerRadius="15dp"
        android:id="@+id/standard_bottom_sheet"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:orientation="vertical"
        android:layout_height="wrap_content">
        <androidx.cardview.widget.CardView
            android:layout_marginTop="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="70dp"
            app:cardCornerRadius="3dp"
            android:layout_height="5dp"
            app:cardBackgroundColor="@color/rulersmallline"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:padding="15dp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/reason_for_cancellation"
                />
            <ImageView
                android:id="@+id/close"
                android:layout_width="30dp"
                android:layout_gravity="center"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/close"/>

        </LinearLayout>
        <CheckBox
            android:paddingHorizontal="5dp"
            android:id="@+id/scheduleConflict"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginHorizontal="15dp"
            android:buttonTint="@color/white"
            style="@style/CustomCheckboxBrand"
            android:fontFamily="@font/manrope_medium"
            android:textColor="@color/white"
            android:text="@string/schedule_conflict" />
        <CheckBox
            android:paddingHorizontal="5dp"
            android:id="@+id/feelingUnwell"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginHorizontal="15dp"
            android:buttonTint="@color/white"
            style="@style/CustomCheckboxBrand"
            android:fontFamily="@font/manrope_medium"
            android:textColor="@color/white"
            android:text="@string/feeling_unwell" />
        <CheckBox
            android:paddingHorizontal="5dp"
            android:id="@+id/unexpectedCommitment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginHorizontal="15dp"
            android:buttonTint="@color/white"
            style="@style/CustomCheckboxBrand"
            android:fontFamily="@font/manrope_medium"
            android:textColor="@color/white"
            android:text="@string/unexpected_personal_commitment" />
        <CheckBox
            android:paddingHorizontal="5dp"
            android:id="@+id/changeOfPlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:layout_marginHorizontal="15dp"
            android:buttonTint="@color/white"
            style="@style/CustomCheckboxBrand"
            android:fontFamily="@font/manrope_medium"
            android:textColor="@color/white"
            android:text="@string/change_of_plans" />
        <LinearLayout
            android:layout_marginBottom="10dp"
            android:background="@drawable/grey_rounded_corner_rectangle"
            android:layout_width="match_parent"
            android:layout_marginTop="50dp"
            android:paddingStart="20dp"
            android:layout_marginHorizontal="15dp"
            android:gravity="center_vertical"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_marginHorizontal="10dp"
                android:src="@drawable/baseline_info_outline_24"
                android:layout_width="24dp"
                android:layout_height="24dp"
                app:tint="@color/fast_filling" />
            <TextView
                android:letterSpacing=".12"
                android:layout_width="wrap_content"
                android:id="@+id/tvcontinue"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="15dp"
                android:text="@string/we_won_t_be_charging_you_a_cancellation_fee"
                android:textColor="@color/white"
                android:textSize="12sp" />
        </LinearLayout>
        <TextView
            android:layout_width="match_parent"
            android:id="@+id/cancelBooking"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:layout_marginBottom="35dp"
            android:background="@drawable/rectangle_btn"
            android:gravity="center"
            android:fontFamily="@font/manrope_medium"
            android:paddingVertical="15dp"
            android:textFontWeight="700"
            android:textAllCaps="true"
            android:text="@string/cancel_booking"
            android:textStyle="bold"
            android:textColor="@color/headingcolor"
            android:textSize="16dp" />
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>