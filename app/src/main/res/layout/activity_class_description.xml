<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:visibility="gone"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/buttontextcolor"
    tools:context=".UpComingClasses.ClassDescriptionActivity">

    <androidx.core.widget.NestedScrollView
        android:scrollbars="none"
        android:layout_alignTop="@+id/tvReserveSlot"
        android:layout_alignParentTop="true"
        android:id="@+id/scrollView"
        android:layout_marginBottom="65dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="358dp">
                <ImageView
                    android:id="@+id/trainerImage"
                    android:scaleType="centerCrop"

                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/class_description_drawable" />

                <RelativeLayout
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:id="@+id/back"
                        android:layout_marginHorizontal="10dp"
                        android:layout_marginVertical="20dp"
                        android:src="@drawable/backarrow"
                        />
                    <ImageView
                        android:layout_width="45dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="10dp"
                        android:id="@+id/imSHare"
                        android:src="@drawable/share_rectangle"
                        android:layout_height="45dp"/>
                   <!-- <androidx.cardview.widget.CardView
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="10dp"
                        app:cardBackgroundColor="@color/headingcolor"
                        app:cardCornerRadius="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <androidx.cardview.widget.CardView
                            app:cardBackgroundColor="@color/buttontextcolor"
                            android:layout_margin="1dp"
                            android:layout_gravity="center"
                            app:cardCornerRadius="8dp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:paddingHorizontal="15dp"
                                android:paddingVertical="8dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/headingcolor"
                                android:textSize="14sp"

                                android:fontFamily="@font/manrope_medium"
                                android:text="@string/follow"
                                />
                        </androidx.cardview.widget.CardView>
                    </androidx.cardview.widget.CardView>-->
                </RelativeLayout>
                <LinearLayout

                    android:layout_marginHorizontal="15dp"
                    android:layout_alignParentBottom="true"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:id="@+id/userName"
                        android:fontFamily="@font/clash_display_medium"
                        android:text="Zumba Classes"
                        />



                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <LinearLayout
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/date_drawable"
                            android:layout_marginLeft="10dp"
                            android:gravity="center"
                            android:layout_marginBottom="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="10dp"
                                android:textStyle="bold"
                                android:id="@+id/tvdate"
                                android:fontFamily="@font/manrope_medium"
                                android:text="28 August, 10:00 AM GST"
                                />

                        </LinearLayout>

                    </RelativeLayout>
                </LinearLayout>
            </RelativeLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:layout_marginVertical="10dp"
                android:textSize="12sp"
                android:layout_marginHorizontal="15dp"
                android:textStyle="bold"
                android:id="@+id/tv_no_of_student"
                android:fontFamily="@font/manrope_medium"
                android:text="Class of 20 students"
                />
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_marginHorizontal="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/location"/>
                <TextView
                    android:text="2.5km"
                    android:id="@+id/distance"
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="12sp"/>
                <View
                    android:layout_marginEnd="5dp"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@drawable/dot"/>
                <TextView
                    android:text="Near Dubai Mall"
                    android:id="@+id/place"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="12sp"/>


            </LinearLayout>


            <TextView
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="15dp"
                android:text="Christene is obsessed with fitness and healthy living, with 5 years of fitness experience... Read More"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/aboutTrainerText"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/subheadingcolor"
                android:textSize="14sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/about_the_trainer"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:textStyle="bold" />
            <LinearLayout
                android:layout_marginBottom="10dp"
                android:layout_marginHorizontal="15dp"

                android:gravity="center_vertical"
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardBackgroundColor="@color/edittextbordercolor"
                    app:cardCornerRadius="40dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="78dp"
                        android:layout_height="78dp"
                        android:layout_gravity="center"
                        app:cardBackgroundColor="#24262B"
                        app:cardCornerRadius="39dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:id="@+id/imTrainer"
                            android:layout_height="match_parent"
                            android:src="@drawable/dummy_trainer" />
                    </androidx.cardview.widget.CardView>


                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:id="@+id/trainer_name"
                    android:layout_marginLeft="10dp"
                    android:fontFamily="@font/clash_display_medium"
                    android:text="Chrstene De Koning"
                    />
                <ImageView
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/badge"/>


                <RelativeLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <LinearLayout
                        android:layout_marginBottom="5dp"
                        android:layout_alignParentEnd="true"
                        android:background="@drawable/product_gradient_rounded_corner"
                        android:paddingHorizontal="20dp"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:fontFamily="@font/manrope_medium"
                            android:text="1.12K"
                            android:id="@+id/tvFollowers"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_marginBottom="5dp"
                            android:text="@string/followers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/headingcolor"
                            android:textSize="12sp"/>
                    </LinearLayout>

                </RelativeLayout>
            </LinearLayout>


            <LinearLayout
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout

                    android:gravity="center"
                    android:background="@drawable/product_gradient_rounded_corner"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:layout_marginTop="15dp"
                        android:layout_marginHorizontal="10dp"
                        android:text="100+"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/tvSession"
                        android:fontFamily="@font/clash_display_medium"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="30sp"/>
                    <TextView
                        android:layout_marginBottom="15dp"
                        android:text="@string/sessions_conducted"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/white"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_marginHorizontal="10dp"
                    android:gravity="center"
                    android:background="@drawable/product_gradient_rounded_corner"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:layout_marginTop="15dp"
                        android:layout_marginHorizontal="10dp"
                        android:text="4.2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/avgRating"
                        android:fontFamily="@font/clash_display_medium"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="30sp"/>
                    <TextView
                        android:layout_marginBottom="15dp"
                        android:text="@string/average_rating1"
                        android:layout_width="wrap_content"
                        android:gravity="center"
                        android:layout_marginHorizontal="10dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/white"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout

                    android:gravity="center"
                    android:background="@drawable/product_gradient_rounded_corner"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:layout_marginTop="15dp"
                        android:layout_marginHorizontal="10dp"
                        android:text="234"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/clientsCoached"
                        android:fontFamily="@font/clash_display_medium"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="30sp"/>
                    <TextView
                        android:layout_marginBottom="15dp"
                        android:text="@string/clients_coached1"
                        android:layout_width="wrap_content"
                        android:gravity="center"
                        android:layout_marginHorizontal="10dp"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/white"
                        android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/specialities"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:layout_marginStart="9dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/specialitiesRecyclerView"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:orientation="horizontal"
                />
            <TextView
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/certifications"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvCertificate"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"/>
            <RelativeLayout
                android:layout_width="match_parent"
                android:visibility="gone"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginTop="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:gravity="center"
                        android:background="@drawable/product_gradient_rounded_corner"
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <TextView
                            android:layout_marginTop="15dp"
                            android:layout_marginHorizontal="10dp"
                            android:text="Lvl. 2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/certificationTv1"
                            android:fontFamily="@font/clash_display_medium"
                            android:textColor="@color/subheadingcolor"
                            android:textSize="30sp"/>


                        <TextView
                            android:layout_marginBottom="15dp"
                            android:text="@string/personal_training"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_marginHorizontal="10dp"
                        android:gravity="center"
                        android:background="@drawable/product_gradient_rounded_corner"
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <TextView
                            android:layout_marginTop="15dp"
                            android:layout_marginHorizontal="10dp"
                            android:text="2&amp;3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/clash_display_medium"
                            android:textColor="@color/subheadingcolor"
                            android:textSize="30sp"/>
                        <TextView
                            android:layout_marginBottom="15dp"
                            android:text="@string/average_rating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:gravity="center"
                        android:background="@drawable/product_gradient_rounded_corner"
                        android:orientation="vertical"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <TextView
                            android:layout_marginTop="15dp"
                            android:layout_marginHorizontal="10dp"
                            android:text="3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/clash_display_medium"
                            android:textColor="@color/subheadingcolor"
                            android:textSize="30sp"/>
                        <TextView
                            android:layout_marginBottom="15dp"
                            android:text="@string/clients_coached"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>

                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_weight="1"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/sand_clock"
                        />
                    <ImageView
                        android:layout_weight="1"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/certificate_fire"
                        />
                    <ImageView
                        android:layout_weight="1"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        />
                </LinearLayout>
            </RelativeLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:orientation="horizontal"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="5dp"
                android:id="@+id/certificateRecycler"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/why_train_with_me"
                android:id="@+id/tvWHyTrain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"/>
            <androidx.cardview.widget.CardView
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="10dp"
                android:descendantFocusability="blocksDescendants"
                app:cardCornerRadius="24dp"
                android:layout_width="match_parent"
                android:layout_height="480dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <VideoView
                        android:focusable="false"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentBottom="true"
                        android:id="@+id/videoView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        />
                    <ImageView
                        android:id="@+id/play"
                        android:src="@drawable/play"
                        android:layout_centerInParent="true"
                        android:layout_width="50dp"
                        android:layout_height="50dp"/>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>
            <TextView
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/personal_motivation_quote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"/>
            <LinearLayout
                android:paddingVertical="10dp"
                android:layout_marginVertical="10dp"
                android:layout_marginHorizontal="15dp"
                android:orientation="vertical"
                android:background="@drawable/product_gradient_rounded_corner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:gravity="center"
                    android:layout_marginVertical="15dp"
                    android:layout_marginHorizontal="10dp"
                    android:text="“ Believe you can and you're halfway there ”"
                    android:layout_width="match_parent"
                    android:id="@+id/tvQuote"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/clash_display_medium"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="24sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:fontFamily="@font/clash_display_medium"
                    android:textColor="@color/subheadingcolor"
                    android:text="-Theodore Roosevelt"
                    android:visibility="gone"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginVertical="15dp"/>
            </LinearLayout>
            <TextView
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/media_gallery"
                android:id="@+id/tvMedia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:orientation="horizontal"
                android:layout_marginStart="9dp"
                android:descendantFocusability="blocksDescendants"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/galleryRecyclerView"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <LinearLayout
        android:background="@color/buttontextcolor"
        android:id="@+id/headerLayout"
        android:gravity="center_vertical"

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back_1"
            android:layout_marginHorizontal="10dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="14sp"
            android:textStyle="bold"
            android:id="@+id/trainerName_1"
            android:fontFamily="@font/clash_display_medium"
            android:text="Zumba Classes"
            />

        <androidx.cardview.widget.CardView
            android:layout_marginEnd="10dp"
            app:cardBackgroundColor="@color/headingcolor"
            app:cardCornerRadius="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <androidx.cardview.widget.CardView
                app:cardBackgroundColor="@color/buttontextcolor"
                android:layout_margin="1dp"
                android:layout_gravity="center"
                app:cardCornerRadius="8dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/headingcolor"
                    android:textSize="14sp"
                    android:id="@+id/follow"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/follow"
                    />
            </androidx.cardview.widget.CardView>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
    <TextView
        android:layout_width="match_parent"
        android:id="@+id/tvReserveSlot"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/white_rectangle"
        android:gravity="center"
        android:fontFamily="@font/manrope_medium"
        android:paddingVertical="15dp"
        android:textFontWeight="700"
        android:layout_alignParentBottom="true"
        android:text="Reserve Slot @ AED 299"
        android:textColor="@color/buttontextcolor"
        android:textSize="16sp" />
</RelativeLayout>