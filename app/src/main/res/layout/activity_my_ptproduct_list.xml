<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="@color/buttontextcolor"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"

    tools:context=".Shop.MyPTProductListActivity">
    <RelativeLayout
        android:layout_width="match_parent"
        android:id="@+id/relativeProductList"
        android:layout_height="wrap_content"
        >
        <LinearLayout
            android:id="@+id/headerLayout"
            android:gravity="center_vertical"
            android:layout_alignParentTop="true"
            android:layout_width="match_parent"

            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:id="@+id/back_1"
                android:layout_marginHorizontal="15dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/backarrow"
                />
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/mypt_products"
                />

        </LinearLayout>
        <View
            android:background="@color/tabbackground"
            android:layout_width="match_parent"
            android:id="@+id/view"
            android:layout_below="@+id/headerLayout"
            android:layout_height="2dp"/>
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_below="@id/view"
            android:layout_above="@id/linear"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:layout_height="wrap_content">
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    android:orientation="vertical"
                    app:spanCount="2"
                    android:id="@+id/FeatureRecycler"
                    android:layout_height="wrap_content"/>
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    app:cardCornerRadius="12dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginBottom="25dp"
                    android:layout_marginHorizontal="15dp"
                    android:layout_height="174dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:src="@drawable/resource_girl"
                        android:scaleType="fitXY"
                        android:layout_height="match_parent"/>


                </androidx.cardview.widget.CardView>
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    android:orientation="vertical"
                    app:spanCount="2"
                    android:id="@+id/bottomRecycler"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:id="@+id/linear"

            android:background="@drawable/half_arc_product"
            android:layout_alignParentBottom="true"

            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:id="@+id/linearSort"
                android:gravity="center"
                android:padding="20dp"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="20dp"
                    android:src="@drawable/im_sort"

                    android:layout_height="20dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_height="match_parent"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/sort_by"
                    />
            </LinearLayout>

            <View

                android:background="@drawable/line_gradient"
                android:layout_width="1dp"
                android:layout_height="match_parent"/>
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="20dp"
                android:id="@+id/linearFilter"
                android:layout_height="match_parent">
                <ImageView
                    android:layout_width="20dp"
                    android:src="@drawable/sort"
                    android:layout_height="20dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_marginLeft="10dp"
                    android:layout_height="match_parent"
                    android:textColor="@color/headingcolor"
                    android:textSize="12sp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/filters"
                    />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:id="@+id/relative"
        android:visibility="gone"
        android:layout_height="wrap_content">
        <LinearLayout
            android:id="@+id/headerLayout1"
            android:gravity="center_vertical"
            android:layout_alignParentTop="true"
            android:layout_width="match_parent"

            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:id="@+id/back"
                android:layout_marginHorizontal="15dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/backarrow"
                />
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/shop"
                />

        </LinearLayout>
        <View
            android:background="@color/tabbackground"
            android:layout_width="match_parent"
            android:id="@+id/view1"
            android:layout_below="@+id/headerLayout1"
            android:layout_height="2dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_below="@+id/view1"
            android:layout_above="@+id/linearbutton"
            android:orientation="horizontal"
            android:layout_height="match_parent">
            <LinearLayout
                android:layout_width="wrap_content"
                android:orientation="vertical"
                android:layout_height="match_parent">
                <TextView
                    android:layout_width="134dp"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textColor="@color/light_gray_filter"
                    android:textSize="16sp"
                    android:layout_marginStart="-10dp"

                    android:id="@+id/tvcategory"
                    android:gravity="center"
                    android:paddingVertical="20dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/categories"
                    />
                <TextView
                    android:layout_width="134dp"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:id="@+id/tvPrice"

                    android:textColor="@color/light_gray_filter"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:paddingVertical="20dp"
                    android:layout_marginStart="-10dp"

                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/price"
                    />
                <TextView
                    android:layout_width="134dp"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textColor="@color/light_gray_filter"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:id="@+id/tvBrand"
                    android:paddingVertical="20dp"
                    android:layout_marginStart="-10dp"

                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/brand"
                    />
                <TextView
                    android:layout_width="134dp"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textColor="@color/light_gray_filter"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:id="@+id/tvrating"
                    android:layout_marginStart="-10dp"

                    android:paddingVertical="20dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/ratings"
                    />


            </LinearLayout>
            <View
                android:layout_width="1dp"
                android:background="#101113"
                android:layout_marginBottom="20dp"
                android:layout_height="match_parent"/>
            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:orientation="vertical"
                android:id="@+id/CategoryRecycle"
                android:layout_height="wrap_content"/>

        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_alignParentBottom="true"
            android:id="@+id/linearbutton"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:text="@string/reset"
                    android:layout_weight="1"
                    android:textColor="@color/headingcolor"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:paddingVertical="15dp"
                    android:textStyle="bold"
                    android:id="@+id/tvDetail"
                    android:textAllCaps="true"
                    android:fontFamily="@font/manrope_medium"
                    android:layout_height="wrap_content"
                    android:background="@drawable/view_detail_rectangle"/>
                <androidx.cardview.widget.CardView
                    app:cardBackgroundColor="@color/headingcolor"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="15dp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:id="@+id/tvConfirmGym"
                    android:layout_height="wrap_content">
                    <TextView
                        android:background="@color/headingcolor"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/buttontextcolor"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_gravity="center"
                        android:id="@+id/bookSlot"
                        android:textAllCaps="true"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Apply Filter (1)"
                        android:paddingHorizontal="40dp"
                        android:paddingVertical="15dp"
                        />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>


    </RelativeLayout>



</RelativeLayout>