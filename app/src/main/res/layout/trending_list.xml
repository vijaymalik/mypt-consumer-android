<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="180dp"
    android:layout_height="300dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/trending_drawable"
    android:layout_marginLeft="15dp"
    android:paddingVertical="1dp"
    android:paddingHorizontal="1dp"> <!-- Ensures inner content doesn't overlap the border -->

    <!-- Content Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/trendingbackground"/>

            <!-- Background Image -->
            <LinearLayout
                android:layout_width="match_parent"
                android:gravity="center_horizontal"
                android:background="@color/tabbackground"
                android:layout_height="match_parent">
                <ImageView
                    android:layout_width="129dp"
                    android:src="@drawable/gymgirl"
                    android:layout_marginTop="30dp"
                    android:scaleType="centerCrop"
                    android:layout_height="129dp"/>
            </LinearLayout>


            <!-- Text Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:background="@drawable/half_trending_list"
                android:orientation="vertical"
                >
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_marginTop="15dp"
                    android:layout_marginHorizontal="15dp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_medium"
                    android:text="HandGripper - Green  5kg to 60kg"
                    />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginVertical="15dp"

                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:id="@+id/tvprice"
                        android:textStyle="bold"
                        android:fontFamily="@font/clash_display_medium"
                        android:text="299"
                        />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:id="@+id/tvcurrency"
                        android:layout_marginLeft="2dp"
                        android:textStyle="bold"
                        android:fontFamily="@font/clash_display_medium"
                        android:text="AED"
                        />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/progress_track_color_1"
                        android:textSize="12sp"
                        android:layout_marginLeft="10dp"
                        android:textStyle="bold"
                        android:id="@+id/tvRealPrice"
                        android:fontFamily="@font/clash_display_medium"
                        android:text="329 AED"
                        />
                </LinearLayout>
            </LinearLayout>

        </FrameLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>

