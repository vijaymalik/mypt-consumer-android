<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/onboarding_backgrd_2"
    android:fitsSystemWindows="true">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout

                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/backgroundImg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignTop="@+id/headerLayout"
                    android:layout_alignBottom="@+id/botomview"
                    android:scaleType="fitXY" />

                <LinearLayout
                    android:id="@+id/headerLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingVertical="20dp"
                    android:paddingStart="20dp">

                    <RelativeLayout
                        android:id="@+id/parentLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:id="@+id/locId"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:src="@drawable/ic_location" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="5dp"
                                android:ellipsize="end"
                                android:fontFamily="@font/clash_display_medium"
                                android:gravity="center_vertical"
                                android:maxLines="1"
                                android:text="Home"
                                android:textColor="@color/white"
                                app:drawableEndCompat="@drawable/down_arrow" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/location"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/locId"
                            android:layout_alignStart="@+id/locId"
                            android:layout_marginHorizontal="20dp"
                            android:layout_toLeftOf="@+id/profileView"
                            android:ellipsize="end"
                            android:fontFamily="@font/clash_display_medium"
                            android:maxLines="1"
                            android:text="@string/choose_location"
                            android:textColor="@color/headingcolor"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:visibility="visible" />

                        <RelativeLayout
                            android:id="@+id/profileView"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_alignParentRight="true"
                            android:layout_centerInParent="true"
                            android:layout_marginEnd="20dp"
                            android:background="@drawable/user_profile_bg">

                            <TextView
                                android:id="@+id/tvProfile"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:fontFamily="@font/funnel_sans_medium"
                                android:textSize="18sp"
                                android:textAllCaps="true"
                                android:textColor="@color/gold_700"
                                android:layout_gravity="center" />
                        </RelativeLayout>
                    </RelativeLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/homeBanner"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_below="@+id/headerLayout"
                    android:scaleType="fitCenter" />

                <HorizontalScrollView
                    android:id="@+id/ptGym"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/homeBanner"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="-40dp"
                    android:scrollbars="none">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <RelativeLayout
                            android:layout_width="100dp"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/homePt"
                                android:layout_width="match_parent"
                                android:layout_height="135dp"
                                android:scaleType="fitCenter" />

                            <TextView
                                android:id="@+id/tvmember"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_marginTop="20dp"
                                android:fontFamily="@font/clash_display_medium"
                                android:text="Book \nsession"
                                android:textColor="@color/white"
                                android:visibility="gone"
                                android:textSize="14sp" />


                        </RelativeLayout>

                        <View
                            android:layout_width="8dp"
                            android:layout_height="wrap_content" />

                        <RelativeLayout
                            android:layout_width="100dp"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/topUpPlan"
                                android:layout_width="match_parent"
                                android:layout_height="132dp"
                                android:scaleType="fitCenter" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_marginTop="20dp"
                                android:fontFamily="@font/clash_display_medium"
                                android:text="Top Up\nPlan"
                                android:visibility="gone"
                                android:textColor="@color/white"
                                android:textSize="14sp" />


                        </RelativeLayout>

                        <View
                            android:layout_width="8dp"
                            android:layout_height="wrap_content" />

                        <RelativeLayout
                            android:layout_width="100dp"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/renewPlan"
                                android:layout_width="match_parent"
                                android:layout_height="132dp"
                                android:layout_weight="1"
                                android:scaleType="fitCenter" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_marginTop="20dp"
                                android:fontFamily="@font/clash_display_medium"
                                android:text="Renew\nPlan"
                                android:visibility="gone"
                                android:textColor="@color/white"
                                android:textSize="14sp" />

                        </RelativeLayout>

                        <View
                            android:layout_width="8dp"
                            android:layout_height="wrap_content" />

                        <RelativeLayout
                            android:layout_width="100dp"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:id="@+id/upgradePlan"
                                android:layout_width="match_parent"
                                android:layout_height="132dp"
                                android:scaleType="fitCenter" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_marginTop="20dp"
                                android:fontFamily="@font/clash_display_medium"
                                android:text="Upgrade\nPlan"
                                android:visibility="gone"
                                android:textColor="@color/white"
                                android:textSize="14sp" />

                        </RelativeLayout>
                    </LinearLayout>
                </HorizontalScrollView>

                <View
                    android:id="@+id/botomview"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:layout_below="@+id/ptGym" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!--<ImageView
                    android:id="@+id/im"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:scaleType="centerCrop"
                    android:src="@drawable/home_bg_ic" />-->

                <!--<LinearLayout
                    android:id="@+id/linearProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginTop="100dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <RelativeLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/golden_ring_bg">

                        <androidx.cardview.widget.CardView
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:layout_centerInParent="true"
                            app:cardCornerRadius="18dp">

                            <ImageView
                                android:id="@+id/improfile"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_gravity="center"
                                android:scaleType="centerCrop"

                                android:src="@drawable/guest_user" />
