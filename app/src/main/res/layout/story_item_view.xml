<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/relative"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="85dp"
        android:id="@+id/backImg"
        android:layout_height="120dp"
        android:layout_marginEnd="10dp"
        app:cardCornerRadius="8dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/classImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/upcoming_class_dummy" />

            <androidx.cardview.widget.CardView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="@drawable/black_background"
                android:layout_marginTop="10dp"
                android:layout_marginStart="5dp"
                app:cardBackgroundColor="@color/home_frag_blk"
                app:cardCornerRadius="8dp">

                <ImageView
                    android:id="@+id/iconTrn"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/menu"
                    android:layout_gravity="center"
                    android:scaleType="fitXY" />
            </androidx.cardview.widget.CardView>


        </RelativeLayout>
    </androidx.cardview.widget.CardView>
    <TextView
        android:id="@+id/typeTrain"
        android:layout_below="@+id/backImg"
        android:layout_width="85dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:layout_marginTop="4dp"
        android:fontFamily="@font/funnel_sans_regular"
        android:maxLines="1"
        android:gravity="center_horizontal"
        android:text="Location"
        android:textColor="@color/location_color"
        android:textSize="10sp" />
</RelativeLayout>