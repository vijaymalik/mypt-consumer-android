<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="15dp"
    android:id="@+id/linear"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_marginEnd="20dp"
        android:layout_height="wrap_content"
        android:background="@drawable/workout_gradient_rectangle">
        <androidx.cardview.widget.CardView
            android:layout_margin="1dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/relative"
                android:background="@drawable/product_gradient">
                <ImageView
                    android:layout_width="240dp"
                    android:layout_alignParentEnd="true"
                    android:layout_height="wrap_content"
                    android:layout_alignBottom="@id/linearLayout"
                    android:layout_alignTop="@id/linearLayout"
                    android:scaleType="centerCrop"
                    android:id="@+id/im"
                    android:src="@drawable/gymgirl"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/linearLayout"
                    >
                    <LinearLayout
                        android:paddingVertical="15dp"
                        android:layout_marginHorizontal="10dp"
                        android:layout_marginVertical="10dp"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <androidx.cardview.widget.CardView
                            app:cardCornerRadius="8dp"
                            app:cardBackgroundColor="@color/home_frag_blk"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">
                            <TextView
                                android:text="Intense"
                                android:fontFamily="@font/manrope_medium"
                                android:textSize="14sp"
                                android:id="@+id/tvType"
                                android:padding="5dp"
                                android:textColor="@color/headingcolor"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </androidx.cardview.widget.CardView>
                        <TextView

                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:id="@+id/tvName"
                            android:layout_marginTop="15dp"
                            android:layout_marginLeft="7dp"
                            android:fontFamily="@font/clash_display_medium"
                            android:text="Upper Strength 2"
                            />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/headingcolor"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:id="@+id/totalWorkouts"
                            android:layout_marginTop="5dp"
                            android:layout_marginLeft="7dp"
                            android:fontFamily="@font/manrope_medium"
                            android:text="8 Series Workout"
                            />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:layout_marginLeft="7dp"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/baseline_timer_24"
                                app:tint="@color/smallTextcolor" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/headingcolor"
                                android:textSize="14sp"
                                android:layout_marginLeft="5dp"
                                android:textStyle="bold"
                                android:id="@+id/tvTime"
                                android:fontFamily="@font/manrope_medium"
                                android:text="1h 30min"
                                />

                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:layout_marginLeft="7dp"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/solid_fire"
                                app:tint="@color/smallTextcolor" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/headingcolor"
                                android:textSize="14sp"
                                android:layout_marginLeft="5dp"
                                android:textStyle="bold"
                                android:id="@+id/tvCalorie"
                                android:fontFamily="@font/manrope_medium"
                                android:text="251"
                                />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/headingcolor"
                                android:textSize="14sp"
                                android:id="@+id/tvkcal"
                                android:layout_marginLeft="5dp"
                                android:fontFamily="@font/manrope_medium"
                                android:text="Kcal"
                                />


                        </LinearLayout>

                    </LinearLayout>
                    <LinearLayout
                        android:gravity="end"
                        android:orientation="vertical"
                        android:layout_marginEnd="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        >
                        <LinearLayout
                            android:layout_marginTop="20dp"
                            android:layout_width="wrap_content"
                            android:layout_height="0dp"
                            android:layout_weight="1">
                            <ImageView
                                android:layout_marginEnd="10dp"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/share"/>
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:id="@+id/imheart"
                                android:src="@drawable/heart"/>
                        </LinearLayout>
                        <ImageView
                            android:layout_marginBottom="20dp"
                            android:id="@+id/play"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/play_fab_button"/>
                    </LinearLayout>


                </LinearLayout>

            </RelativeLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</LinearLayout>