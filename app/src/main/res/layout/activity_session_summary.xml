<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/buttontextcolor"
    android:fitsSystemWindows="true"
    tools:context=".WorkoutLibrary.SessionSummaryActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/linearHeader"
        android:layout_alignParentTop="true"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/headerLayout"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:id="@+id/back_1"
                android:layout_marginHorizontal="10dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/backarrow"
                />
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/workout_library"
                />


        </LinearLayout>
        <View
            android:background="@color/tabbackground"
            android:layout_width="match_parent"

            android:layout_height="2dp"/>


    </LinearLayout>
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:layout_below="@id/linearHeader"
        android:src="@drawable/gym_men"/>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/session_background"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_above="@id/tvWorkoutName"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_centerHorizontal="true"
        android:padding="10dp"
        android:id="@+id/tvWorkoutTotal"
        android:fontFamily="@font/manrope_medium"
        android:textFontWeight="700"
        android:textAllCaps="true"
        android:background="@drawable/joining_rectangle"
        android:textColor="@color/white"
        android:textSize="14sp" />
    <TextView
        android:layout_width="match_parent"
        android:layout_above="@id/linearDetail"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="20dp"
        android:gravity="center"
        android:id="@+id/tvWorkoutName"
        android:fontFamily="@font/clashdisplay_medium"
        android:textFontWeight="700"
        android:textAllCaps="true"
        android:text="Back Workout"
        android:textColor="@color/white"
        android:textSize="32sp" />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:id="@+id/linearDetail"
        android:layout_marginBottom="20dp"
        android:layout_above="@+id/tv_complete"
        android:layout_marginHorizontal="10dp"
        android:orientation="horizontal">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:background="@drawable/product_gradient_rounded_corner"
            android:orientation="horizontal"
            android:clipToOutline="true"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="43dp"
                android:layout_height="43dp"
                android:scaleType="centerCrop"
                android:layout_gravity="bottom"
                android:src="@drawable/starttimer"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:id="@+id/tvTime"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:fontFamily="@font/manrope_medium"
                    />
                <TextView
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/duration"
                    />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:background="@drawable/product_gradient_rounded_corner"
            android:orientation="horizontal"
            android:clipToOutline="true"
            android:layout_marginStart="10dp"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:layout_gravity="bottom"
                android:src="@drawable/im_calories"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:id="@+id/tvCalories"
                    android:fontFamily="@font/manrope_medium"
                    />
                <TextView
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/calories"
                    />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/product_gradient_rounded_corner"
            android:clipToOutline="true"
            android:orientation="horizontal"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="43dp"
                android:layout_height="43dp"
                android:layout_gravity="bottom"
                android:scaleType="centerCrop"
                android:src="@drawable/im_excercise"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"

                android:orientation="vertical">
                <TextView
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="20sp"
                    android:id="@+id/tvExercises"
                    android:fontFamily="@font/manrope_medium"
                    />
                <TextView
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/exercises"
                    />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:layout_width="match_parent"
        android:id="@+id/tv_complete"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginBottom="15dp"
        android:background="@drawable/white_rectangle"
        android:gravity="center"
        android:fontFamily="@font/manrope_medium"
        android:paddingVertical="15dp"
        android:textFontWeight="700"
        android:layout_alignParentBottom="true"
        android:textAllCaps="true"
        android:text="@string/complete"
        android:textColor="@color/buttontextcolor"
        android:textSize="16sp" />
</RelativeLayout>