<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".WorkoutLibrary.StreakActivity"
    android:fitsSystemWindows="true"
    android:background="@color/buttontextcolor"
    >

    <androidx.core.widget.NestedScrollView
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/tv_complete"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_width="match_parent"
        android:layout_height="0dp">
        <LinearLayout
            android:id="@+id/topView"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <RelativeLayout

                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <View
                        android:background="@drawable/ring"
                        android:layout_centerInParent="true"
                        android:layout_width="280dp"
                        android:layout_height="280dp"/>
                    <ImageView
                        android:layout_centerInParent="true"
                        android:src="@drawable/streak_badge"
                        android:layout_width="250dp"
                        android:layout_height="250dp"/>
                    <TextView
                        android:layout_marginTop="280dp"
                        android:layout_centerHorizontal="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/headingcolor"
                        android:textSize="100sp"
                        android:gravity="center"
                        android:padding="10dp"
                        android:background="@color/buttontextcolor"
                        android:fontFamily="@font/clash_display_semibold"
                        android:id="@+id/totalStreakDays"
                        />
                </RelativeLayout>
                <ImageView
                    android:layout_marginTop="-25dp"
                    android:layout_width="150dp"
                    android:adjustViewBounds="true"
                    android:layout_height="wrap_content"
                    android:src="@drawable/podium"/>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:gravity="center"
                android:textStyle="bold"
                android:padding="10dp"
                android:fontFamily="@font/clashdisplay_medium"
                android:text="Week Streak"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/subheadingcolor"
                android:textSize="14sp"
                android:gravity="center"
                android:textStyle="bold"
                android:id="@+id/tvmsg"
                android:fontFamily="@font/manrope_medium"
                android:text="You are doing really great"
                />
            <androidx.cardview.widget.CardView
                android:id="@+id/streakCard"
                app:cardCornerRadius="10dp"
                android:layout_marginTop="30dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/tabbackground"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_marginTop="15dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_medium"
                        android:text="@string/day_streak"
                        />

                    <LinearLayout
                        android:gravity="center"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="30dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/schedule_drawable">
                        <androidx.recyclerview.widget.RecyclerView
                            android:layout_marginTop="10dp"
                            android:id="@+id/streakRecyclerView"
                            android:layout_width="match_parent"

                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
                        <View
                            android:layout_marginVertical="10dp"
                            android:layout_marginHorizontal="20dp"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:background="@color/progress_track_color"/>
                        <TextView
                            android:layout_marginHorizontal="5dp"
                            android:layout_marginBottom="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/subheadingcolor"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:fontFamily="@font/manrope_medium"
                            android:text="Workout each day to stay fit and maintain your streak"
                            />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <TextView
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_width="match_parent"
        android:id="@+id/tv_complete"

        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="15dp"

        android:background="@drawable/white_rectangle"
        android:gravity="center"
        android:fontFamily="@font/manrope_medium"
        android:paddingVertical="20dp"
        android:textFontWeight="700"
        android:layout_alignParentBottom="true"
        android:textAllCaps="true"
        android:text="@string/proceed"
        android:textColor="@color/buttontextcolor"
        android:textSize="16sp" />
</androidx.constraintlayout.widget.ConstraintLayout>