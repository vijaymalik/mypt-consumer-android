<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_width="300dp"
        android:background="@drawable/bg_card_gradient_black_without_border"
        android:orientation="vertical"
        android:layout_marginEnd="10dp"
        android:layout_marginVertical="10dp"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="wrap_content"
            android:gravity="center_vertical"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:src="@drawable/star" />
            <RatingBar
                android:id="@+id/rBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:stepSize="0.5"
                style="?android:attr/ratingBarStyleSmall"
                android:progressTint="#FFC606"
                android:rating="3"
                android:numStars="5"/>

            <View
                android:layout_marginHorizontal="10dp"
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:background="@drawable/dot"/>
            <TextView
                android:text="1 Week Ago"
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/white"
                android:textSize="12sp"/>

        </LinearLayout>
        <TextView
            android:text="One of the best Gym in Dubai and Amazing atmosphere for athletes and gym lover."
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="15dp"
            android:maxLines="4"
            android:id="@+id/tvDetail"
            android:minLines="4"
            android:ellipsize="end"
            android:fontFamily="@font/clash_display_medium"
            android:textColor="@color/subheadingcolor"
            android:textSize="20sp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">
            <androidx.cardview.widget.CardView
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="20dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitXY"
                    android:id="@+id/im"
                    android:src="@drawable/gym"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:text="Kabir Khan"
                android:layout_width="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:id="@+id/tvname"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/white"
                android:textSize="14sp"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>