<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/onboarding_backgrd_2"
    android:fitsSystemWindows="true"
    tools:context=".onBoarding.PersonalizedActivity2">

    <!-- <ImageView
         android:id="@+id/im"
         android:layout_width="match_parent"
         android:layout_height="280dp"
         android:adjustViewBounds="true"
         android:scaleType="centerCrop"
         android:src="@drawable/chest_press_dark_blur" />
 -->
    <RelativeLayout
        android:id="@+id/personaliseLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:paddingBottom="16dp">

        <RelativeLayout
            android:id="@+id/relative"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp">

            <ImageView
                android:id="@+id/back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginTop="4dp"
                android:scaleType="fitXY"
                android:src="@drawable/ic_back_arrow_new" />

            <LinearLayout
                android:id="@+id/layoutDots"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dots_height"
                android:layout_alignParentTop="true"
                android:layout_centerInParent="true"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="@dimen/dots_margin_bottom"
                android:orientation="horizontal"
                android:visibility="gone">

            </LinearLayout>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/p_Bar"
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:indeterminate="false"
                android:max="100"
                android:progress="20"
                android:progressTint="@color/progress_clr_1"
                android:visibility="visible"
                app:indicatorColor="@color/progress_color"
                app:trackColor="@color/progress_color_bg"
                app:trackCornerRadius="10dp" />

            <TextView
                android:id="@+id/skip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:fontFamily="@font/funnel_sans_medium"
                android:lineSpacingExtra="2sp"
                android:text="@string/skip"
                android:textAllCaps="true"
                android:textColor="@color/text_color_neutral_200"
                android:textSize="14sp"
                android:visibility="visible" />
        </RelativeLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/view_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/flBtn"
            android:layout_below="@+id/relative" />

        <FrameLayout
            android:id="@+id/flBtn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_alignParentBottom="true"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_shape_btn_disabled">

            <TextView
                android:id="@+id/tvcontinue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:drawablePadding="8dp"
                android:drawableTint="@color/text_color_neutral_200"
                android:fontFamily="@font/funnel_sans_medium"
                android:gravity="center"
                android:lineSpacingExtra="2sp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="15dp"
                android:paddingTop="10dp"
                android:paddingBottom="8dp"
                android:text="@string/label_lets_get_started"
                android:textAllCaps="true"
                android:textColor="@color/text_color_neutral_200"
                android:textSize="14sp" />
        </FrameLayout>
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/almostDoneLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical">

            <pl.droidsonroids.gif.GifImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal"
                android:src="@drawable/cosmos" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginVertical="20dp"
                android:layout_marginRight="10dp"
                android:fontFamily="@font/clash_display_medium"
                android:gravity="center"
                android:text="@string/almost_done"
                android:textColor="@color/headingcolor"
                android:textSize="24sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginRight="10dp"
                android:fontFamily="@font/manrope_medium"
                android:gravity="center"
                android:text="@string/fine_tune"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp" />


        </LinearLayout>


    </RelativeLayout>

</RelativeLayout>