<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:layout_width="match_parent"
        android:id="@+id/relative"
        android:layout_marginBottom="10dp"
        android:layout_marginHorizontal="10dp"
        android:background="@drawable/excercise_gradient"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:layout_width="246dp"
            android:src="@drawable/gymgirl"
            android:layout_alignParentEnd="true"
            android:scaleType="centerCrop"
            android:id="@+id/im"
            android:layout_alignParentTop="true"
            android:layout_height="190dp"/>
        <LinearLayout
            android:id="@+id/ll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="10dp"
                android:layout_marginTop="20dp"
                >
                <TextView
                    android:text="Rope"
                    android:background="@drawable/booking_choicelayout"
                    android:paddingVertical="5dp"
                    android:paddingHorizontal="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tv"
                    android:layout_alignParentStart="true"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:textColor="@color/white"
                    android:textSize="12sp"/>
                <ImageView
                    android:id="@+id/verticalDots"
                    android:layout_alignParentEnd="true"
                    android:layout_width="50dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/vertical_dots"/>
            </RelativeLayout>
            <TextView
                android:text="Rope Aerobics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvexercise_name"
                android:layout_marginTop="15dp"
                android:layout_marginHorizontal="20dp"
                android:fontFamily="@font/clash_display_semibold"
                android:textColor="@color/white"
                android:textSize="20sp"/>
            <TextView
                android:text="Shinomiya Kaguya"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:visibility="gone"
                android:layout_marginTop="15dp"
                android:layout_marginHorizontal="20dp"
                android:fontFamily="@font/clash_display_medium"
                android:textColor="@color/smallTextcolor"
                android:textSize="14sp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="15dp"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/imdumbel"/>
                <TextView
                    android:text="12"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:id="@+id/tvreps"
                    android:layout_marginLeft="5dp"
                    android:fontFamily="@font/manrope_regular_400"
                    android:textColor="@color/headingcolor"
                    android:textSize="14sp"/>
                <TextView
                    android:text="Reps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:fontFamily="@font/manrope_regular_400"
                    android:textColor="@color/headingcolor"
                    android:textSize="14sp"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/solid_fire"/>
                <TextView
                    android:text="251"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvcalorie"
                    android:layout_marginLeft="5dp"
                    android:fontFamily="@font/manrope_bold"
                    android:textColor="@color/headingcolor"
                    android:textSize="14sp"/>
                <TextView
                    android:text="Kcal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dp"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:textColor="@color/headingcolor"
                    android:textSize="14sp"/>
            </LinearLayout>
        </LinearLayout>

    </RelativeLayout>



</RelativeLayout>