<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/buttontextcolor"
    android:fitsSystemWindows="true"
    tools:context=".activities.ReviewPackageActivity">
    <LinearLayout
        android:id="@+id/headerLayout"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back_1"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/review_package"
            />


    </LinearLayout>
    <View
        android:layout_marginBottom="20dp"
        android:id="@+id/view"
        android:layout_below="@id/headerLayout"
        android:background="@color/tabbackground"
        android:layout_width="match_parent"
        android:layout_height="2dp"/>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:id="@+id/nested"
        android:layout_above="@id/linearpay"
        android:layout_below="@id/view">
        <LinearLayout
            android:layout_marginHorizontal="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/review_rectangle"
                android:orientation="horizontal">
                <androidx.cardview.widget.CardView
                    app:cardCornerRadius="12dp"
                    android:layout_width="100dp"
                    android:layout_height="100dp">
                    <ImageView
                        android:scaleType="centerCrop"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:id="@+id/imTrainer"
                        android:src="@drawable/dummy_trainer"/>
                </androidx.cardview.widget.CardView>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="15dp"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/headingcolor"
                        android:textSize="14dp"
                        android:textFontWeight="700"
                        android:textStyle="bold"
                        android:id="@+id/tvTrainer_name"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Christene De Koning"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/recycler"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:orientation="horizontal"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:id="@+id/im_star"
                            android:src="@drawable/star"/>
                        <TextView
                            android:text="4"
                            android:id="@+id/avgRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                        <View
                            android:layout_marginHorizontal="5dp"
                            android:layout_width="3dp"
                            android:layout_height="3dp"
                            android:background="@drawable/dot"/>
                        <TextView
                            android:text="12k ratings"
                            android:id="@+id/totalRatings"
                            android:layout_marginEnd="5dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/smallTextcolor"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
                <ImageView
                    android:layout_marginTop="15dp"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:id="@+id/imEditTrainer"
                    android:src="@drawable/edir"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/linearEdit"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/linearPreference"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_marginHorizontal="10dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:background="@drawable/review_rectangle"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginEnd="5dp"
                            android:layout_weight="1"
                            android:fontFamily="@font/manrope_regular_400"
                            android:text="@string/training_preference"
                            android:textColor="@color/smallTextcolor"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:src="@drawable/edir" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvTrainingPrefernce"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="@string/one_on_one"
                        android:textColor="@color/white"
                        android:textSize="18dp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:id="@+id/linearslot"
                    android:layout_marginEnd="10dp"
                    android:layout_marginStart="5dp"
                    android:padding="10dp"
                    android:gravity="center_vertical"
                    android:background="@drawable/review_rectangle"
                    android:layout_height="110dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:text="@string/booking_slot"
                            android:layout_marginEnd="5dp"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_regular_400"
                            android:textColor="@color/smallTextcolor"
                            android:textSize="14sp"/>
                        <ImageView
                            android:layout_width="36dp"
                            android:layout_gravity="center"
                            android:layout_height="36dp"
                            android:src="@drawable/edir"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:background="@drawable/night_rectangle"
                        android:layout_height="wrap_content"
                        android:textColor="@color/headingcolor"
                        android:textSize="14dp"
                        android:id="@+id/tvTime"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="10dp"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_medium"
                        android:text="10:00-11:00"
                        />
                </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="10dp"
                android:paddingHorizontal="15dp"
                android:paddingVertical="20dp"
                android:background="@drawable/review_rectangle"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <androidx.cardview.widget.CardView
                        app:cardCornerRadius="15dp"
                        app:cardBackgroundColor="#3B3B3B"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/txt_color_db"
                            android:textSize="14dp"
                            android:id="@+id/addressType"
                            android:paddingHorizontal="15dp"
                            android:paddingVertical="5dp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text=""
                            />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_marginTop="5dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:layout_marginLeft="5dp"
                        android:id="@+id/address"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:text="Mobile:"
                            android:layout_marginTop="5dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:layout_marginLeft="5dp"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/smallTextcolor"
                            android:textSize="14sp"/>
                        <TextView
                            android:text=""
                            android:layout_marginTop="5dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:layout_marginLeft="5dp"
                            android:id="@+id/mobile"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/headingcolor"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>
                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:id="@+id/editAddress"
                    android:src="@drawable/edir"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/membersLayout"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="10dp"
                android:paddingHorizontal="15dp"
                android:paddingVertical="20dp"
                android:background="@drawable/review_rectangle"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:text="Members List"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:textColor="@color/white"
                            android:textSize="16dp"/>
                        <ImageView
                            android:id="@+id/editMembers"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/edir"/>
                    </LinearLayout>
                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:orientation="vertical"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:id="@+id/membersListRecyclerView" />
                </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="10dp"
                android:paddingHorizontal="15dp"
                android:id="@+id/linear"
                android:visibility="gone"
                android:paddingVertical="20dp"
                android:background="@drawable/review_rectangle"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/linearCoupon"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/discount"/>
                    <TextView
                        android:text="@string/view_coupons_amp_offers"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:layout_marginLeft="10dp"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/white"
                        android:textSize="16dp"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/arrow_right"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/linearShowCoupon"
                    android:background="@drawable/offer_rectangle"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginTop="15dp"
                    android:paddingVertical="5dp"
                    android:orientation="horizontal">
                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        >
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="15dp"
                            android:paddingVertical="5dp"
                            android:layout_margin="5dp"
                            android:textStyle="bold"
                            android:textSize="16dp"
                            android:fontFamily="@font/manrope_medium"
                            android:background="@drawable/dotted_rectangle"
                            android:textColor="@color/subheadingcolor"
                            android:text="FIRST200"/>
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="20dp"

                            android:src="@drawable/scissor"/>
                    </RelativeLayout>

                    <TextView
                        android:text="Save AED 100"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:layout_marginLeft="10dp"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/white"
                        android:textSize="14dp"/>
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/delete"/>
                </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"
                android:paddingHorizontal="15dp"
                android:background="@drawable/review_rectangle"
                android:paddingVertical="15dp"
                android:orientation="vertical">
                <TextView
                    android:text="@string/package_details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="16dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:orientation="horizontal">
                    <TextView
                        android:text="Package"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"

                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14dp"/>
                    <TextView
                        android:text="@string/package_details"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:id="@+id/tvPackageDetail"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/start_date"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14dp"/>
                    <TextView
                        android:text="@string/package_details"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:id="@+id/tvStartDate"
                        android:gravity="end"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/end_date"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14dp"/>
                    <TextView
                        android:text="@string/package_details"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:id="@+id/tvEndDate"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:id="@+id/linear_Duration"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/total_duration"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14dp"/>
                    <TextView
                        android:text="@string/package_details"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:id="@+id/tvTotalDuration"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:id="@+id/linearSession"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/total_sessions"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14dp"/>
                    <TextView
                        android:text="@string/package_details"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:id="@+id/tvTotalSession"
                        android:gravity="end"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:id="@+id/linearpay"
        android:background="@color/tabbackground"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical"
        android:layout_alignParentBottom="true"
        android:paddingHorizontal="20dp"
        >
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginEnd="15dp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:orientation="horizontal"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:id="@+id/tvPrice"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    android:text=""/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:layout_marginTop="3dp"
                    android:layout_gravity="center"
                    android:layout_marginLeft="5dp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_regular_400"
                    android:text="AED"/>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/smallTextcolor"
                android:fontFamily="@font/manrope_semi_bold"
                android:text="@string/view_breakdown"/>
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/make_payment"
            android:background="@drawable/white_rectangle"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:layout_gravity="center_vertical"
            android:gravity="center"
            android:paddingVertical="18dp"
            android:paddingHorizontal="25dp"
            android:id="@+id/tvPayment"
            android:textAllCaps="true"
            android:fontFamily="@font/manrope_bold"
            />
    </LinearLayout>
</RelativeLayout>