<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/buttontextcolor"
    android:fitsSystemWindows="true"
    tools:context=".WorkoutLibrary.CompletedSessionSummaryActivity">
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/tv_complete"
        android:id="@+id/nested"
        android:layout_marginBottom="10dp"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:descendantFocusability="blocksDescendants"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/linearHeader"
                android:layout_alignParentTop="true"
                android:orientation="vertical">
                <LinearLayout
                    android:id="@+id/headerLayout"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:id="@+id/back_1"
                        android:layout_marginHorizontal="10dp"
                        android:layout_marginVertical="20dp"
                        android:src="@drawable/backarrow"
                        />
                    <TextView
                        android:layout_marginEnd="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/headingcolor"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_medium"
                        android:text="@string/session_summary"
                        />


                </LinearLayout>
                <View
                    android:background="@color/tabbackground"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"/>


            </LinearLayout>
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="32sp"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:textStyle="bold"
                android:fontFamily="@font/clash_display_medium"
                android:text="@string/session_completed"
                />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <co.com.mypt.model.SemiCircleProgressView
                    android:id="@+id/semiProgress"
                    android:layout_width="match_parent"
                    android:layout_marginHorizontal="20dp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="20dp"
                    android:layout_height="330dp"
                    />
                <LinearLayout
                    android:layout_marginTop="110dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/booked"
                        android:textSize="56sp"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:id="@+id/tvPercentage"
                        android:fontFamily="@font/clash_display_medium"
                        android:text=""/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="14sp"

                        android:gravity="center"
                        android:textStyle="bold"
                        android:layout_centerInParent="true"
                        android:fontFamily="@font/manrope_medium"
                        android:text="@string/session_target_achieved"/>
                </LinearLayout>

            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:layout_marginTop="-80dp"
                android:layout_marginHorizontal="10dp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/my_score"
                />
            <!--<com.github.mikephil.charting.charts.BarChart
                android:id="@+id/chart1"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                />-->
            <LinearLayout
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="300dp">
                <RelativeLayout
                    android:layout_marginHorizontal="20dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent">
                    <ProgressBar
                        android:id="@+id/caloriesBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:indeterminate="false"
                        android:layout_height="match_parent"
                        android:progressDrawable="@drawable/vertical_bar_1"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_centerHorizontal="true"
                        android:layout_alignParentBottom="true"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:layout_marginHorizontal="10dp">
                        <TextView
                            android:id="@+id/caloriesBarText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="0"/>
                        <TextView
                            android:layout_marginStart="5dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="Kcal"/>
                    </LinearLayout>
                </RelativeLayout>
                <RelativeLayout
                    android:layout_marginEnd="20dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent">
                    <ProgressBar
                        android:id="@+id/workoutDurationBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:indeterminate="false"
                        android:layout_height="match_parent"
                        android:progressDrawable="@drawable/vertical_bar_2"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_centerHorizontal="true"
                        android:layout_alignParentBottom="true"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        android:layout_marginHorizontal="10dp">
                        <TextView
                            android:id="@+id/workoutDurationBarText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="0"/>
                        <TextView
                            android:layout_marginStart="5dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/kcal"/>
                    </LinearLayout>
                </RelativeLayout>
                <RelativeLayout
                    android:layout_marginEnd="20dp"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="match_parent">
                    <ProgressBar
                        android:id="@+id/heartRateBar"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:indeterminate="false"
                        android:layout_height="match_parent"
                        android:progressDrawable="@drawable/vertical_bar_3"/>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_centerHorizontal="true"
                        android:layout_alignParentBottom="true"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp">
                        <TextView
                            android:id="@+id/heartRateBarText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="0"/>
                        <TextView
                            android:layout_marginStart="5dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/kcal"/>
                    </LinearLayout>
                </RelativeLayout>
            </LinearLayout>
            <TextView
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:layout_marginHorizontal="10dp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/workout_summary"
                />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_workoutlist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                android:orientation="vertical"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <TextView
        android:layout_width="match_parent"
        android:id="@+id/tv_complete"

        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginBottom="15dp"

        android:background="@drawable/white_rectangle"
        android:gravity="center"
        android:fontFamily="@font/manrope_medium"
        android:paddingVertical="20dp"
        android:textFontWeight="700"
        android:layout_alignParentBottom="true"
        android:textAllCaps="true"
        android:text="@string/cont_inue"
        android:textColor="@color/buttontextcolor"
        android:textSize="16sp" />
</RelativeLayout>