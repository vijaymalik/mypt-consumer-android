<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/buttontextcolor"
    tools:context=".activities.GymDetailActivity">
    <ImageView
        android:layout_width="match_parent"
        android:id="@+id/gymTempImage"
        android:visibility="invisible"
        android:layout_height="200dp"/>
    <androidx.core.widget.NestedScrollView
        android:scrollbars="none"
        android:layout_above="@+id/bookSlot"
        android:layout_alignParentTop="true"
        android:id="@+id/scrollView"
        android:layout_marginBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:layout_width="match_parent"
                android:id="@+id/relative"
                android:layout_height="358dp">
                <androidx.viewpager.widget.ViewPager
                    android:id="@+id/idViewPager"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_centerInParent="true"
                    android:layout_gravity="center"
                    android:layout_marginBottom="10dp"
                    android:layout_marginHorizontal="5dp" />
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bottom_navigation_gradient">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="15dp"
                        android:layout_marginTop="10dp"
                        android:layout_gravity="bottom"
                        android:layout_marginBottom="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/userName"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/clashdisplay_medium"
                            android:text="MyPT Studio Dubai"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold" />
                        <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
                            android:id="@+id/dots_indicator"
                            android:layout_width="0dp"
                            android:layout_weight="0.5"
                            android:layout_height="wrap_content"
                            app:dotsColor="@color/progress_track_color_1"
                            app:dotsCornerRadius="8dp"
                            app:dotsSize="5dp"
                            app:dotsSpacing="4dp"
                            app:dotsWidthFactor="5"
                            app:selectedDotColor="@color/white"
                            app:progressMode="true"
                            />

                    </LinearLayout>
                </FrameLayout>
                <RelativeLayout
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:id="@+id/back"
                        android:layout_marginHorizontal="15dp"
                        android:layout_marginTop="60dp"
                        android:layout_marginBottom="20dp"
                        android:src="@drawable/backarrow"
                        />

                    <androidx.cardview.widget.CardView
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="10dp"
                        app:cardBackgroundColor="@color/headingcolor"
                        app:cardCornerRadius="8dp"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <androidx.cardview.widget.CardView
                            app:cardBackgroundColor="@color/buttontextcolor"
                            android:layout_margin="1dp"
                            android:layout_gravity="center"
                            app:cardCornerRadius="8dp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:paddingHorizontal="15dp"
                                android:paddingVertical="8dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/headingcolor"
                                android:textSize="14sp"
                                android:id="@+id/follow_1"
                                android:fontFamily="@font/manrope_medium"
                                android:text="@string/follow"
                                />
                        </androidx.cardview.widget.CardView>
                    </androidx.cardview.widget.CardView>
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:id="@+id/imShare1"
                        android:layout_alignParentEnd="true"
                        android:layout_marginHorizontal="15dp"
                        android:layout_marginTop="60dp"
                        android:layout_marginBottom="20dp"
                        android:src="@drawable/rectangle_share"
                        />
                </RelativeLayout>

            </RelativeLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_marginHorizontal="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/location"/>
                <TextView
                    android:text="2.5km"
                    android:id="@+id/distance"
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="12sp"/>
                    <View
                        android:layout_marginEnd="5dp"
                        android:layout_width="3dp"
                        android:layout_height="3dp"
                        android:background="@drawable/dot"/>
                <TextView
                    android:text="Near Dubai Mall"
                    android:id="@+id/place"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="12sp"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/star"/>
                <TextView
                    android:text="4"
                    android:id="@+id/avgRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="12sp"/>
                <View
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@drawable/dot"/>
                <TextView
                    android:text="12k ratings"
                    android:id="@+id/totalRatings"
                    android:layout_marginEnd="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="12sp"/>
            </LinearLayout>
            <HorizontalScrollView
                android:layout_marginTop="25dp"
                android:layout_marginHorizontal="15dp"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:paddingHorizontal="10dp"
                        android:background="@drawable/category_border_bg"
                        android:id="@+id/aboutMe"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:src="@drawable/dumbell_fill"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>
                        <TextView
                            android:paddingVertical="8dp"
                            android:layout_marginHorizontal="5dp"
                            android:text="@string/about_me"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_marginStart="10dp"
                        android:paddingHorizontal="10dp"
                        android:id="@+id/linear_gymfeature"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:src="@drawable/review"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>
                        <TextView
                            android:paddingVertical="8dp"
                            android:layout_marginHorizontal="5dp"
                            android:text="@string/gym_features"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_marginStart="10dp"
                        android:paddingHorizontal="10dp"
                        android:id="@+id/Equipment"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:src="@drawable/story"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>
                        <TextView
                            android:paddingVertical="8dp"
                            android:layout_marginHorizontal="5dp"
                            android:text="@string/equipment"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <LinearLayout

                        android:layout_marginStart="10dp"
                        android:paddingHorizontal="10dp"
                        android:id="@+id/mediaGallery"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:src="@drawable/gallery"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>
                        <TextView
                            android:paddingVertical="8dp"
                            android:layout_marginHorizontal="5dp"
                            android:text="@string/media_gallery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/located_right_opposite_the_marina_metro_this_gym_is_perfect_for_medium_to_heavy_workouts_with_a_read_more"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/aboutTrainerText"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/subheadingcolor"
                android:textSize="14sp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:id="@+id/linearWhatthisGym"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="15dp"
                    android:text="@string/what_this_gym_offers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_marginStart="9dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/gymOfferRecyclerView"
                    app:spanCount="4"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    android:orientation="vertical"
                    />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/linearEquipment"
                android:orientation="vertical"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_marginTop="20dp"
                    android:layout_marginHorizontal="15dp"
                    android:text="@string/equipment_inside_the_gym"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_marginStart="9dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/equipmentRecyclerView"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:orientation="vertical"
                    />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:id="@+id/tvEquipment"
                android:visibility="gone"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginVertical="20dp"
                android:background="@drawable/white_rectangle_package"
                android:gravity="center"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="15dp"
                android:textFontWeight="700"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:text="Show all 32 equipments "
                android:textColor="@color/headingcolor"
                android:textSize="16sp" />
            <TextView
                android:layout_marginTop="20dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/gym_timings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"/>
            <TextView
                android:layout_width="match_parent"
                android:textSize="14sp"
                android:id="@+id/tv"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="15dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/subheadingcolor"
                android:text="Morning 6AM - 13:00 PM"
                />
            <TextView
                android:layout_width="match_parent"
                android:textSize="14sp"
                android:visibility="gone"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="15dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/subheadingcolor"
                android:text="Evening 16 PM  - 23:00 PM"
                />
            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/linearGallery"
                android:orientation="vertical"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_marginTop="25dp"
                    android:layout_marginHorizontal="15dp"
                    android:text="@string/media_gallery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:orientation="horizontal"
                    android:layout_marginStart="9dp"
                    android:descendantFocusability="blocksDescendants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/galleryRecyclerView"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    />
            </LinearLayout>


            <TextView
                android:layout_marginTop="25dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/location_of_the_gym"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:textSize="14sp"
                android:id="@+id/tvlocation"
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="10dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/subheadingcolor"
                android:text="Barsha Heights - Dubai - UAE"
                />
            <androidx.cardview.widget.CardView
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:id="@+id/card"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                android:layout_height="200dp">
                <fragment
                    android:id="@+id/map1"

                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    />
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/star"
                    app:tint="#FFC606" />
                <TextView
                    android:text="4"
                    android:id="@+id/avgRating1"
                    android:layout_width="wrap_content"
                    android:layout_marginStart="3dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="12sp"/>
                <View
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@drawable/dot"/>
                <TextView
                    android:text="12k ratings"
                    android:id="@+id/totalRatings1"
                    android:layout_marginEnd="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="12sp"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/reviewRecycle"
                android:layout_marginLeft="15dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:orientation="horizontal"/>
            <TextView
                android:layout_width="match_parent"
                android:id="@+id/tvReview"
                android:visibility="gone"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="30dp"
                android:background="@drawable/white_rectangle_package"
                android:gravity="center"
                android:fontFamily="@font/manrope_medium"
                android:paddingVertical="15dp"
                android:textFontWeight="700"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:text="Show all 32 Reviews"
                android:textColor="@color/headingcolor"
                android:textSize="16sp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <LinearLayout
        android:background="@color/buttontextcolor"
        android:id="@+id/headerLayout"
        android:gravity="center_vertical"
        android:paddingTop="20dp"
       android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back_1"
            android:layout_marginHorizontal="15dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="14sp"
            android:textStyle="bold"
            android:id="@+id/trainerName_1"
            android:fontFamily="@font/clashdisplay_medium"
            android:text="MyPT Studio Dubai"
            />

        <androidx.cardview.widget.CardView
            android:layout_marginEnd="10dp"
            app:cardBackgroundColor="@color/headingcolor"
            app:cardCornerRadius="8dp"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <androidx.cardview.widget.CardView
                app:cardBackgroundColor="@color/buttontextcolor"
                android:layout_margin="1dp"
                android:layout_gravity="center"
                app:cardCornerRadius="8dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/headingcolor"
                    android:textSize="14sp"
                    android:id="@+id/follow"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/follow"
                    />
            </androidx.cardview.widget.CardView>
        </androidx.cardview.widget.CardView>
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/imShare"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginHorizontal="15dp"

            android:layout_marginVertical="20dp"
            android:src="@drawable/rectangle_share"
            />
    </LinearLayout>
    <TextView
        android:layout_width="match_parent"
        android:id="@+id/bookSlot"
        android:visibility="gone"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/white_rectangle"
        android:gravity="center"
        android:fontFamily="@font/manrope_medium"
        android:paddingVertical="15dp"
        android:textFontWeight="700"
        android:layout_alignParentBottom="true"
        android:text="@string/book_a_slot"
        android:textColor="@color/buttontextcolor"
        android:textSize="16sp" />
</RelativeLayout>