<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".ActiveSession.ActiveSessionDetails">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_marginTop="20dp"
        android:id="@+id/linear"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:id="@+id/back"
            android:layout_marginLeft="15dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginHorizontal="15dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="18sp"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/active_session"
            />
        <TextView
            android:layout_marginHorizontal="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFC606"
            android:textSize="14sp"
            android:id="@+id/tvSos"
            android:paddingVertical="5dp"
            android:paddingHorizontal="20dp"
            android:background="@drawable/sos_rectangle"
            android:fontFamily="@font/manrope_bold"
            android:text="@string/sos"
            />
    </LinearLayout>
    <View
        android:background="@color/tabbackground"
        android:layout_width="match_parent"
        android:id="@+id/view"
        android:layout_marginTop="10dp"
        android:layout_below="@id/linear"
        android:layout_height="2dp"/>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_below="@id/view"
        android:id="@+id/nested"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="vertical"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:layout_marginHorizontal="15dp"
                android:fontFamily="@font/manrope_semi_bold"
                android:text="@string/my_trainer"
                />
            <LinearLayout
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_marginHorizontal="15dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <androidx.cardview.widget.CardView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    app:cardCornerRadius="26dp"
                    app:cardBackgroundColor="#1C1F21"> <!-- Outer boundary color -->

                    <androidx.cardview.widget.CardView
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="25dp"
                        app:cardBackgroundColor="#09131D"> <!-- Inner boundary color -->

                        <!-- Content (optional) -->
                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:id="@+id/trainer_im"
                            android:src="@drawable/dummy_trainer" />

                    </androidx.cardview.widget.CardView>
                </androidx.cardview.widget.CardView>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="10dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="16sp"
                        android:maxLines="2"
                        android:id="@+id/tvTrainer_name"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:text="Christene De Koning"/>
                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/recycler"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:orientation="horizontal"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_gravity="end"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#F5F5F5"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:gravity="end"
                            android:id="@+id/tvRating"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:text="4.0"/>
                        <ImageView
                            android:layout_width="10dp"
                            android:layout_marginLeft="5dp"
                            android:layout_gravity="center"
                            android:src="@drawable/star"
                            android:layout_height="13dp"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#F5F5F5"
                        android:textSize="14sp"
                        android:layout_marginTop="5dp"
                        android:gravity="end"
                        android:id="@+id/tvSlotTime"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:text="9AM- 10 AM"/>
                </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"

                android:id="@+id/linearprogress"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="match_parent"
                    android:src="@drawable/im_scale"
                    android:layout_marginTop="20dp"
                    android:adjustViewBounds="true"
                    android:layout_height="wrap_content"/>
                <co.com.mypt.utils.CurvedProgressBar
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:id="@+id/timeCurveProgress"
                    android:layout_marginTop="-30dp"
                    android:layout_marginStart="-30dp"
                    android:layout_marginEnd="-30dp"
                    />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="80sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="-30dp"
                    android:layout_marginHorizontal="15dp"
                    android:fontFamily="@font/clash_display_semibold"
                    android:id="@+id/tvSec"
                    android:text="60"
                    />
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginTop="-20dp"
                    android:layout_marginHorizontal="15dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/mins_remaining"
                    />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="16sp"

                        android:layout_marginTop="-20dp"
                        android:layout_marginHorizontal="15dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="@string/mins_remaining"
                        />

                </LinearLayout>
            </LinearLayout>
            <RelativeLayout
                android:layout_width="match_parent"
                android:visibility="gone"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp"
                    android:layout_marginHorizontal="15dp"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:text="@string/heart_rate"
                    />
                <co.com.mypt.utils.WaveformView
                    android:id="@+id/waveformView"
                    android:layout_marginTop="16dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"/>
            </RelativeLayout>

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/heartRateChart"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="16dp"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/linearGoal"

                android:layout_marginTop="15dp"
                android:orientation="vertical"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"
                    android:layout_marginHorizontal="15dp"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:text="@string/today_s_goals"
                    />
                <LinearLayout
                    android:layout_marginHorizontal="15dp"
                    android:layout_width="match_parent"
                    android:id="@+id/linearHealthOverview"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:id="@+id/linearActivity"
                        android:orientation="vertical"
                        android:clipToOutline="true"
                        android:background="@drawable/health_overview_drawable"
                        android:layout_height="160dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="30sp"
                            android:id="@+id/tvDuration"
                            android:layout_marginTop="15dp"
                            android:layout_marginHorizontal="15dp"
                            android:fontFamily="@font/clash_display_medium"
                            android:text="22"
                            />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:layout_marginHorizontal="15dp"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:text="@string/duration"
                            />
                        <RelativeLayout
                            android:layout_marginHorizontal="2dp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <co.com.mypt.utils.GradientHalfCircleProgressBar
                                android:id="@+id/durationProgress"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginTop="-20dp"
                                android:rotation="-45"
                                android:layout_alignParentEnd="true"
                                />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="-20dp"
                                android:layout_marginTop="10dp"
                                android:rotation="-45"
                                android:src="@drawable/half_ring"
                                app:tint="@color/white" />
                            <ImageView
                                android:layout_alignParentBottom="true"
                                android:layout_alignParentEnd="true"
                                android:layout_width="30dp"
                                android:layout_height="wrap_content"
                                android:adjustViewBounds="true"
                                android:src="@drawable/tilt_hour_glass"
                                />
                        </RelativeLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:clipToOutline="true"
                        android:id="@+id/linearCalorie"
                        android:layout_marginLeft="3dp"

                        android:orientation="vertical"
                        android:background="@drawable/health_overview_drawable"
                        android:layout_height="160dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="30sp"
                            android:id="@+id/tvCalories"
                            android:layout_marginTop="15dp"
                            android:layout_marginHorizontal="15dp"
                            android:fontFamily="@font/clash_display_medium"
                            android:text="225"
                            />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:layout_marginHorizontal="15dp"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:text="@string/calories"
                            />
                        <RelativeLayout
                            android:layout_marginHorizontal="2dp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <co.com.mypt.utils.GradientHalfCircleProgressBar
                                android:id="@+id/caloriesProgress"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginTop="-20dp"
                                android:rotation="-45"
                                android:layout_alignParentEnd="true"
                                />
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginEnd="-20dp"
                                android:layout_marginTop="10dp"
                                android:rotation="-45"
                                android:src="@drawable/half_ring"
                                app:tint="@color/white" />
                            <ImageView
                                android:layout_alignParentBottom="true"
                                android:layout_alignParentEnd="true"
                                android:layout_width="30dp"
                                android:layout_height="wrap_content"
                                android:adjustViewBounds="true"
                                android:src="@drawable/tilt_fire"
                                />

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginTop="10dp"
                                android:layout_marginEnd="-20dp"
                                android:rotation="-45"
                                android:src="@drawable/half_ring"
                                app:tint="@color/white" />
                        </RelativeLayout>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:clipToOutline="true"
                        android:layout_marginLeft="3dp"
                        android:id="@+id/linearExercise"
                        android:orientation="vertical"
                        android:background="@drawable/health_overview_drawable"
                        android:layout_height="160dp">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="30sp"
                            android:id="@+id/tvExercise"
                            android:layout_marginTop="15dp"
                            android:layout_marginHorizontal="15dp"
                            android:fontFamily="@font/clash_display_medium"
                            android:text="225"
                            />
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:layout_marginHorizontal="15dp"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:text="@string/execrise"
                            />
                        <RelativeLayout
                            android:layout_marginHorizontal="2dp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <co.com.mypt.utils.GradientHalfCircleProgressBar
                                android:id="@+id/exerciseProgress"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginTop="-20dp"
                                android:rotation="-45"
                                android:layout_alignParentEnd="true"
                                />

                            <ImageView
                                android:layout_alignParentBottom="true"
                                android:layout_alignParentEnd="true"
                                android:layout_width="30dp"
                                android:layout_height="wrap_content"
                                android:adjustViewBounds="true"
                                android:src="@drawable/tilt_dumbbell"
                                />
                        </RelativeLayout>

                    </LinearLayout>

                </LinearLayout>
                <ImageView
                    android:layout_width="match_parent"
                    android:src="@drawable/im_plan_for_the_day"
                    android:paddingHorizontal="26dp"
                    android:layout_marginTop="30dp"
                    android:layout_height="57dp"/>
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_marginTop="-50dp"
                    android:id="@+id/relativeDetail"
                    android:layout_marginBottom="30dp"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:layout_width="match_parent"
                        android:src="@drawable/im_back"
                        android:id="@+id/im_workout"
                        android:layout_height="274dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:textColor="@color/white"
                        android:textSize="46sp"
                        android:layout_alignParentBottom="true"
                        android:id="@+id/tvBodyPart"
                        android:gravity="bottom|center"
                        android:background="@drawable/bottom_nav_gradient"
                        android:fontFamily="@font/clash_display_semibold"
                        android:text="Back"
                        />
                </RelativeLayout>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="16sp"

                    android:layout_marginHorizontal="15dp"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:text="@string/upcoming_sessions"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="15dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:id="@+id/UpcomingRecycler"
                    />
            </LinearLayout>

            <ImageView
                android:layout_marginVertical="30dp"
                android:layout_marginHorizontal="10dp"
                android:src="@drawable/divider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:layout_gravity="center_horizontal"
                android:textSize="25sp"
                android:gravity="center_vertical"
                android:fontFamily="@font/clash_display_medium"
                android:text="“ Believe you can and\nyou're halfway there ”"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:fontFamily="@font/clash_display_regular"
                android:textColor="@color/edittextbordercolor"
                android:text="-Theodore Roosevelt"
                android:layout_gravity="center_horizontal"
                android:layout_marginVertical="15dp"/>
            <ImageView
                android:layout_marginTop="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:src="@drawable/home_header_image"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</RelativeLayout>