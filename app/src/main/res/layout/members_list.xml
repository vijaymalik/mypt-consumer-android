<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:background="@drawable/offer_rectangle"
    android:layout_marginTop="15dp"
    android:id="@+id/relative"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="10dp"

        android:layout_marginHorizontal="15dp"
        android:orientation="vertical">
        <TextView

            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="14sp"

            android:background="@drawable/session_rectangle"
            android:id="@+id/tvname"
            android:fontFamily="@font/manrope_medium"

            android:text="Ali Khan"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvage"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:background="@drawable/joining_rectangle"
                    android:fontFamily="@font/manrope_medium"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:text="25"
                    android:textColor="@color/white"
                    android:layout_marginEnd="10dp"
                    android:textSize="12sp" />
                <TextView
                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:background="@drawable/joining_rectangle"
                    android:id="@+id/tvgender"
                    android:fontFamily="@font/manrope_medium"
                    android:text="Male"/>
            </LinearLayout>
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:id="@+id/imEdit"
                android:src="@drawable/darkcircle_edit"/>
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:id="@+id/imDelete"
                android:layout_marginLeft="10dp"
                android:src="@drawable/delete_circle"/>

        </LinearLayout>

    </LinearLayout>
</RelativeLayout>