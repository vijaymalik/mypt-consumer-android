<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/buttontextcolor"

    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:id="@+id/linearclose"
        android:layout_marginTop="20dp"
        android:orientation="horizontal">
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="20sp"
            android:layout_gravity="center_vertical"
            android:background="@drawable/grey_light_rectangle"
            android:paddingVertical="10dp"
            android:paddingHorizontal="25dp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="1"
            />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:orientation="horizontal">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_marginEnd="10dp"
                    android:layout_width="match_parent"

                    android:layout_height="wrap_content"
                    android:textColor="@color/headingcolor"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_medium"
                    android:text="Set 1"
                    />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_marginEnd="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_medium"
                        android:text="12 Reps "
                        />
                    <View
                        android:layout_marginHorizontal="5dp"
                        android:layout_width="5dp"
                        android:layout_height="5dp"
                        android:layout_gravity="center"
                        android:layout_marginTop="3dp"
                        android:backgroundTint="@color/smallTextcolor"
                        android:background="@drawable/dot"/>
                    <TextView
                        android:layout_marginHorizontal="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_medium"
                        android:text="20s Rest "
                        />
                </LinearLayout>
            </LinearLayout>



        </LinearLayout>
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:rotation="270"
            android:visibility="gone"
            android:id="@+id/imarrowUp"
            android:src="@drawable/arrow_right"
            app:tint="@color/smallTextcolor" />
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:rotation="90"
            android:id="@+id/imarrowdown"
            android:layout_gravity="center"
            android:src="@drawable/arrow_right"
            app:tint="@color/smallTextcolor" />
    </LinearLayout>
    <View
        android:layout_width="match_parent"
        android:layout_marginTop="20dp"
        android:background="@drawable/editview"
        android:layout_height="1dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:id="@+id/lineardetail"

        android:layout_marginHorizontal="15dp"
        android:orientation="vertical">
        <RelativeLayout
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/minimum_reps"
                />
            <LinearLayout
                android:layout_width="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:id="@+id/imMinusMininmumReps"
                    android:src="@drawable/baseline_horizontal_rule_24"
                    app:tint="@color/white" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:id="@+id/tvMinimum"
                    android:layout_marginHorizontal="30dp"
                    android:fontFamily="@font/manrope_medium"
                    android:text="1"
                    />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:id="@+id/imAddMinimumReps"
                    android:src="@drawable/baseline_add_24"
                    app:tint="@color/white" />
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/maximum_reps"
                />
            <LinearLayout
                android:layout_width="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentEnd="true"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:id="@+id/imMaximumMinus"
                    android:src="@drawable/baseline_horizontal_rule_24"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="30dp"
                    android:fontFamily="@font/manrope_medium"
                    android:id="@+id/tvMax"
                    android:text="1"
                    android:textColor="@color/white"
                    android:textSize="14sp" />
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:id="@+id/imAddMaximumReps"
                    android:src="@drawable/baseline_add_24"
                    app:tint="@color/white" />
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
        android:layout_width="match_parent"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:layout_height="wrap_content">
        <TextView
            android:layout_width="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/rest_time"
            />
        <LinearLayout
            android:layout_width="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:id="@+id/imRestTime"
                android:src="@drawable/baseline_horizontal_rule_24"
                app:tint="@color/white" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:id="@+id/tvRestTime"
                android:layout_marginHorizontal="19.5dp"
                android:fontFamily="@font/manrope_medium"
                android:text="1:00"
                />
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:id="@+id/imRestTimeAdd"
                android:src="@drawable/baseline_add_24"
                app:tint="@color/white" />
        </LinearLayout>
    </RelativeLayout>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:layout_marginVertical="20dp"
            android:textSize="16sp"
            android:gravity="center"
            android:id="@+id/tvApply"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/apply_to_all_sets"
            />
    </LinearLayout>


</LinearLayout>