<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"

    android:layout_height="match_parent"
    tools:context=".onBoarding.personalize.LocationSelectFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/linear"
        android:orientation="vertical">

        <TextView
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="30sp"
            android:gravity="center"
            android:layout_marginHorizontal="10dp"
            android:layout_marginBottom="30dp"
            android:fontFamily="@font/clashdisplay_medium"
            android:text="@string/what_s_your_location" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/edittext_background">
            <ImageView
                android:layout_marginStart="16dp"
                android:id="@+id/searchImg"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_centerVertical="true"
                android:src="@drawable/search"
                app:tint="@color/white" />
            <AutoCompleteTextView
                android:layout_marginEnd="10dp"
                android:layout_toEndOf="@id/searchImg"
                android:layout_toStartOf="@+id/currentLoc"
                android:id="@+id/edaddress"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:cursorVisible="false"
                android:hint="@string/search_for_area_street_name"
                android:inputType="text"
                android:textColorHint="@color/smallTextcolor"
                android:paddingHorizontal="10dp"
                android:layout_centerInParent="true"
                android:fontFamily="@font/manrope_semi_bold"
                android:drawableTint="@color/white"
                android:drawablePadding="10dp"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/currentLoc"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_alignParentEnd="true"
                android:padding="18dp"
                android:layout_centerInParent="true"
                android:src="@drawable/baseline_my_location_24"
                app:tint="@color/white" />
        </RelativeLayout>

    </LinearLayout>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_above="@id/linear1"
        android:layout_below="@id/linear"
        android:layout_height="wrap_content">
        <fragment
            android:id="@+id/map1"

            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            />
        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_centerInParent="true"
            android:src="@drawable/marker"/>
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/linear1"
        android:paddingHorizontal="10dp"
        android:layout_marginHorizontal="15dp"
        android:paddingVertical="15dp"
        android:layout_alignParentBottom="true"

       >
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="5dp"
            android:src="@drawable/locimage"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            android:orientation="vertical">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginStart="10dp"
                android:id="@+id/tvlocation"
                android:fontFamily="@font/manrope_medium"
                android:text="" />
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="12sp"
                android:layout_marginHorizontal="10dp"
                android:textFontWeight="600"
                android:maxLines="1"
                android:id="@+id/stateCountry"
                android:fontFamily="@font/manrope_medium"
                android:text="" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>