<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/buttontextcolor"
    android:fitsSystemWindows="true"
    tools:context=".WorkoutLibrary.ActiveessionWorkoutActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:id="@+id/linearheader"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:id="@+id/back"
                android:layout_marginHorizontal="10dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/backarrow"
                />
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:id="@+id/userName"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/active_session"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/progress_clr"
                android:textSize="14sp"
                android:layout_marginRight="10dp"
                android:paddingVertical="8dp"
                android:paddingHorizontal="25dp"
                android:background="@drawable/sos_rectangle"
                android:fontFamily="@font/manrope_bold"
                android:text="@string/sos"
                />

        </LinearLayout>

        <View
            android:background="@color/tabbackground"
            android:layout_width="match_parent"
            android:layout_height="2dp"/>
        <LinearLayout
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:orientation="horizontal">
           <RelativeLayout
               android:layout_width="52dp"
               android:layout_height="52dp"
               android:layout_marginStart="10dp"
               android:gravity="center">
               <ImageView
                   android:layout_width="52dp"
                   android:layout_height="52dp"
                   android:src="@drawable/pause_circle"
                   />
               <ImageView
                   android:layout_width="24dp"
                   android:layout_height="24dp"
                   android:layout_centerInParent="true"
                   android:src="@drawable/baseline_pause_24"
                   />
           </RelativeLayout>
            <LinearLayout
                android:gravity="bottom"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <RelativeLayout
                    android:layout_marginBottom="-5dp"
                    android:layout_width="match_parent"
                    android:layout_height="30dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginStart="-4dp"
                    >
                    <View
                        android:layerType="software"
                        android:id="@+id/view"
                        android:layout_width="match_parent"
                        android:layout_height="30dp"
                        android:layout_marginStart="-10dp"
                        android:layout_marginEnd="-10dp"
                        android:background="@drawable/background_progressbar" />
                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:max="100"
                        android:layout_marginEnd="10dp"
                        android:indeterminate="false"
                        android:layout_centerInParent="true"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:progressDrawable="@drawable/custom_progressbar"
                        />
                </RelativeLayout>
                <TextView
                    android:layout_marginStart="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#808280"
                    android:textSize="12sp"
                    android:id="@+id/tvProgressPercentage"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:text="50 percent complete"
                    />
            </LinearLayout>
        </LinearLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:orientation="horizontal"
                android:id="@+id/recycler_workout"/>
            <ImageView
                android:layout_width="50dp"
                android:layout_height="150dp"
                android:id="@+id/imLeft"
                android:layout_centerVertical="true"
                android:src="@drawable/rightslider"/>
            <ImageView
                android:layout_width="50dp"
                android:layout_height="150dp"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:id="@+id/imRight"
                android:src="@drawable/fixedslider"/>
        </RelativeLayout>



    </LinearLayout>
</RelativeLayout>