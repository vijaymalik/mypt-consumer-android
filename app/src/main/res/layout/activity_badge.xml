<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/buttontextcolor">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/linearHeader"
        android:layout_alignParentTop="true"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/headerLayout"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:id="@+id/back_1"
                android:layout_marginHorizontal="10dp"
                android:layout_marginVertical="20dp"
                android:src="@drawable/backarrow"
                />
            <TextView
                android:layout_marginEnd="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/session_summary"
                />


        </LinearLayout>
        <View
            android:background="@color/tabbackground"
            android:layout_width="match_parent"

            android:layout_height="2dp"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_below="@+id/linearHeader"
        android:layout_width="match_parent"
        android:layout_above="@id/shareAchievement"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="25sp"
                android:gravity="center"
                android:textStyle="bold"
                android:padding="10dp"
                android:fontFamily="@font/clash_display_medium"
                android:text="@string/badge_earned"
                />
            <co.com.mypt.utils.CarouselRecyclerview
                android:layout_marginVertical="20dp"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:id="@+id/carouselRecyclerview"/>
            <TextView
                android:layout_marginTop="-20dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/subheadingcolor"
                android:textSize="14sp"
                android:gravity="center"
                android:textStyle="bold"
                android:id="@+id/date"
                android:fontFamily="@font/manrope_medium"
                android:text="Date"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="20sp"
                android:gravity="center"
                android:id="@+id/badgeEarnedName"
                android:fontFamily="@font/clash_display_semibold"
                android:text="Max Sets"
                />

            <co.com.mypt.utils.CarouselIndicatorView
                android:id="@+id/dots_indicator"
                android:layout_width="wrap_content"
                android:layout_height="10dp"
                android:layout_marginTop="20dp" />
            <androidx.cardview.widget.CardView
                android:id="@+id/streakCard"
                app:cardCornerRadius="10dp"
                android:layout_marginTop="30dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/tabbackground"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_marginTop="15dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_medium"
                        android:text="@string/day_streak"
                        />

                    <LinearLayout
                        android:gravity="center"
                        android:layout_marginTop="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/schedule_drawable">
                        <androidx.recyclerview.widget.RecyclerView
                            android:layout_marginTop="10dp"
                            android:id="@+id/streakRecyclerView"
                            android:layout_width="match_parent"

                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
                        <View
                            android:layout_marginVertical="10dp"
                            android:layout_marginHorizontal="20dp"
                            android:layout_width="match_parent"
                            android:layout_height="2dp"
                            android:background="@color/progress_track_color"/>
                        <TextView
                            android:layout_marginHorizontal="5dp"
                            android:layout_marginBottom="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/subheadingcolor"
                            android:textSize="14sp"
                            android:gravity="center"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:text="Workout each day to stay fit and maintain your streak"
                            />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <TextView
        android:layout_width="match_parent"
        android:id="@+id/shareAchievement"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="15dp"
        android:background="@drawable/white_rectangle"
        android:gravity="center"
        android:fontFamily="@font/manrope_medium"
        android:paddingVertical="20dp"
        android:textFontWeight="700"
        android:layout_alignParentBottom="true"
        android:textAllCaps="true"
        android:text="@string/share_achievement"
        android:textColor="@color/buttontextcolor"
        android:textSize="16sp" />
</RelativeLayout>