<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/buttontextcolor"
    tools:context=".Notification.NotificationAddressFormActivity">
    <LinearLayout
        android:background="@color/buttontextcolor"
        android:id="@+id/headerLayout"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back_1"
            android:layout_marginHorizontal="10dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/add_address"
            />

    </LinearLayout>
    <androidx.core.widget.NestedScrollView
        android:layout_marginBottom="60dp"
        android:layout_below="@id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginHorizontal="15dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_semi_bold"
                android:text="@string/contact_info"
                />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:orientation="horizontal"
                android:layout_gravity="center"
                android:background="@drawable/profile_edittext">
                <ImageView
                    android:layout_width="20dp"
                    android:src="@drawable/info_name"
                    android:layout_marginLeft="12dp"
                    android:layout_gravity="center_vertical"
                    android:layout_height="20dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    app:hintTextColor="@color/smallTextcolor"
                    app:boxStrokeColor="@android:color/transparent"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    android:textColorHint="@color/smallTextcolor"
                    android:background="@android:color/transparent"
                    app:hintTextAppearance="@style/MyFloatingLabelStyle"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textCursorDrawable="@null"
                        android:id="@+id/textName"
                        android:inputType="textPersonName"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrst uvwxyz1234567890"
                        android:fontFamily="@font/manrope_medium"
                        android:hint="@string/full_name"
                        android:textColor="@color/headingcolor"
                        android:background="@android:color/transparent"
                        android:enabled="false"

                        />

                </com.google.android.material.textfield.TextInputLayout>
                <ImageView
                    android:layout_width="20dp"
                    android:src="@drawable/im_edit"
                    android:id="@+id/im_editname"
                    android:layout_marginRight="12dp"
                    android:layout_gravity="center_vertical"
                    android:layout_height="match_parent"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:layout_gravity="center"
                android:background="@drawable/profile_edittext">
                <ImageView
                    android:layout_width="20dp"
                    android:src="@drawable/call"
                    android:layout_marginLeft="12dp"
                    android:layout_gravity="center_vertical"
                    android:layout_height="20dp"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    app:hintTextColor="@color/smallTextcolor"
                    app:boxStrokeColor="@android:color/transparent"
                    app:boxStrokeWidth="0dp"
                    app:boxStrokeWidthFocused="0dp"
                    android:textColorHint="@color/smallTextcolor"
                    android:background="@android:color/transparent"
                    app:hintTextAppearance="@style/MyFloatingLabelStyle"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textCursorDrawable="@null"
                        android:id="@+id/textphone"
                        android:digits="1234567890"
                        android:maxLength="13"
                        android:inputType="number"
                        android:fontFamily="@font/manrope_medium"
                        android:hint="@string/contact_number"
                        android:textColor="@color/headingcolor"
                        android:background="@android:color/transparent"

                        />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/manrope_semi_bold"
                android:text="@string/address_info"
                />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"
                android:background="@drawable/profile_edittext">
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    app:hintTextColor="@color/booked"
                    app:boxStrokeColor="@android:color/transparent"
                    android:paddingVertical="2dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1dp"
                    android:textColorHint="@color/booked"
                    android:background="@android:color/transparent"
                    app:hintTextAppearance="@style/MyFloatingLabelStyle"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textCursorDrawable="@null"
                        android:id="@+id/tvBuildingName"
                        android:imeOptions="actionNext"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrst uvwxyz1234567890"
                        android:inputType="textNoSuggestions|textVisiblePassword"
                        android:importantForAutofill="noExcludeDescendants"
                        android:autofillHints=""
                        android:fontFamily="@font/manrope_medium"
                        android:textColorHint="@color/smallTextcolor"
                        android:hint="@string/building_villa_name_or_number"
                        android:textStyle="bold"
                        android:textColor="@color/headingcolor"
                        android:background="@android:color/transparent"
                        />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"
                android:background="@drawable/profile_edittext">
                <com.google.android.material.textfield.TextInputLayout
                    android:importantForAutofill="no"
                    android:layout_width="match_parent"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    app:hintTextColor="@color/booked"
                    app:boxStrokeColor="@android:color/transparent"
                    android:paddingVertical="2dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1dp"
                    android:textColorHint="@color/booked"
                    android:background="@android:color/transparent"
                    app:hintTextAppearance="@style/MyFloatingLabelStyle"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textCursorDrawable="@null"
                        android:id="@+id/tvStreetName"
                        android:inputType="textNoSuggestions"
                        android:importantForAutofill="noExcludeDescendants"
                        android:autofillHints=""
                        android:imeOptions="actionNext"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrst uvwxyz1234567890"
                        android:fontFamily="@font/manrope_medium"
                        android:textColorHint="@color/smallTextcolor"
                        android:hint="@string/street_name_number"
                        android:textStyle="bold"
                        android:textColor="@color/headingcolor"
                        android:background="@android:color/transparent"

                        />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"
                android:background="@drawable/profile_edittext">
                <com.google.android.material.textfield.TextInputLayout

                    android:layout_width="match_parent"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    app:hintTextColor="@color/booked"
                    app:boxStrokeColor="@android:color/transparent"
                    android:paddingVertical="2dp"
                    app:boxStrokeWidth="1dp"
                    android:importantForAutofill="no"
                    app:boxStrokeWidthFocused="1dp"
                    android:textColorHint="@color/booked"
                    android:background="@android:color/transparent"
                    app:hintTextAppearance="@style/MyFloatingLabelStyle"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textCursorDrawable="@null"
                        android:id="@+id/tvLandmark"
                        android:digits="ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrst uvwxyz1234567890"
                        android:imeOptions="actionNext"
                        android:inputType="textNoSuggestions|textVisiblePassword"
                        android:importantForAutofill="noExcludeDescendants"
                        android:autofillHints=""
                        android:fontFamily="@font/manrope_medium"
                        android:textColorHint="@color/smallTextcolor"
                        android:hint="@string/landmark_optional"
                        android:textStyle="bold"
                        android:textColor="@color/headingcolor"
                        android:background="@android:color/transparent"

                        />

                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>


            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_marginTop="20dp"
                android:layout_height="wrap_content">
                <AutoCompleteTextView
                    android:id="@+id/autoCompleteCity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:padding="14dp"
                    android:layout_alignBottom="@id/stateLinearLayout"
                    android:cursorVisible="false"
                    android:background="@android:color/transparent"
                    android:textColor="@color/tabbackground"
                    android:textColorHint="@color/smallTextcolor"
                    android:fontFamily="@font/manrope_medium" />
                <LinearLayout
                    android:id="@+id/stateLinearLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:background="@drawable/profile_edittext">
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/stateTextInputLayout"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_gravity="center"
                        android:layout_height="wrap_content"
                        app:hintTextColor="@color/booked"
                        app:boxStrokeColor="@android:color/transparent"
                        android:paddingVertical="2dp"
                        app:boxStrokeWidth="1dp"
                        android:importantForAutofill="no"
                        app:boxStrokeWidthFocused="1dp"
                        android:textColorHint="@color/booked"
                        android:background="@android:color/transparent"
                        android:hint="@string/city"
                        app:hintTextAppearance="@style/MyFloatingLabelStyle"
                        >
                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:cursorVisible="false"
                            android:textSize="14sp"
                            android:textCursorDrawable="@null"
                            android:id="@+id/tvCity"
                            android:fontFamily="@font/manrope_medium"
                            android:textColorHint="@color/smallTextcolor"
                            android:textStyle="bold"
                            android:textColor="@color/headingcolor"
                            android:background="@android:color/transparent"
                            android:inputType="textNoSuggestions|textVisiblePassword"
                            android:importantForAutofill="noExcludeDescendants"
                            android:autofillHints=""
                            />
                    </com.google.android.material.textfield.TextInputLayout>
                    <ImageView
                        android:layout_width="wrap_content"
                        android:src="@drawable/baseline_keyboard_arrow_down_24"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginRight="10dp"
                        app:tint="@color/smallTextcolor" />
                </LinearLayout>
            </RelativeLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:background="@drawable/profile_edittext">
                <com.google.android.material.textfield.TextInputLayout

                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_gravity="center"
                    android:layout_height="wrap_content"
                    app:hintTextColor="@color/booked"
                    app:boxStrokeColor="@android:color/transparent"
                    android:paddingVertical="2dp"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="1dp"
                    android:importantForAutofill="no"
                    android:textColorHint="@color/booked"
                    android:background="@android:color/transparent"
                    app:hintTextAppearance="@style/MyFloatingLabelStyle"
                    >

                    <com.google.android.material.textfield.TextInputEditText
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textCursorDrawable="@null"
                        android:id="@+id/tvCountry"
                        android:text="United Arab Emirates"
                        android:focusable="false"
                        android:cursorVisible="false"
                        android:fontFamily="@font/manrope_medium"
                        android:textColorHint="@color/smallTextcolor"
                        android:hint="@string/country"
                        android:textStyle="bold"
                        android:textColor="@color/headingcolor"
                        android:background="@android:color/transparent"
                        android:inputType="textNoSuggestions|textVisiblePassword"
                        android:importantForAutofill="noExcludeDescendants"
                        android:autofillHints=""
                        />

                </com.google.android.material.textfield.TextInputLayout>
                <ImageView
                    android:layout_width="wrap_content"
                    android:src="@drawable/baseline_keyboard_arrow_down_24"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginRight="10dp"
                    android:visibility="gone"
                    app:tint="@color/smallTextcolor" />
            </LinearLayout>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                app:cardCornerRadius="12dp"
                app:cardBackgroundColor="#101113"
                android:layout_marginVertical="20dp"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:orientation="vertical"
                    android:layout_marginHorizontal="15dp"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="10dp"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_medium"
                        android:text="@string/type_of_address"
                        />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <CheckBox
                            android:paddingHorizontal="5dp"
                            android:id="@+id/checkHome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:layout_marginRight="10dp"
                            android:buttonTint="@color/white"
                            style="@style/CustomCheckboxBrand"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/subheadingcolor"
                            android:text="@string/home" />
                        <CheckBox
                            android:paddingHorizontal="5dp"
                            android:id="@+id/checkOffice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:buttonTint="@color/white"
                            style="@style/CustomCheckboxBrand"
                            android:layout_marginRight="10dp"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/subheadingcolor"
                            android:text="@string/office" />
                        <CheckBox
                            android:paddingHorizontal="5dp"
                            android:id="@+id/checkOthers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:buttonTint="@color/white"
                            style="@style/CustomCheckboxBrand"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/subheadingcolor"
                            android:text="@string/others" />


                    </LinearLayout>

                    <CheckBox
                        android:paddingHorizontal="5dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:layout_marginBottom="10dp"
                        android:layout_marginRight="10dp"
                        android:buttonTint="@color/white"
                        style="@style/CustomCheckboxBrand"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/subheadingcolor"
                        android:text="@string/mark_as_default_address" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>


        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


    <LinearLayout
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="15dp"
        android:layout_marginBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/linearSave"
        android:orientation="horizontal">

        <TextView
            android:layout_width="match_parent"
            android:id="@+id/tvDone"
            android:layout_height="wrap_content"
            android:background="@drawable/apply_rectangle"
            android:gravity="center"
            android:fontFamily="@font/manrope_medium"
            android:paddingVertical="15dp"
            android:textFontWeight="700"
            android:textAllCaps="true"
            android:text="@string/save_address"
            android:textStyle="bold"
            android:textColor="@color/buttontextcolor"
            android:textSize="16dp" />
    </LinearLayout>
</RelativeLayout>