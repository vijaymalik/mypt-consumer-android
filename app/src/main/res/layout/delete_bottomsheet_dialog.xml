<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/top_rounded_corners"

    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_marginTop="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="70dp"
            app:cardCornerRadius="3dp"
            android:layout_height="5dp"
            app:cardBackgroundColor="@color/rulersmallline"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:layout_marginTop="30dp"

            android:layout_height="wrap_content">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="10dp"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_semi_bold"
                android:text="@string/sure_you_want_to_close_your_account_and_delete_your_data" />
            <ImageView
                android:layout_width="28dp"
                android:layout_gravity="center"
                android:layout_marginRight="15dp"
                android:src="@drawable/close"
                android:id="@+id/imclose"
                android:layout_height="28dp"
                app:tint="@color/white" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/smallTextcolor"
            android:id="@+id/tvcalorietakemsg"
            android:textSize="14sp"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="15dp"
            android:fontFamily="@font/manrope_semi_bold"

            android:text="This action is permanent and cannot be undone. Your account, profile details, and all related data, including your booking history, goals, and progress will be permanently erased. You’ll no longer be able to access any part of your MyPT experience."
            />

        <TextView
            android:layout_width="match_parent"
            android:id="@+id/tvCancel"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="15dp"
            android:background="@drawable/white_rectangle"
            android:gravity="center"
            android:layout_marginTop="30dp"
            android:fontFamily="@font/manrope_bold"
            android:paddingVertical="15dp"
            android:text="@string/cancel"
            android:textColor="@color/buttontextcolor"
            android:textSize="16sp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:id="@+id/linearDelete"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="30dp"
            android:paddingVertical="15sp"
            android:background="@drawable/logout_drawable"
            android:layout_marginHorizontal="15dp"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="16sp"
                android:layout_marginHorizontal="15dp"
                android:textAllCaps="true"
                android:fontFamily="@font/manrope_bold"
                android:text="@string/delete_my_account"
                />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>