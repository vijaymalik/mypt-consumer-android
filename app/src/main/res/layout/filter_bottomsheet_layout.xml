<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:background="@drawable/top_rounded_corners"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_marginTop="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_width="70dp"
            app:cardCornerRadius="3dp"
            android:layout_height="5dp"
            app:cardBackgroundColor="@color/rulersmallline"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="15dp"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/headingcolor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/filter_workout" />
            <ImageView
                android:layout_width="24dp"
                android:src="@drawable/question_square"
                android:layout_gravity="center"
                android:layout_height="24dp"/>
        </LinearLayout>

        <TextView
            android:layout_marginTop="20dp"
            android:layout_marginStart="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/smallTextcolor"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/filter_by"
            />
        <androidx.cardview.widget.CardView
            android:layout_marginVertical="5dp"
            app:cardCornerRadius="8dp"
            android:layout_marginHorizontal="15dp"
            app:cardBackgroundColor="@color/edittextbordercolor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.cardview.widget.CardView
                android:layout_margin="2dp"
                app:cardBackgroundColor="@color/home_frag_blk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:padding="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:src="@drawable/round_bar_chart_24"
                        android:layout_width="18dp"
                        android:layout_height="18dp"/>
                    <AutoCompleteTextView
                        android:gravity="center_vertical"
                        android:layout_marginStart="10dp"
                        android:textColor="@color/white"
                        android:hint="Select"
                        android:textColorHint="@color/smallTextcolor"
                        android:id="@+id/filterBy"
                        android:drawableEnd="@drawable/baseline_keyboard_arrow_down_24_white"
                        android:background="@android:color/transparent"
                        android:layout_width="0dp"
                        android:textSize="16sp"
                        android:fontFamily="@font/manrope_medium"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </androidx.cardview.widget.CardView>
        <TextView
            android:layout_marginTop="20dp"
            android:layout_marginStart="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/smallTextcolor"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/workout_type"
            />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/workoutTypeRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
        <TextView
            android:layout_marginTop="20dp"
            android:layout_marginStart="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/smallTextcolor"
            android:textSize="16sp"
            android:id="@+id/tvBody"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/body_parts"
            />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/bodyPartsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="5dp"
            android:layout_marginTop="10dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
        <TextView
            android:layout_marginTop="20dp"
            android:layout_marginStart="15dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/smallTextcolor"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:id="@+id/tvWorkout"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/workout_level"
            />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/workoutLevelRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"

            android:layout_marginHorizontal="5dp"
            android:layout_marginTop="10dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="15dp"
            android:layout_height="wrap_content">
            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/workout_duration"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/minutes"
                />

        </LinearLayout>


        <co.com.mypt.model.DoubleRangeSlider
            android:id="@+id/doubleRangeSlider"
            android:layout_width="match_parent"
            android:layout_marginTop="-25dp"
            android:layout_height="90dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:orientation="horizontal"
            android:layout_marginHorizontal="15dp"
            android:layout_height="wrap_content">
            <TextView

                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/calorie_burn"
                />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/manrope_medium"
                android:text="@string/kcal"
                />

        </LinearLayout>

        <co.com.mypt.model.SingleRangeBar
            android:id="@+id/singleRangeSlider"
            android:layout_width="match_parent"
            android:layout_marginTop="-25dp"
            android:layout_marginBottom="20dp"
            android:layout_height="100dp"/>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/tvApplyFilter"
            android:text="Apply Filter"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/white_stroke_rectangle"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:paddingVertical="18dp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginBottom="20dp"
            android:fontFamily="@font/manrope_medium"
            android:textFontWeight="700"/>


    </LinearLayout>

</androidx.core.widget.NestedScrollView>