<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/buttontextcolor"
    tools:context=".PlanRenewal.UpgradeTopUpReviewPackageActivity">
    <LinearLayout
        android:id="@+id/headerLayout"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back_1"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="20dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/manrope_medium"
            android:text="@string/review_package"
            />


    </LinearLayout>
    <View
        android:layout_marginBottom="20dp"
        android:id="@+id/view"
        android:layout_below="@id/headerLayout"
        android:background="@color/tabbackground"
        android:layout_width="match_parent"
        android:layout_height="2dp"/>
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:id="@+id/nested"
        android:layout_above="@id/linearpay"
        android:layout_below="@id/view">
        <LinearLayout
            android:layout_marginHorizontal="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/membersLayout"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="10dp"
                android:paddingHorizontal="15dp"
                android:paddingVertical="20dp"
                android:background="@drawable/review_rectangle"
                android:orientation="horizontal">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView
                            android:text="Members List"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="10dp"
                            android:fontFamily="@font/manrope_semi_bold"
                            android:textColor="@color/white"
                            android:textSize="16dp"/>
                        <ImageView
                            android:id="@+id/editMembers"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/edir"/>
                    </LinearLayout>
                    <androidx.recyclerview.widget.RecyclerView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:orientation="vertical"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        android:id="@+id/membersListRecyclerView" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginBottom="16dp"
                android:paddingHorizontal="15dp"
                android:background="@drawable/review_rectangle"
                android:paddingVertical="15dp"
                android:orientation="vertical">
                <TextView
                    android:text="@string/package_details"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/white"
                    android:textSize="16sp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:id="@+id/linearPackage"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/current_package"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:id="@+id/tvcurrent_package"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:id="@+id/linearEndDate"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/current_end_date"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:id="@+id/tvcurrent_end_date"
                        android:gravity="end"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:id="@+id/linearPackageStart"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/new_package_start"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:id="@+id/tvnew_package_start"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:id="@+id/linearPackageEnd"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/new_package_end"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:id="@+id/tvnew_package_end"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:id="@+id/linearPrefernce"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/training_preference"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:id="@+id/tvtraining_preference"
                        android:gravity="end"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:id="@+id/linearTotalSession"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/total_sessions"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:id="@+id/tvTotalSession"
                        android:gravity="end"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:visibility="gone"
                    android:id="@+id/linearTopupSession"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/topup_sessions"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:id="@+id/tvTopupSessionValue"
                        android:gravity="end"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:id="@+id/linearValidity"
                    android:orientation="horizontal">
                    <TextView
                        android:text="@string/validity"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/smallTextcolor"
                        android:textSize="14sp"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:id="@+id/tvValidity"
                        android:gravity="end"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/headingcolor"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="10dp"
                android:layout_marginBottom="16dp"
                android:paddingHorizontal="15dp"
                android:id="@+id/linear"
                android:paddingVertical="20dp"
                android:background="@drawable/review_rectangle"
                android:orientation="vertical">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/linearCoupon"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/discount"/>
                    <TextView
                        android:text="@string/view_coupons_amp_offers"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:layout_marginLeft="10dp"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/white"
                        android:textSize="16dp"/>
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/arrow_right"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/linearShowCoupon"
                    android:background="@drawable/offer_rectangle"
                    android:paddingHorizontal="10dp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:layout_marginTop="15dp"
                    android:paddingVertical="5dp"
                    android:orientation="horizontal">
                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"

                        >
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="15dp"
                            android:paddingVertical="5dp"
                            android:layout_margin="5dp"
                            android:textStyle="bold"
                            android:textSize="16dp"
                            android:fontFamily="@font/manrope_medium"
                            android:background="@drawable/dotted_rectangle"
                            android:textColor="@color/subheadingcolor"
                            android:text="FIRST200"/>
                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:layout_marginStart="20dp"

                            android:src="@drawable/scissor"/>
                    </RelativeLayout>

                    <TextView
                        android:text="Save AED 100"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:layout_marginLeft="10dp"
                        android:fontFamily="@font/manrope_medium"
                        android:textColor="@color/white"
                        android:textSize="14dp"/>
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/delete"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:id="@+id/linearpay"
        android:background="@color/tabbackground"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical"
        android:layout_alignParentBottom="true"
        android:paddingHorizontal="20dp"
        >
        <LinearLayout
            android:id="@+id/linearBill"
            android:layout_width="0dp"
            android:layout_weight="0.3"
            android:layout_height="wrap_content"
            android:layout_marginEnd="15dp"
            android:orientation="vertical">
            <LinearLayout
                android:layout_width="wrap_content"
                android:orientation="horizontal"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="28sp"
                    android:id="@+id/tvPrice"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_bold"
                    android:text=""/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:layout_marginTop="3dp"
                    android:layout_gravity="center"
                    android:layout_marginLeft="5dp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/manrope_regular_400"
                    android:text="AED"/>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/smallTextcolor"
                android:fontFamily="@font/manrope_semi_bold"
                android:text="@string/view_breakdown"/>
        </LinearLayout>
        <TextView
            android:layout_width="0dp"
            android:layout_weight="0.5"
            android:layout_height="wrap_content"
            android:text="@string/make_payment"
            android:background="@drawable/white_rectangle"
            android:textColor="@color/buttontextcolor"
            android:textSize="16sp"
            android:layout_gravity="center_vertical"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:paddingHorizontal="24dp"
            android:id="@+id/tvPayment"
            android:textAllCaps="true"
            android:fontFamily="@font/manrope_bold"
            />
    </LinearLayout>
</RelativeLayout>