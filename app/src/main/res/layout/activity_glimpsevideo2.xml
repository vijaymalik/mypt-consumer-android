<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/buttontextcolor"
    android:fitsSystemWindows="true"

    tools:context=".activities.GlimpsevideoActivity2">
    <ImageView
        android:layout_width="45dp"
        android:layout_alignParentEnd="true"
        android:layout_marginHorizontal="15dp"
        android:layout_marginVertical="15dp"
        android:id="@+id/imclose"
        android:src="@drawable/close_rectangle"
        android:layout_height="45dp"/>
    <androidx.cardview.widget.CardView

        android:layout_marginHorizontal="15dp"
        android:layout_marginBottom="15dp"
        app:cardCornerRadius="12dp"
        android:layout_width="match_parent"
        android:layout_below="@+id/imclose"
        android:layout_height="match_parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <VideoView
                android:focusable="false"
                android:layout_alignParentStart="true"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_alignParentBottom="true"
                android:id="@+id/videoView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                />
            <LinearLayout
                android:layout_width="80dp"
                android:id="@+id/linearplay"
                android:gravity="center"
                android:layout_centerInParent="true"
                android:background="@drawable/play_blur_background"
                android:layout_height="80dp">
                <ImageView
                    android:id="@+id/play"
                    android:src="@drawable/pause"
                    android:layout_width="43dp"
                    android:padding="4dp"
                    android:layout_height="43dp"/>
            </LinearLayout>

        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>