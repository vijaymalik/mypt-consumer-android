<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:layout_marginStart="2dp"
        android:layout_marginEnd="10dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="10dp"
        app:cardBackgroundColor="@color/tabbackground"
        app:cardCornerRadius="20dp"
        android:layout_width="180dp"
        android:layout_height="300dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <ImageView
                android:adjustViewBounds="true"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="50dp"
                android:src="@drawable/dummy_product"
                android:layout_width="120dp"
                android:layout_height="120dp"/>

            <LinearLayout
                android:padding="10dp"
                android:background="@drawable/product_gradient"
                android:orientation="vertical"
                android:layout_alignParentBottom="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/manrope_medium"
                    android:text="HandGripper - Green  5kg to 60kg"
                    />
                <LinearLayout
                    android:layout_marginTop="5dp"
                    android:orientation="horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:id="@+id/actualPrice"
                        android:fontFamily="@font/manrope_medium"
                        android:text="200AED"
                        />
                    <TextView
                        android:layout_marginStart="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/edittextbordercolor"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:id="@+id/oldPrice"
                        android:fontFamily="@font/manrope_medium"
                        android:text="200AED"
                        />
                </LinearLayout>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_margin="10dp"
                app:cardCornerRadius="10dp"
                android:layout_alignParentEnd="true"
                app:cardBackgroundColor="@color/home_frag_blk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
               <LinearLayout
                   android:gravity="center_vertical"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:orientation="horizontal"
                   android:paddingHorizontal="8dp"
                   android:paddingVertical="3dp">
                   <TextView
                       android:layout_width="wrap_content"
                       android:layout_height="wrap_content"
                       android:textColor="@color/headingcolor"
                       android:textSize="12sp"
                       android:textStyle="bold"
                       android:id="@+id/rating"
                       android:fontFamily="@font/manrope_medium"
                       android:text="4.5"
                       />

                   <ImageView
                       android:layout_marginStart="5dp"
                       android:layout_width="16sp"
                       android:layout_height="16sp"
                       android:src="@drawable/star"/>
               </LinearLayout>
            </androidx.cardview.widget.CardView>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>