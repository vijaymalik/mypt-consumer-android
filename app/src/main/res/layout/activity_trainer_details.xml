<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@drawable/onboarding_backgrd_2"
    tools:context=".activities.TrainerDetails">


    <androidx.core.widget.NestedScrollView

        android:scrollbars="none"
        android:layout_alignTop="@+id/bookSlot"
        android:layout_alignParentTop="true"
        android:id="@+id/scrollView"
        android:layout_marginBottom="65dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="340dp">
                <ImageView
                    android:id="@+id/trainerImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    />
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bottom_navigation_gradient"/>
                <RelativeLayout
                    android:layout_marginTop="5dp"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:id="@+id/back"
                        android:layout_marginHorizontal="15dp"
                        android:src="@drawable/ic_back_arrow_new"
                        />

                    <androidx.cardview.widget.CardView
                        android:visibility="gone"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="10dp"
                        app:cardBackgroundColor="@color/headingcolor"
                        app:cardCornerRadius="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <androidx.cardview.widget.CardView
                            app:cardBackgroundColor="@color/buttontextcolor"
                            android:layout_margin="1dp"
                            android:layout_gravity="center"
                            app:cardCornerRadius="8dp"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <TextView
                                android:paddingHorizontal="15dp"
                                android:paddingVertical="8dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/headingcolor"
                                android:textSize="14sp"
                                android:id="@+id/follow_1"
                                android:fontFamily="@font/manrope_medium"
                                android:text="@string/follow"
                                />
                        </androidx.cardview.widget.CardView>
                    </androidx.cardview.widget.CardView>
                </RelativeLayout>
                <LinearLayout
                    android:layout_marginBottom="20dp"
                    android:layout_marginHorizontal="15dp"
                    android:layout_alignParentBottom="true"
                    android:gravity="center_vertical"
                    android:layout_marginVertical="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/white"
                        android:textSize="24sp"
                        android:text="Ruba Darwich"
                        android:id="@+id/userName"
                        android:fontFamily="@font/clash_display_medium"
                        />
                    <View
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="1dp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginHorizontal="2dp"
                        android:src="@drawable/star"/>
                    <TextView
                        android:id="@+id/avgRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/white"
                        android:textSize="12sp"/>
                    <View
                        android:layout_marginHorizontal="5dp"
                        android:layout_width="3dp"
                        android:layout_height="3dp"
                        android:background="@drawable/dot"/>
                    <TextView
                        android:id="@+id/totalRatings"
                        android:layout_marginEnd="5dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="12sp"/>




                    <ImageView
                        android:layout_marginHorizontal="5dp"
                        android:layout_width="24dp"
                        android:visibility="gone"
                        android:layout_height="24dp"
                        android:src="@drawable/badge"/>


                    <RelativeLayout
                        android:layout_width="0dp"
                        android:visibility="gone"
                        android:layout_height="wrap_content"
                        android:layout_weight="1">
                        <LinearLayout
                            android:paddingHorizontal="16dp"
                            android:layout_marginBottom="5dp"
                            android:layout_alignParentEnd="true"
                            android:background="@drawable/product_gradient_rounded_corner"
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="50dp"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/headingcolor"
                                android:textSize="18sp"
                                android:id="@+id/followersCount"
                                android:fontFamily="@font/manrope_semi_bold"
                                />
                            <TextView
                                android:layout_marginBottom="5dp"
                                android:text="@string/followers"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope_semi_bold"
                                android:textColor="@color/headingcolor"
                                android:textSize="12sp"/>
                        </LinearLayout>

                    </RelativeLayout>
                </LinearLayout>
            </RelativeLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_marginHorizontal="15dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/location"/>
                <TextView
                    android:id="@+id/distance"
                    android:layout_marginHorizontal="5dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/funnel_sans_semibold"
                    android:textColor="@color/white"
                    android:lineHeight="18sp"
                    android:textSize="14sp"/>
                <View
                    android:layout_marginEnd="5dp"
                    android:layout_width="3dp"
                    android:layout_height="3dp"
                    android:background="@drawable/dot"/>
                <TextView
                    android:id="@+id/place"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:minLines="1"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:lineHeight="18sp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/funnel_sans_semibold"
                    android:textColor="@color/white"
                    android:textSize="14sp"/>


            </LinearLayout>
            <HorizontalScrollView
                android:visibility="gone"
                android:layout_marginTop="25dp"
                android:layout_marginHorizontal="15dp"
                android:scrollbars="none"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:orientation="horizontal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">
                    <LinearLayout
                        android:paddingVertical="6dp"
                        android:paddingHorizontal="8dp"
                        android:background="@drawable/category_border_bg"
                        android:id="@+id/aboutMe"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:src="@drawable/dumbell_fill"
                            android:layout_marginEnd="5dp"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>
                        <TextView
                            android:text="@string/about_me"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_marginStart="10dp"
                        android:paddingVertical="6dp"
                        android:paddingHorizontal="8dp"
                        android:id="@+id/review"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:src="@drawable/review"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>
                        <TextView
                            android:layout_marginStart="5dp"
                            android:text="@string/review"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_marginStart="10dp"
                        android:paddingVertical="6dp"
                        android:paddingHorizontal="8dp"
                        android:id="@+id/whyTrain"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:src="@drawable/story"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>
                        <TextView
                            android:layout_marginStart="5dp"
                            android:text="@string/why_train_with_me"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <LinearLayout

                        android:layout_marginStart="10dp"
                        android:paddingVertical="6dp"
                        android:paddingHorizontal="8dp"
                        android:id="@+id/mediaGallery"
                        android:gravity="center_vertical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:src="@drawable/gallery"
                            android:layout_width="16dp"
                            android:layout_height="16dp"/>
                        <TextView
                            android:layout_marginStart="5dp"
                            android:text="@string/media_gallery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/manrope_medium"
                            android:textColor="@color/white"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:layout_marginTop="15dp"
                android:layout_marginHorizontal="15dp"
                android:text=""
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:id="@+id/aboutTrainerText"
                android:lineHeight="18sp"
                android:fontFamily="@font/funnel_sans_regular"
                android:textColor="@color/subheadingcolor"
                android:textSize="14sp"/>

            <TextView

                android:text="... Read More"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/tvreadMore"
                android:visibility="gone"
                android:fontFamily="@font/funnel_sans_medium"
                android:textColor="#F6AA54"
                android:textSize="14sp"/>
            <androidx.recyclerview.widget.RecyclerView
                android:layout_marginStart="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/specialitiesRecyclerView"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:orientation="horizontal"
                />
            <LinearLayout
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="20dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout
                    android:gravity="center"
                    android:background="@drawable/product_gradient_rounded_corner"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1">
                    <TextView
                        android:layout_marginHorizontal="10dp"
                        android:text="5+"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/totalExp"
                        android:fontFamily="@font/clash_display_medium"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="30sp"/>
                    <TextView
                        android:gravity="center"
                        android:text="@string/years_of_experience"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/white"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_marginHorizontal="10dp"
                    android:gravity="center"
                    android:background="@drawable/product_gradient_rounded_corner"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1">
                    <TextView
                        android:layout_marginTop="15dp"
                        android:layout_marginHorizontal="10dp"
                        android:text="4.2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/avgRating1"
                        android:fontFamily="@font/clash_display_medium"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="30sp"/>
                    <TextView
                        android:gravity="center"
                        android:layout_marginBottom="15dp"
                        android:text="@string/average_rating1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/white"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout

                    android:gravity="center"
                    android:background="@drawable/product_gradient_rounded_corner"
                    android:orientation="vertical"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1">
                    <TextView
                        android:layout_marginTop="15dp"
                        android:layout_marginHorizontal="10dp"
                        android:text="234"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/clientsCoached"
                        android:fontFamily="@font/clash_display_medium"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="30sp"/>
                    <TextView
                        android:layout_marginBottom="15dp"
                        android:text="@string/clients_coached1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:textColor="@color/white"
                        android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>

            <TextView
                android:visibility="gone"
                android:layout_marginTop="30dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/specialities"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:id="@+id/linearCertificate"
                android:orientation="vertical"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_marginTop="30dp"
                    android:layout_marginHorizontal="15dp"
                    android:text="@string/certifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:orientation="horizontal"
                    android:layout_marginLeft="15dp"
                    android:layout_marginRight="5dp"
                    android:id="@+id/certificateRecycler"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:id="@+id/LinearWhyTrainWithMe"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_marginTop="30dp"
                    android:layout_marginHorizontal="15dp"
                    android:text="@string/why_train_with_me"
                    android:layout_width="wrap_content"

                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"/>
                <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
                    android:descendantFocusability="blocksDescendants"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginVertical="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        app:cardCornerRadius="24dp"
                        app:layout_constraintDimensionRatio="4:3"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <VideoView
                                android:focusable="false"
                                android:layout_alignParentStart="true"
                                android:layout_alignParentEnd="true"
                                android:layout_alignParentTop="true"
                                android:layout_alignParentBottom="true"
                                android:id="@+id/videoView"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent" />

                            <ImageView
                                android:id="@+id/play"
                                android:src="@drawable/play"
                                android:layout_width="50dp"
                                android:layout_height="50dp"
                                android:layout_centerInParent="true" />
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>

            <TextView
                android:layout_marginTop="30dp"
                android:layout_marginHorizontal="15dp"
                android:text="@string/personal_motivation_quote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/manrope_medium"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp"/>
            <LinearLayout
                android:paddingVertical="10dp"
                android:layout_marginHorizontal="15dp"
                android:layout_marginVertical="10dp"
                android:orientation="vertical"
                android:background="@drawable/motivation_gradient_rounded_corner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:gravity="center"
                    android:layout_marginVertical="15dp"
                    android:layout_marginHorizontal="10dp"
                    android:text="“ Believe you can and you're halfway there ”"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/tvQuote"
                    android:fontFamily="@font/clash_display_medium"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="24sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:visibility="gone"
                    android:fontFamily="@font/clash_display_medium"
                    android:textColor="@color/subheadingcolor"
                    android:text="-Theodore Roosevelt"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginVertical="15dp"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:orientation="vertical"
                android:id="@+id/linearMedia"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_marginTop="30dp"
                    android:layout_marginHorizontal="15dp"
                    android:text="@string/media_gallery"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/manrope_medium"
                    android:textColor="@color/smallTextcolor"
                    android:textSize="16sp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:orientation="horizontal"
                    android:layout_marginStart="14dp"
                    android:descendantFocusability="blocksDescendants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:id="@+id/galleryRecyclerView"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <LinearLayout
        android:visibility="gone"
        android:background="@color/buttontextcolor"
        android:id="@+id/headerLayout"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:paddingVertical="10dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back_1"
            android:layout_marginHorizontal="10dp"
            android:src="@drawable/backarrow"
            />
        <TextView
            android:layout_marginEnd="10dp"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="@color/headingcolor"
            android:textSize="14sp"
            android:textStyle="bold"
            android:id="@+id/trainerName_1"
            android:fontFamily="@font/clash_display_medium"
            android:text="Chrstene De Koning"
            />

        <androidx.cardview.widget.CardView
            android:layout_marginEnd="10dp"
            app:cardBackgroundColor="@color/headingcolor"
            app:cardCornerRadius="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <androidx.cardview.widget.CardView
                app:cardBackgroundColor="@color/buttontextcolor"
                android:layout_margin="1dp"
                android:layout_gravity="center"
                app:cardCornerRadius="8dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/headingcolor"
                    android:textSize="14sp"
                    android:id="@+id/follow"
                    android:fontFamily="@font/manrope_medium"
                    android:text="@string/follow"
                    />
            </androidx.cardview.widget.CardView>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
    <TextView
        android:visibility="gone"
        android:layout_width="match_parent"
        android:id="@+id/bookSlot"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:layout_marginBottom="5dp"
        android:background="@drawable/white_rectangle"
        android:gravity="center"
        android:fontFamily="@font/manrope_bold"
        android:paddingVertical="15dp"
        android:textFontWeight="700"
        android:textAllCaps="true"
        android:letterSpacing="0.05"
        android:layout_alignParentBottom="true"
        android:text="@string/book_a_slot"
        android:textColor="@color/buttontextcolor"
        android:textSize="16sp" />
</RelativeLayout>