<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/buttontextcolor"
    tools:context=".onBoarding.PersonalizedActivity2">
    <ImageView
        android:id="@+id/im"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        android:src="@drawable/chest_press_dark_blur"
        />
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:id="@+id/back"
            android:layout_marginHorizontal="20dp"
            android:layout_marginVertical="20dp"
            android:layout_alignParentStart="true"
            android:src="@drawable/backarrow"
            />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="50dp"
            android:fontFamily="@font/clashdisplay_medium"
            android:gravity="center"
            android:text="@string/where_would_you_like_to_train"
            android:textColor="@color/headingcolor"
            android:textSize="32sp"
             />

        <ImageView
            android:id="@+id/homeWorkout"
            android:layout_marginHorizontal="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:cropToPadding="true"
            android:adjustViewBounds="true"
            android:src="@drawable/home_workout"
            />
        <ImageView
            android:layout_marginTop="20dp"
            android:id="@+id/gymWorkout"
            android:layout_marginHorizontal="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/gym_workout"
            />
    </LinearLayout>
    <TextView
        android:layout_width="match_parent"
        android:id="@+id/tvcontinue"
        android:layout_alignParentBottom="true"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="15dp"
        android:layout_marginVertical="20dp"
        android:background="@drawable/rectangle_btn"
        android:gravity="center"
        android:fontFamily="@font/manrope_bold"
        android:paddingVertical="15dp"
        android:textAllCaps="true"
        android:letterSpacing="0.05"
        android:text="@string/cont_inue"
        android:textColor="@color/subheadingcolor"
        android:textSize="16sp" />
</RelativeLayout>