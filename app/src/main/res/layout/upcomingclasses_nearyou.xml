<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="356dp"
    app:cardCornerRadius="24dp"
    android:layout_marginVertical="10dp"
    android:layout_marginRight="10dp"
    android:id="@+id/card"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="240dp">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/upcoming_drawable"
        >
        <ImageView
            android:layout_width="wrap_content"
            android:adjustViewBounds="true"
            android:id="@+id/imclass"
            android:layout_alignParentEnd="true"
            android:layout_height="match_parent"/>
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="20dp"
                    android:id="@+id/cardStatus"
                    app:cardBackgroundColor="#960000"
                    app:cardCornerRadius="15dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/manrope_medium"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="10dp"
                        android:text="Almost Full"
                        android:id="@+id/tvStatus"
                        android:textColor="@color/headingcolor"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/clash_display_medium"
                    android:text="Zumba"
                    android:id="@+id/tvname"
                    android:textColor="@color/headingcolor"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="My PT Studio"
                        android:id="@+id/tvgymName"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="4dp"
                        android:layout_height="4dp"
                        android:layout_gravity="center"
                        android:layout_marginLeft="15dp"
                        android:background="@drawable/dot" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="15dp"
                        android:fontFamily="@font/manrope_medium"
                        android:text="Intermediate"
                        android:id="@+id/tvType"
                        android:textColor="@color/subheadingcolor"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="10dp"
                    android:id="@+id/tvTime"
                    android:fontFamily="@font/manrope_medium"
                    android:text="28 August, 10:00 AM GST"
                    android:textColor="@color/subheadingcolor"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="30dp"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal">

                    <androidx.cardview.widget.CardView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="@color/edittextbordercolor"
                        app:cardCornerRadius="20dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:layout_gravity="center"
                            app:cardBackgroundColor="#24262B"

                            app:cardCornerRadius="19dp">

                            <ImageView
                                android:layout_width="match_parent"
                                android:id="@+id/imTrainer"
                                android:scaleType="fitXY"
                                android:layout_height="match_parent"
                                android:src="@drawable/dummy_trainer" />
                        </androidx.cardview.widget.CardView>


                    </androidx.cardview.widget.CardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp"

                            android:fontFamily="@font/manrope_medium"
                            android:text="@string/trained_by"
                            android:textColor="#D7D8D9"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="15dp"
                            android:fontFamily="@font/manrope_medium"
                            android:text="Maria Hussain"
                            android:textColor="#D7D8D9"
                            android:id="@+id/tvTrainerName"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="20dp"
                        android:fontFamily="@font/clash_display_medium"
                        android:layout_gravity="bottom"
                        android:text="AED 299"
                        android:id="@+id/tvPrice"
                        android:textColor="#D7D8D9"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

    </RelativeLayout>


</androidx.cardview.widget.CardView>