<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".onBoarding.PhoneNumberScreenActivity">

    <co.com.mypt.utils.FullScreenVideoView
        android:id="@+id/idVideoView"
        android:layout_width="match_parent"
        android:visibility="gone"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/blurredView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/number_screen_gradient" />

    <ImageView
        android:id="@+id/blurImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_alignParentStart="true"
            android:layout_gravity="start"
            android:adjustViewBounds="true"
            android:scaleType="fitXY"
            android:src="@drawable/phone_screenlogo" />

        <TextView
            android:id="@+id/skipToHome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_gravity="end|center_vertical"
            android:drawablePadding="8dp"
            android:fontFamily="@font/google_sans_text_compat"
            android:gravity="center_vertical"
            android:text="@string/skip_to_home"
            android:textAllCaps="true"
            android:textColor="@color/text_color_neutral_200"
            android:textSize="14sp"
            android:textStyle="bold"
            app:drawableRightCompat="@drawable/ic_arrow_right"
            app:drawableTint="@color/subheadingcolor" />

    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/clash_display_medium"
                android:gravity="center"
                android:lineHeight="39sp"
                android:text="@string/let_your_fitness_journey_begin"
                android:textColor="@color/text_color_primary_white"
                android:textSize="32sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginVertical="20dp"
                android:fontFamily="@font/manrope_semi_bold"
                android:gravity="center"
                android:lineHeight="24sp"
                android:text="@string/share_your_details_to_create_your_account_get_started"
                android:textColor="@color/smallTextcolor"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="50dp"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/baseline_mail_outline_24"
                    android:visibility="gone"
                    app:tint="@color/subheadingcolor" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/emailInputLayout"
                    style="@style/NoUnderlineTextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:errorTextAppearance="@style/NoSpaceErrorStyle"
                    app:startIconDrawable="@drawable/baseline_mail_outline_24"
                    app:startIconTint="@color/white">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edemail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/manrope_semi_bold"
                        android:hint="@string/enter_your_email"
                        android:inputType="textEmailAddress"
                        android:paddingStart="45dp"
                        android:textColor="@color/white"
                        android:textColorHint="@color/subheadingcolor"
                        android:textSize="18sp" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <com.hbb20.CountryCodePicker
                    android:id="@+id/country_code_picker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:ccp_contentColor="@color/white"
                    app:ccp_padding="0dp"
                    app:ccp_showArrow="false"
                    app:ccp_showNameCode="false" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/flag"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:fontFamily="@font/manrope_variablefont_wght"
                    android:gravity="center"
                    android:text="+971"
                    android:textColor="@color/lightgreycolor"
                    android:textFontWeight="600"
                    android:textSize="20dp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="22dp"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginTop="1dp"
                    android:background="@color/bg_color_primary_white_55" />

                <EditText
                    android:id="@+id/edPhoneno"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:digits="1234567890"
                    android:fontFamily="@font/manrope_semi_bold"
                    android:hint="XXX-XXX-XXXX"
                    android:inputType="phone"
                    android:lineHeight="27sp"
                    android:maxLines="1"
                    android:textColor="@color/text_color_neutral_alpha"
                    android:textColorHint="@color/smallTextcolor"
                    android:textSize="18sp" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="2dp"
                android:drawableEnd="@drawable/ic_arrow_right"
                android:drawablePadding="8dp"
                android:drawableTint="@color/text_color_neutral_200"
                android:fontFamily="@font/clash_display_medium"
                android:gravity="center"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="@string/login_number"
                android:textAllCaps="true"
                android:textColor="@color/text_color_neutral_200"
                android:textSize="14sp"
                app:backgroundTint="@color/login_btn"
                app:cornerRadius="8dp"
                app:iconGravity="textEnd"
                app:iconPadding="8dp"
                app:useMaterialThemeColors="false" />


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="35dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:adjustViewBounds="true"
                    android:background="#1AFFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8sp"
                    android:fontFamily="@font/clash_display_medium"
                    android:lineSpacingExtra="2sp"
                    android:text="@string/or"
                    android:textColor="@color/buttongreycolor"
                    android:textFontWeight="600"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:adjustViewBounds="true"
                    android:background="#1AFFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:layout_marginBottom="12dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/im_gmail"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_alignParentStart="true"
                    android:layout_marginHorizontal="10dp"
                    android:src="@drawable/socialicons" />

                <ImageView
                    android:id="@+id/imfb"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_alignParentStart="true"
                    android:layout_marginHorizontal="10dp"
                    android:src="@drawable/facebook_icon" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>


</FrameLayout>