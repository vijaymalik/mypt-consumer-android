<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
<!--
     Outer gradient border
    <item>
        <shape>
            <gradient
                android:angle="360"
                android:startColor="#31343A"
                android:endColor="#878FA0"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>

     Inner transparent background -->
    <item
        android:bottom="1dp"
        android:top="1dp"
        android:left="1dp" android:right="1dp">
        <shape>
            <gradient
                android:angle="90"
                android:startColor="#101113"
                android:endColor="#474D60"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>

</layer-list>
