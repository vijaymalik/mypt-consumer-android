<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0FA958" />
            <corners android:radius="15dp"/>
        </shape>
    </item>
    <item
        android:left="1sp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#101113"
                android:endColor="#474D60"
                />
            <corners android:radius="15dp"/>
        </shape>
    </item>
</layer-list>
