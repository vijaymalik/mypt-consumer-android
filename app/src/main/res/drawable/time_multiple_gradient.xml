<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:height="150dp">
        <shape
            android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="#101113"
                android:endColor="#991C1F21" />
        </shape>
    </item>
    <item android:top="100dp"
        android:height="50dp">
        <shape
            android:shape="rectangle">
            <solid android:color="#31343A"/>
        </shape>
    </item>
    <item android:top="150dp"
        android:height="90dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#101113"
                android:endColor="#991C1F21" />

        </shape>
    </item>
</layer-list>