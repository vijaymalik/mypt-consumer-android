<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- CHECKED : Neon glow -->
    <item android:state_checked="true">
        <layer-list>

            <!-- Glow -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#40E0FE08"/> <!-- neon with alpha -->
                    <corners android:radius="18dp"/>
                </shape>
            </item>

            <!-- Main background -->
            <item android:inset="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#E0FE08"/> <!-- neon -->
                    <corners android:radius="16dp"/>
                    <stroke
                        android:width="1dp"
                        android:color="#E0FE08"/>
                </shape>
            </item>

        </layer-list>
    </item>

    <!-- UNCHECKED -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="16dp"/>
            <stroke
                android:width="1dp"
                android:color="#40E0FE08"/>
        </shape>
    </item>

</selector>
