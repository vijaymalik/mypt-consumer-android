<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Border layer (gradient) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#29292A"
                android:endColor="#0029292A"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">

        <shape android:shape="rectangle">

            <!-- Base color -->
            <solid android:color="#101113"/>

            <!-- Radial gradient ON TOP of base -->
            <gradient
                android:type="radial"
                android:gradientRadius="140dp"
                android:startColor="#14FFFFFF"
                android:endColor="#00FFFFFF"
                android:centerX="0.5"
                android:centerY="0.0"/>

            <corners android:radius="11dp"/>
        </shape>
    </item>

</layer-list>