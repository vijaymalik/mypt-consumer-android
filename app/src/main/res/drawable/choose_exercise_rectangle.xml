<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

<!-- Outer gradient border -->
<item>
    <shape>
        <stroke android:color="#9EBCFF" android:width="3dp"/>
        <corners android:radius="14dp" />
    </shape>
</item>

<!-- Inner transparent background -->
<item
    android:bottom="1dp"
    android:top="1dp"
    android:left="1dp" android:right="1dp">
    <shape>
        <gradient
            android:angle="135"
            android:startColor="#101113"
            android:endColor="#474D60"
            android:type="linear" />
        <corners android:radius="14dp" />
    </shape>
</item>

</layer-list>
