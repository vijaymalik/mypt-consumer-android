<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#31343A"
                android:endColor="#878FA0"
                android:angle="-45"/>
            <padding android:top="1dp"
                android:right="1dp"
                android:left="1dp"
                android:bottom="1dp"/>

            <corners android:radius="25dp"/>
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">

            <gradient
                android:startColor="#101113"
                android:endColor="#474D60"
                android:angle="135"/>
            <corners android:radius="25dp"/>
        </shape>
    </item>
</layer-list>