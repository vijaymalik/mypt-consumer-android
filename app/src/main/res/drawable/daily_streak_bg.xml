                android:top="1dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#474D60"
                android:endColor="#101113"
                />
            <corners android:radius="15dp" />

        </shape>
    </item>
</layer-list>