<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#000502"
                android:type="linear"
                android:startColor="#878FA0" />
            <corners
                android:topLeftRadius="15dp"
                android:topRightRadius="15dp"
                />
            <padding
                android:left="1dp"
                android:right="1dp"
                android:top="1dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#000502"/>
            <corners
                android:topLeftRadius="15dp"
                android:topRightRadius="15dp"
                />

        </shape>
    </item>
</layer-list>