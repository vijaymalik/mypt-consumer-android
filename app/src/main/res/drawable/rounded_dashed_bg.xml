<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="#2B2B2C"/>

    <!-- Rounded corners -->
    <corners android:radius="12dp"/>

    <!-- Dashed stroke -->
    <stroke
        android:width="2dp"
        android:color="#33FFFFFF"
        android:dashWidth="8dp"
        android:dashGap="4dp"/>
</shape>
