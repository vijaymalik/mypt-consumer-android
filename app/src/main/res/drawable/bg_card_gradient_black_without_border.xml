<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#101113"/>
            <corners android:radius="12dp"/>
        </shape>
    </item>

    <!-- Radial gradient (8% white glow) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp"/>

            <gradient
                android:type="radial"
                android:gradientRadius="140dp"
                android:centerX="50%"
                android:centerY="0%"
                android:startColor="#14FFFFFF"
            android:endColor="#00FFFFFF"/>
        </shape>
    </item>

</layer-list>