<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="CurvedBottomNavigationView">
        <attr name="cbn_selectedColor" format="color" />
        <attr name="cbn_unSelectedColor" format="color" />
        <attr name="cbn_animDuration" format="integer" />
        <attr name="cbn_fabElevation" format="dimension" />
        <attr name="cbn_elevation" format="dimension"/>
        <attr name="cbn_fabBg" format="color" />
        <attr name="cbn_bg" format="color" />

        <attr name="cbn_iconColor" format="color" />
        <attr name="cbn_titleColor" format="color" />
        <attr name="cbn_titleTextSize" format="integer" />
        <attr name="cbn_selectedIconColor" format="color" />
        <attr name="cbn_background" format="color" />
        <attr name="cbn_curve_radius" format="dimension" />
        <attr name="cbn_height" format="dimension" />
        <attr name="cbn_icon_size" format="dimension" />
        <attr name="cbn_selected_icon_size" format="dimension" />
        <attr name="cbn_fabColor" format="color" />
        <attr name="cbn_badgeTextColor" format="color" />
        <attr name="cbn_badgeBackgroundColor" format="color" />
        <attr name="cbn_titleFont" format="reference" />
        <attr name="cbn_badgeFont" format="reference" />
        <attr name="cbn_rippleColor" format="color" />
        <attr name="cbn_shadowColor" format="color" />
        <attr name="cbn_hasAnimation" format="boolean" />
    </declare-styleable>

    <declare-styleable name="SnakeView">
        <attr name="strokeColor" format="color" />
        <attr name="fillColor" format="color" />
        <attr name="strokeWidth" format="dimension" />

        <attr name="maximumNumberOfValues" format="integer" />
        <attr name="animationDuration" format="integer" />
        <attr name="scaleMode">
            <enum name="fixed" value="0" />
            <enum name="auto" value="1" />
        </attr>
        <attr name="chartStyle">
            <enum name="stroke" value="0" />
            <enum name="fill" value="1" />
            <enum name="fill_stroke" value="2" />
        </attr>
    </declare-styleable>
</resources>